---
/**
 * MiniSearch island — lazy-loads `/help-index.json` on first input focus, then
 * runs fuzzy search entirely client-side. ~10 KB JS; only ships on pages that
 * include this component.
 *
 * Styling mirrors the Vue HelpCenterPage hero search (rounded-3xl, soft shadow,
 * italic serif placeholder, inline 🔍 icon).
 */

interface Props {
  placeholder?: string;
}
const { placeholder = 'search the help center' } = Astro.props;
---

<div class="relative" data-help-search>
  <span class="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-xl opacity-40">🔍</span>
  <input
    type="search"
    placeholder={placeholder}
    autocomplete="off"
    class="w-full rounded-3xl border-2 border-[var(--color-border)] bg-white py-[18px] pl-14 pr-6 text-[17px] text-[var(--color-text)] shadow-[var(--soft-shadow)] transition-[border-color,box-shadow] duration-200 focus:border-sky-silk-300 focus:shadow-[0_8px_40px_rgba(174,214,241,0.2)] focus:outline-none"
    style="font-family: 'Source Serif 4', Georgia, serif; font-style: italic"
    data-help-search-input
  />
  <ul
    role="listbox"
    class="absolute left-0 right-0 top-full z-20 mt-2 hidden max-h-80 overflow-y-auto rounded-3xl bg-white p-2 shadow-lg"
    data-help-search-results
  ></ul>
</div>

<script>
  import MiniSearch from 'minisearch';

  interface Doc {
    id: string;
    title: string;
    excerpt: string;
    category: string;
    slug: string;
    text: string;
  }

  let search: MiniSearch<Doc> | null = null;
  let loading: Promise<void> | null = null;

  function loadIndex(): Promise<void> {
    if (search || loading) return loading ?? Promise.resolve();
    loading = fetch('/help-index.json')
      .then((r) => r.json() as Promise<Doc[]>)
      .then((docs) => {
        const idx = new MiniSearch<Doc>({
          fields: ['title', 'excerpt', 'text'],
          storeFields: ['title', 'excerpt', 'category', 'slug'],
          searchOptions: {
            boost: { title: 3, excerpt: 2 },
            fuzzy: 0.2,
            prefix: true,
          },
        });
        idx.addAll(docs);
        search = idx;
      });
    return loading;
  }

  document.querySelectorAll<HTMLElement>('[data-help-search]').forEach((root) => {
    const input = root.querySelector<HTMLInputElement>('[data-help-search-input]');
    const results = root.querySelector<HTMLUListElement>('[data-help-search-results]');
    if (!input || !results) return;

    const render = (q: string) => {
      if (!search || !q.trim()) {
        results.classList.add('hidden');
        results.innerHTML = '';
        return;
      }
      const hits = search.search(q, { combineWith: 'AND' }).slice(0, 8);
      if (hits.length === 0) {
        results.innerHTML =
          '<li class="px-4 py-3 text-sm text-secondary-400">no matches</li>';
        results.classList.remove('hidden');
        return;
      }
      results.innerHTML = hits
        .map((h) => {
          const href = `/help/${h.category}/${h.slug}`;
          return `<li><a href="${href}" class="flex items-start gap-3 rounded-xl px-3 py-2.5 text-left transition-colors hover:bg-[var(--tint-slate-5)]"><span class="flex-1"><span class="block text-sm font-medium text-secondary-500">${escape(h.title as string)}</span><span class="block text-xs text-secondary-400">${escape(h.excerpt as string)}</span></span></a></li>`;
        })
        .join('');
      results.classList.remove('hidden');
    };

    const escape = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);

    input.addEventListener('focus', () => void loadIndex(), { once: true });
    input.addEventListener('input', async () => {
      await loadIndex();
      render(input.value);
    });
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        results.classList.add('hidden');
      }
    });
  });
</script>
