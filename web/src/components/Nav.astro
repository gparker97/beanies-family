---
import { APP_URL } from '@beanies/brand/nav';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

// In-page anchors on the homepage stay as #anchors so the same-page smooth-scroll
// handler can intercept them. From other pages we prepend "/" so the browser
// navigates to the homepage first, then resolves the anchor.
const storyHref = isHome ? '#story' : '/#story';
const securityHref = isHome ? '#security' : '/#security';
---

<div id="scroll-progress" class="scroll-progress"></div>

<nav id="fnav" class="fnav" aria-label="main navigation">
  <a href="/" class="fnav__logo" data-scroll-top={isHome ? '' : undefined}>
    <img src="/brand/beanies_logo_transparent_logo_only_192x192.webp" alt="" width="192" height="192" decoding="async" />beanies<span class="fnav__logo-orange">.family</span>
  </a>
  <div class="fnav__right">
    <div class="fnav__links">
      <a href={storyHref} data-scroll-to={isHome ? 'story' : undefined}>my story</a>
      <a href={securityHref} data-scroll-to={isHome ? 'security' : undefined}>security</a>
      <a href="/blog">beanstalk</a>
      <a href="/guides">family library</a>
      <a href={`${APP_URL}/login`}>sign in</a>
    </div>
    <a href={`${APP_URL}/welcome`} class="fnav__cta">create your bean pod</a>
  </div>

  <!-- Hamburger button — hidden on wide screens via CSS, revealed below
       the width threshold where the full link row can't fit. -->
  <button
    type="button"
    id="fnav-toggle"
    class="fnav__hamburger"
    aria-label="open menu"
    aria-controls="fnav-drawer"
    aria-expanded="false"
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
</nav>

<!-- Drawer + overlay. Rendered at document level (not inside .fnav) so
     the pill's backdrop-filter + border radius don't clip the drawer.
     Hidden by default; CSS animates in when [data-open]. -->
<div id="fnav-overlay" class="fnav-overlay" inert></div>
<aside
  id="fnav-drawer"
  class="fnav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="site menu"
  inert
>
  <div class="fnav-drawer__head">
    <a href="/" class="fnav-drawer__brand" data-close-drawer data-scroll-top={isHome ? '' : undefined}>
      <img src="/brand/beanies_logo_transparent_logo_only_192x192.webp" alt="" width="192" height="192" decoding="async" />beanies<span class="fnav-drawer__brand-orange">.family</span>
    </a>
    <button
      type="button"
      id="fnav-close"
      class="fnav-drawer__close"
      aria-label="close menu"
    >
      <span aria-hidden="true">×</span>
    </button>
  </div>

  <ul class="fnav-drawer__links">
    <li><a href={storyHref} data-scroll-to={isHome ? 'story' : undefined} data-close-drawer>my story</a></li>
    <li><a href={securityHref} data-scroll-to={isHome ? 'security' : undefined} data-close-drawer>security</a></li>
    <li><a href="/blog" data-close-drawer>beanstalk</a></li>
    <li><a href="/guides" data-close-drawer>family library</a></li>
    <li><a href="/help" data-close-drawer>help</a></li>
  </ul>

  <div class="fnav-drawer__foot">
    <a href={`${APP_URL}/login`} class="fnav-drawer__signin" data-close-drawer>sign in</a>
    <a href={`${APP_URL}/welcome`} class="fnav-drawer__cta" data-close-drawer>create your bean pod</a>
  </div>
</aside>

<script>
  const scrollProgress = document.getElementById('scroll-progress') as HTMLElement | null;
  const fnav = document.getElementById('fnav') as HTMLElement | null;

  function onScroll() {
    const sy = window.scrollY;
    const dh = document.documentElement.scrollHeight - window.innerHeight;
    const pct = dh > 0 ? (sy / dh) * 100 : 0;
    if (scrollProgress) scrollProgress.style.width = pct + '%';
    if (fnav) fnav.classList.toggle('scrolled', sy > 20);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  function scrollToId(id: string) {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function scrollTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Same-page smooth-scroll only on homepage (where data-scroll-to is set).
  document.querySelectorAll<HTMLAnchorElement>('[data-scroll-to]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const id = a.getAttribute('data-scroll-to');
      if (id) scrollToId(id);
    });
  });
  document.querySelectorAll<HTMLAnchorElement>('[data-scroll-top]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      scrollTop();
    });
  });

  // ---- Mobile drawer ----
  const toggle = document.getElementById('fnav-toggle') as HTMLButtonElement | null;
  const close = document.getElementById('fnav-close') as HTMLButtonElement | null;
  const overlay = document.getElementById('fnav-overlay') as HTMLDivElement | null;
  const drawer = document.getElementById('fnav-drawer') as HTMLElement | null;
  const HTML = document.documentElement;

  function openDrawer() {
    if (!drawer || !overlay || !toggle) return;
    drawer.setAttribute('data-open', '');
    overlay.setAttribute('data-open', '');
    // `inert` (instead of aria-hidden=true) removes the closed drawer's
    // descendants from both focus and the accessibility tree without the
    // Lighthouse `aria-hidden-focus` violation that aria-hidden produces
    // when its container has focusable children.
    drawer.removeAttribute('inert');
    overlay.removeAttribute('inert');
    toggle.setAttribute('aria-expanded', 'true');
    HTML.style.overflow = 'hidden';
    // Focus the close button so keyboard users can Esc/close immediately.
    window.setTimeout(() => close?.focus(), 50);
  }

  function closeDrawer() {
    if (!drawer || !overlay || !toggle) return;
    drawer.removeAttribute('data-open');
    overlay.removeAttribute('data-open');
    drawer.setAttribute('inert', '');
    overlay.setAttribute('inert', '');
    toggle.setAttribute('aria-expanded', 'false');
    HTML.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    if (drawer?.hasAttribute('data-open')) {
      closeDrawer();
    } else {
      openDrawer();
    }
  });
  close?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.hasAttribute('data-open')) {
      closeDrawer();
    }
  });

  // Any link tagged [data-close-drawer] closes the drawer before the
  // browser starts the navigation — keeps the transition feeling tidy
  // even when the destination takes a beat to respond.
  document.querySelectorAll<HTMLAnchorElement>('[data-close-drawer]').forEach((a) => {
    a.addEventListener('click', () => closeDrawer());
  });

  // If the viewport crosses back above the hamburger threshold while the
  // drawer is open (e.g. rotating a tablet to landscape), close it so the
  // hidden drawer can't eat scroll or focus.
  const mql = window.matchMedia('(min-width: 820px)');
  mql.addEventListener('change', (e) => {
    if (e.matches) closeDrawer();
  });
</script>

<style>
  :root {
    --heritage-orange: #f15d22;
    --deep-slate: #2c3e50;
  }

  .fnav {
    align-items: center;
    backdrop-filter: blur(24px);
    background: rgb(255 255 255 / 82%);
    border: 1px solid rgb(44 62 80 / 6%);
    border-radius: 40px;
    display: flex;
    gap: 12px;
    left: 50%;
    padding: 6px 10px 6px 16px;
    position: fixed;
    top: 16px;
    transform: translateX(-50%);
    transition: box-shadow 300ms ease, background 500ms ease;
    z-index: 200;
  }
  .fnav.scrolled { box-shadow: 0 4px 24px rgb(44 62 80 / 8%); }

  .fnav__logo {
    align-items: center;
    color: var(--deep-slate);
    display: flex;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    gap: 0;
    text-decoration: none;
    white-space: nowrap;
  }
  .fnav__logo img { border-radius: 8px; height: 26px; margin-right: 7px; width: 26px; }
  .fnav__logo-orange { color: var(--heritage-orange); }

  .fnav__right { align-items: center; display: flex; gap: 8px; }
  .fnav__links { display: flex; gap: 2px; }
  .fnav__links a {
    border-radius: 16px;
    color: var(--deep-slate);
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.55;
    padding: 4px 10px;
    text-decoration: none;
    transition: all 200ms;
    white-space: nowrap;
  }
  .fnav__links a:hover { background: rgb(44 62 80 / 5%); opacity: 0.9; }

  .fnav__cta {
    background: var(--heritage-orange);
    border: none;
    border-radius: 20px;
    color: white;
    cursor: pointer;
    display: inline-block;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 6px 16px;
    text-decoration: none;
    transition: all 200ms;
    white-space: nowrap;
  }
  .fnav__cta:hover { background: #d14d1a; transform: translateY(-1px); }

  /* Hamburger button — hidden on wide viewports, revealed below the
     threshold where the full-link row won't fit. */
  .fnav__hamburger {
    align-items: center;
    background: transparent;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    display: none;
    flex-direction: column;
    gap: 4px;
    height: 36px;
    justify-content: center;
    padding: 0;
    transition: background-color 150ms;
    width: 36px;
  }
  .fnav__hamburger:hover { background: rgb(44 62 80 / 6%); }
  .fnav__hamburger:focus-visible {
    outline: 2px solid var(--heritage-orange);
    outline-offset: 2px;
  }
  .fnav__hamburger span {
    background: var(--deep-slate);
    border-radius: 2px;
    display: block;
    height: 2px;
    transition: transform 220ms ease, opacity 160ms ease;
    width: 18px;
  }
  .fnav__hamburger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .fnav__hamburger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .fnav__hamburger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .scroll-progress {
    background: var(--heritage-orange);
    height: 2px;
    left: 0;
    position: fixed;
    top: 0;
    transition: width 150ms linear;
    width: 0%;
    z-index: 300;
  }

  /* --- Drawer --- */
  .fnav-overlay {
    background: rgb(44 62 80 / 42%);
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: fixed;
    transition: opacity 260ms ease;
    z-index: 210;
  }
  .fnav-overlay[data-open] {
    opacity: 1;
    pointer-events: auto;
  }

  .fnav-drawer {
    background: white;
    border-radius: 0 0 24px 24px;
    box-shadow: 0 18px 42px rgb(44 62 80 / 18%);
    display: flex;
    flex-direction: column;
    left: 0;
    max-height: min(calc(100vh - 48px), 560px);
    overflow: hidden;
    position: fixed;
    right: 0;
    top: 0;
    transform: translateY(-100%);
    transition: transform 320ms cubic-bezier(0.32, 0.72, 0, 1);
    width: 100%;
    z-index: 220;
  }
  .fnav-drawer[data-open] {
    transform: translateY(0);
  }

  .fnav-drawer__head {
    align-items: center;
    border-bottom: 1px solid rgb(44 62 80 / 8%);
    display: flex;
    justify-content: space-between;
    padding: 20px 20px 18px;
  }
  .fnav-drawer__brand {
    align-items: center;
    color: var(--deep-slate);
    display: flex;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
  }
  .fnav-drawer__brand img {
    border-radius: 8px;
    height: 26px;
    margin-right: 8px;
    width: 26px;
  }
  .fnav-drawer__brand-orange { color: var(--heritage-orange); }

  .fnav-drawer__close {
    align-items: center;
    background: transparent;
    border: none;
    border-radius: 999px;
    color: rgb(44 62 80 / 75%);
    cursor: pointer;
    display: inline-flex;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 1.75rem;
    height: 36px;
    justify-content: center;
    line-height: 1;
    padding: 0;
    transition: background-color 150ms, color 150ms;
    width: 36px;
  }
  .fnav-drawer__close:hover {
    background: rgb(44 62 80 / 6%);
    color: var(--deep-slate);
  }

  .fnav-drawer__links {
    display: flex;
    flex: 1;
    flex-direction: column;
    list-style: none;
    margin: 0;
    overflow-y: auto;
    padding: 12px 8px;
  }
  .fnav-drawer__links a {
    border-radius: 12px;
    color: var(--deep-slate);
    display: block;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    padding: 13px 16px;
    text-decoration: none;
    transition: background-color 150ms, color 150ms;
  }
  .fnav-drawer__links a:hover,
  .fnav-drawer__links a:focus-visible {
    background: rgb(44 62 80 / 5%);
    color: var(--heritage-orange);
    outline: none;
  }

  .fnav-drawer__foot {
    border-top: 1px solid rgb(44 62 80 / 8%);
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px 20px 24px;
  }
  .fnav-drawer__signin {
    color: var(--deep-slate);
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    opacity: 0.6;
    padding: 8px 0;
    text-align: center;
    text-decoration: none;
    transition: opacity 150ms, color 150ms;
  }
  .fnav-drawer__signin:hover {
    color: var(--heritage-orange);
    opacity: 1;
  }
  .fnav-drawer__cta {
    background: var(--heritage-orange);
    border-radius: 999px;
    color: white;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 14px 20px;
    text-align: center;
    text-decoration: none;
    transition: background-color 200ms, transform 200ms;
  }
  .fnav-drawer__cta:hover {
    background: #d14d1a;
    transform: translateY(-1px);
  }

  /* Hamburger threshold. Above 820px, the full nav (5 links + CTA at
     0.85rem) fits on a single row comfortably. Below, swap to the
     drawer — no ugly wrapping, no compromise. */
  @media (max-width: 820px) {
    .fnav {
      gap: 8px;
      padding: 5px 6px 5px 14px;
    }
    .fnav__logo { font-size: 0.95rem; }
    .fnav__logo img { height: 24px; margin-right: 6px; width: 24px; }
    .fnav__right { display: none; }
    .fnav__hamburger { display: inline-flex; }
  }

  @media (max-width: 520px) {
    .fnav { max-width: calc(100vw - 16px); }
    .fnav__logo { font-size: 0.9rem; }
    .fnav__logo img { height: 22px; margin-right: 5px; width: 22px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .fnav-drawer { transition: none; }
    .fnav-overlay { transition: none; }
    .fnav__hamburger span { transition: none; }
  }
</style>
