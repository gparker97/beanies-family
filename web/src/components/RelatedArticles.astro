---
interface RelatedItem {
  title: string;
  href: string;
  excerpt?: string;
}

interface Props {
  items: RelatedItem[];
  heading?: string;
}

const { items, heading = 'related reading' } = Astro.props;
---

{
  items.length > 0 && (
    <aside class="mt-16 border-t border-secondary-100/60 pt-10">
      <h2 class="font-outfit text-lg font-semibold text-secondary-500">{heading}</h2>
      <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-2xl border border-secondary-100/60 bg-white p-5 transition-shadow hover:shadow-md"
            >
              <p class="font-outfit text-sm font-semibold text-secondary-500">{item.title}</p>
              {item.excerpt && (
                <p class="mt-2 line-clamp-2 text-xs text-secondary-400">{item.excerpt}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
