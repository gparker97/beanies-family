---
/**
 * Substack newsletter subscribe strip. Embeds the gpbeanies.substack.com
 * subscribe iframe inside a gradient card matching the Vue blog version 1:1.
 *
 * Used on /blog (index) and /blog/[slug] (post pages) as a primary inbound
 * channel — subscribers are future users, so we want this visible wherever
 * someone is reading long-form content.
 */
---

<section class="substack-strip">
  <p class="substack-strip-heading">
    follow me on substack for a new beanstalk post every friday (well, usually)
  </p>
  <div class="substack-strip-embed-wrap">
    <iframe
      src="https://gpbeanies.substack.com/embed"
      width="100%"
      height="120"
      style="background: transparent; border: none"
      frameborder="0"
      scrolling="no"
      title="Subscribe to the beanstalk on Substack"
      loading="lazy"></iframe>
  </div>
</section>

<style>
  .substack-strip {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;

    background: linear-gradient(135deg, var(--heritage-orange) 0%, var(--terracotta) 100%);
    border-radius: 20px;
    overflow: hidden;
    padding: 16px 24px;
    text-align: center;
  }

  .substack-strip-heading {
    color: rgb(255 255 255 / 90%);
    font-family: Outfit, sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 4px;
  }

  .substack-strip-embed-wrap {
    background: rgb(255 255 255 / 15%);
    border-radius: 14px;
    margin-top: 4px;
    padding: 4px;
  }

  .substack-strip-embed-wrap iframe {
    border-radius: 10px;
    display: block;
    width: 100%;
  }
</style>
