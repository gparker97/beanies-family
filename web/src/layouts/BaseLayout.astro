---
import { SEO } from 'astro-seo';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { ORGANIZATION, WEBSITE } from '@beanies/brand/schema';
import { SITE_URL } from '@beanies/brand/nav';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Canonical path starting with "/" (the site URL is prepended). Defaults to current pathname. */
  canonicalPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** Article-specific OG fields (used on blog posts). */
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  /** Tags rendered as article:tag OG meta. */
  tags?: string[];
  /** Additional per-page JSON-LD nodes merged into the @graph. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Mark the page as noindex (e.g. staging preview, utility pages). */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = `${SITE_URL}/brand/beanies-logo.png`,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  author,
  tags,
  jsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(canonicalPath, SITE_URL).toString();
const globalLd = [ORGANIZATION, WEBSITE];
const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Favicon set matches the Vue app 1:1 so the tab icon is identical
         across prod (apex) and this site during Phase B / after cutover. -->
    <link rel="icon" type="image/png" href="/brand/beanies_small_bean_favicon_32x32.png" />
    <link rel="apple-touch-icon" href="/brand/beanies_father_son_icon_192x192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: { title, type: ogType, image: ogImage, url: canonical },
        optional: { description, siteName: 'beanies.family', locale: 'en_US' },
        article:
          ogType === 'article'
            ? {
                publishedTime,
                modifiedTime,
                authors: author ? [author] : undefined,
                tags,
              }
            : undefined,
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage,
      }}
    />
    <JsonLd data={[...globalLd, ...extraLd]} />

    <!-- Plausible analytics (cookie-free, privacy-first) -->
    <script is:inline async src="https://plausible.io/js/pa-3pxexgz2YF03NyMDucQKN.js"></script>
    <script is:inline>
      ((window.plausible =
        window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        }),
        (plausible.init =
          plausible.init ||
          function (i) {
            plausible.o = i || {};
          }));
      plausible.init();
    </script>

    <!-- Web Vitals RUM → Plausible custom events -->
    <script>
      import '../scripts/vitals';
    </script>
    <!-- PWA-install escape hatch (#167): users who installed the Vue PWA
         pre-cutover have start_url: '/' baked into the install, so every
         launch lands here. Detect standalone display-mode and redirect
         them to app.beanies.family preserving the path. Regular browser
         visits never match (display-mode is 'browser') and see the
         marketing site normally. `is:inline` + placing this at the top of
         <body> ensures it runs before any other script or content paints. -->
    <script is:inline>
      (function () {
        try {
          var isStandalone =
            window.matchMedia &&
            window.matchMedia('(display-mode: standalone)').matches;
          var isIOS = window.navigator.standalone === true;
          if (isStandalone || isIOS) {
            var url = new URL(
              'https://app.beanies.family' +
                window.location.pathname +
                window.location.search +
                window.location.hash
            );
            url.searchParams.set('from-stale-pwa', '1');
            window.location.replace(url.toString());
          }
        } catch (e) {
          // No-op — matchMedia unsupported, fall through to marketing page.
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[#f8f9fa] text-secondary-500">
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
