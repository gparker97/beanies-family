---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { AUTHOR } from '@beanies/brand/schema';
---

<BaseLayout
  title="about greg - beanies.family"
  description="greg is the founder of beanies.family. father of three, IT nerd, believer in privacy-preserving software, living in singapore, and the dude that writes the beanstalk."
  canonicalPath="/about/greg"
  jsonLd={{ ...AUTHOR, description: 'founder of beanies.family, father, software engineer' }}
>
  <article class="mx-auto max-w-3xl px-6 pb-16 pt-28">
    <Breadcrumbs items={[{ label: 'home', href: '/' }, { label: 'about', href: '/about/greg' }, { label: 'greg', href: '/about/greg' }]} />

    <header class="mt-8 space-y-4">
      <h1 class="font-outfit text-4xl font-bold text-secondary-500">greg</h1>
      <p class="text-lg text-secondary-400">founder, beanies.family</p>
    </header>

    <section class="mt-10 space-y-5 text-secondary-500 leading-relaxed">
      <p>
        Hi. I'm greg. I built beanies.family because my family needed a way to stay organized (or, I did).
      </p>
      <p>
        I've been building software and doing IT stuff for over two decades, and I can talk about it forever,
        so just tell me if I get annoying. beanies.family is the focal point of our family, and I'm here to
        share it with yours.
      </p>
      <p>
        The <a href="/blog" class="text-primary-500 hover:text-primary-600">beanstalk blog</a> is
        where I write about the hows and whys of beanies.family, the philosophy behind local-first
        software, vibe coding in general, and other random stuff that may or may not have anything 
        to do with building an app, such as the chaos of raising 3 crazy (but cute) little boys.
      </p>
    </section>

    <section class="mt-10 space-y-2">
      <h2 class="font-outfit text-lg font-semibold text-secondary-500">find me elsewhere</h2>
      <ul class="space-y-1 text-sm text-secondary-400">
        <li>
          <a href="https://github.com/gparker97" class="text-primary-500 hover:text-primary-600" rel="me">
            github: @gparker97
          </a>
        </li>
        <li>
          <a href="https://gpbeanies.substack.com" class="text-primary-500 hover:text-primary-600" rel="me">
            substack: the beanstalk
          </a>
        </li>
      </ul>
    </section>
  </article>
</BaseLayout>
