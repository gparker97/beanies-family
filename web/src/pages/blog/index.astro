---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubstackSubscribe from '../../components/SubstackSubscribe.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '~/utils/content';
// Fraunces drives the beanstalk's broadsheet/zine aesthetic — oversized
// italic on the masthead + typographic-plate cards, italic on subtitles.
import '@fontsource-variable/fraunces';

/**
 * Per-issue tint treatment. Each post gets one of five brand-palette
 * washes so the /blog index reads as a series of distinct editions,
 * not a uniform card grid. Cycles by issue number so posts 6+ wrap
 * back to the first tint, preserving the visual rhythm indefinitely.
 *
 * Hex values chosen to match the guides' pillar tints — keeps the
 * site visually consistent family-wide.
 */
type IssueTint = {
  name: string;
  hex: string;
  wash: string;
  accentOn: string;
  ink: string;
};

const TINTS: IssueTint[] = [
  {
    name: 'orange',
    hex: '#f15d22',
    wash: 'linear-gradient(140deg, #fff6ef 0%, #ffe9d6 100%)',
    accentOn: 'rgb(241 93 34 / 18%)',
    ink: '#a83a11',
  },
  {
    name: 'terracotta',
    hex: '#c76a21',
    wash: 'linear-gradient(140deg, #fff5e8 0%, #f5e1c2 100%)',
    accentOn: 'rgb(199 106 33 / 22%)',
    ink: '#7d420f',
  },
  {
    name: 'sky',
    hex: '#3a82b3',
    wash: 'linear-gradient(140deg, #f1f8fd 0%, #dceaf6 100%)',
    accentOn: 'rgb(58 130 179 / 22%)',
    ink: '#1f4d6d',
  },
  {
    name: 'kraft',
    hex: '#b58a2a',
    wash: 'linear-gradient(140deg, #fbf6e8 0%, #f3e4bc 100%)',
    accentOn: 'rgb(181 138 42 / 22%)',
    ink: '#6c4f15',
  },
  {
    name: 'slate',
    hex: '#2c3e50',
    wash: 'linear-gradient(140deg, #f2f4f7 0%, #dde3ec 100%)',
    accentOn: 'rgb(44 62 80 / 20%)',
    ink: '#1a2533',
  },
];

const allPosts = await getCollection('blog', isPublished);

// Assign issue numbers by chronological order (oldest = Issue 01). Done
// ascending so issue numbers stay stable as new posts land at the top.
const byDateAsc = [...allPosts].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const issueMap = new Map<string, number>();
byDateAsc.forEach((p, i) => issueMap.set(p.data.slug, i + 1));

const byDateDesc = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// "This week's issue" is always the most recent post. `featured: true` in
// frontmatter can still pin a different post if editorial logic ever
// calls for it.
const explicitFeatured = allPosts.find((p) => p.data.featured);
const featuredPost = explicitFeatured ?? byDateDesc[0];
const backIssues = byDateDesc.filter((p) => p !== featuredPost);

function tintFor(issueNumber: number): IssueTint {
  return TINTS[(issueNumber - 1) % TINTS.length]!;
}

const fmtLong = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const fmtIssueStamp = (d: Date) =>
  d.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();

const totalIssues = allPosts.length;
const latestDate = byDateDesc[0]?.data.date;
---

<BaseLayout
  title="the beanstalk — the beanies.family blog"
  description="the latest beanie news and updates — posted every friday, or roughly whenever I feel like it."
  canonicalPath="/blog"
>
  <main class="beanstalk">
    <!-- ══════════════ MASTHEAD ══════════════ -->
    <header class="masthead">
      <div class="masthead-wash" aria-hidden="true"></div>

      {/* Mascot as a left-side hero illustration — full opacity,
          anchored bottom of the masthead so it reads as "standing
          next to the title." Absolutely positioned so the text block
          stays naturally centered in the max-width container. */}
      <img
        src="/brand/beanies-beanstalk-mascot.webp"
        alt=""
        class="masthead-mascot"
        aria-hidden="true"
      />
      <div class="masthead-text">
        <div class="masthead-rule-top" aria-hidden="true">
          <span>THE BEANSTALK</span>
          <span class="masthead-rule-divider">·</span>
          <span>EST. 2026</span>
          <span class="masthead-rule-divider">·</span>
          <span>A BEANIES.FAMILY PUBLICATION</span>
        </div>
        <h1 class="masthead-title">
          <span class="masthead-title-lede">the</span>
          <span class="masthead-title-brand">beanies.family</span>
          <span class="masthead-title-main">
            beanstalk
            <svg
              class="masthead-title-squiggle"
              viewBox="0 0 300 20"
              aria-hidden="true"
              preserveAspectRatio="none"
            >
              <path
                d="M 4 14 Q 30 2, 60 11 T 120 10 T 180 11 T 240 10 T 296 11"
                fill="none"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"
              />
            </svg>
          </span>
        </h1>
        <p class="masthead-pitch">
          a newsletter about <span class="masthead-pitch-brand">beanies.family</span>,
          vibe coding, or just life in general. published every friday, or roughly whenever
          I feel like it. not written by AI. usually.
        </p>
        <p class="masthead-issue">
          <span class="masthead-issue-chip">VOL. 01</span>
          <span class="masthead-issue-dot">·</span>
          <span class="masthead-issue-chip">{totalIssues} ISSUES</span>
          {latestDate && (
            <>
              <span class="masthead-issue-dot">·</span>
              <span class="masthead-issue-stamp">LATEST {fmtIssueStamp(latestDate)}</span>
            </>
          )}
        </p>
      </div>
    </header>

    <!-- ══════════════ DIVIDER: MASTHEAD → LATEST ISSUE ══════════════
         An ornamental zine-style flourish that separates the masthead
         from the featured issue card. Thin orange rules fade in from
         each side, meeting a Fraunces-italic "fresh off the press"
         label bracketed by two small heritage-orange dots. Echoes the
         hand-drawn squiggle motif under the beanstalk title without
         repeating it. -->
    <div class="fresh-divider" aria-hidden="true">
      <span class="fresh-divider-rule"></span>
      <span class="fresh-divider-ornament">
        <span class="fresh-divider-dot"></span>
        <span class="fresh-divider-text">fresh off the press</span>
        <span class="fresh-divider-dot"></span>
      </span>
      <span class="fresh-divider-rule"></span>
    </div>

    <!-- ══════════════ FEATURED: THIS WEEK'S ISSUE ══════════════ -->
    {featuredPost && (() => {
      const issueNo = issueMap.get(featuredPost.data.slug) ?? 1;
      const tint = tintFor(issueNo);
      const hasImage = !!featuredPost.data.coverImage;
      return (
        <a
          class={`issue issue-featured ${hasImage ? 'issue-has-image' : 'issue-plate-variant'}`}
          href={`/blog/${featuredPost.data.slug}`}
          style={`--tint: ${tint.hex}; --tint-ink: ${tint.ink}; --wash: ${tint.wash}; --accent-on: ${tint.accentOn};`}
          aria-label={`Read: ${featuredPost.data.title}`}
        >
          <div class="issue-media" aria-hidden="true">
            {hasImage ? (
              <div class="issue-media-frame">
                <img src={featuredPost.data.coverImage} alt="" loading="eager" />
                <span class="issue-media-tape issue-media-tape-tl"></span>
                <span class="issue-media-tape issue-media-tape-br"></span>
              </div>
            ) : (
              <div class="issue-plate">
                <span class="issue-plate-grid" aria-hidden="true"></span>
                {featuredPost.data.coverEmoji && (
                  <span class="issue-plate-emoji">{featuredPost.data.coverEmoji}</span>
                )}
                <span class="issue-plate-stamp">ISSUE {String(issueNo).padStart(2, '0')}</span>
                <img
                  class="issue-plate-sprout"
                  src="/brand/beanies-beanstalk-mascot.webp"
                  alt=""
                  aria-hidden="true"
                  width="96"
                  height="166"
                />
              </div>
            )}
          </div>
          <div class="issue-body">
            <p class="issue-kicker">
              <span class="issue-kicker-dot" aria-hidden="true"></span>
              <span class="issue-kicker-label">LATEST ISSUE</span>
              <span class="issue-kicker-divider">·</span>
              <span class="issue-kicker-issue">ISSUE {String(issueNo).padStart(2, '0')}</span>
            </p>
            <h2 class="issue-title issue-title-featured">{featuredPost.data.title}</h2>
            {featuredPost.data.subtitle && (
              <p class="issue-sub">{featuredPost.data.subtitle}</p>
            )}
            <p class="issue-byline">
              <span class="issue-byline-author">{featuredPost.data.author}</span>
              <span class="issue-byline-dot">·</span>
              <span class="issue-byline-date">{fmtLong(featuredPost.data.date)}</span>
              {featuredPost.data.category && (
                <>
                  <span class="issue-byline-dot">·</span>
                  <span class="issue-byline-cat">{featuredPost.data.category}</span>
                </>
              )}
            </p>
            <span class="issue-cta">
              read the issue
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </span>
          </div>
        </a>
      );
    })()}

    <!-- ══════════════ BACK ISSUES ══════════════ -->
    {backIssues.length > 0 && (
      <>
        <div class="section-rule" aria-hidden="true">
          <span>BACK ISSUES</span>
        </div>
        <section class="issues-grid" aria-label="Back issues">
          {backIssues.map((post) => {
            const issueNo = issueMap.get(post.data.slug) ?? 1;
            const tint = tintFor(issueNo);
            const hasImage = !!post.data.coverImage;
            return (
              <a
                class={`issue ${hasImage ? 'issue-has-image' : 'issue-plate-variant'}`}
                href={`/blog/${post.data.slug}`}
                style={`--tint: ${tint.hex}; --tint-ink: ${tint.ink}; --wash: ${tint.wash}; --accent-on: ${tint.accentOn};`}
                aria-label={`Read: ${post.data.title}`}
              >
                <div class="issue-media" aria-hidden="true">
                  {hasImage ? (
                    <div class="issue-media-frame">
                      <img src={post.data.coverImage} alt="" loading="lazy" />
                      <span class="issue-media-tape issue-media-tape-tl"></span>
                    </div>
                  ) : (
                    <div class="issue-plate">
                      <span class="issue-plate-grid" aria-hidden="true"></span>
                      {post.data.coverEmoji && (
                        <span class="issue-plate-emoji">{post.data.coverEmoji}</span>
                      )}
                      <span class="issue-plate-stamp">ISSUE {String(issueNo).padStart(2, '0')}</span>
                      <img
                        class="issue-plate-sprout"
                        src="/brand/beanies-beanstalk-mascot.webp"
                        alt=""
                        aria-hidden="true"
                        width="80"
                        height="138"
                      />
                    </div>
                  )}
                </div>
                <div class="issue-body">
                  <p class="issue-kicker">
                    <span class="issue-kicker-dot" aria-hidden="true"></span>
                    <span class="issue-kicker-issue">ISSUE {String(issueNo).padStart(2, '0')}</span>
                    {post.data.category && (
                      <>
                        <span class="issue-kicker-divider">·</span>
                        <span class="issue-kicker-cat">{post.data.category}</span>
                      </>
                    )}
                  </p>
                  <h3 class="issue-title">{post.data.title}</h3>
                  {post.data.subtitle && (
                    <p class="issue-sub">{post.data.subtitle}</p>
                  )}
                  <p class="issue-byline">
                    <span class="issue-byline-author">{post.data.author}</span>
                    <span class="issue-byline-dot">·</span>
                    <span class="issue-byline-date">{fmtLong(post.data.date)}</span>
                  </p>
                </div>
              </a>
            );
          })}
        </section>
      </>
    )}

    <div class="subscribe-section">
      <SubstackSubscribe />
    </div>
  </main>
</BaseLayout>

<style>
  .beanstalk {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --kraft: #f3ecd8;
    --cloud-white: #f8f9fa;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', Fraunces, 'Source Serif 4', Georgia, serif;

    background: var(--cloud-white);
    background-image:
      radial-gradient(circle at 8% 12%, rgb(241 93 34 / 4%) 0%, transparent 40%),
      radial-gradient(circle at 92% 88%, rgb(174 214 241 / 6%) 0%, transparent 45%);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* ══════════════ MASTHEAD ══════════════
     Flex layout: mascot on the left, text block on the right. Mascot
     is bottom-aligned so the soil mound in the drawing sits on the
     masthead's baseline. On narrow viewports the flex direction flips
     to column + mascot scales down (see responsive block). */
  .masthead {
    align-items: flex-end;
    box-sizing: border-box;
    display: flex;
    gap: 32px;
    margin: 0 auto;
    max-width: 980px;
    padding: 120px 32px 48px;
    position: relative;
    text-align: center;
  }
  .masthead-text {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }
  /* Polished beanies-theme gradient backdrop. Layered radial gradients
     in the brand palette (Heritage Orange at top-left, Terracotta
     middle-right, Sky Silk lower-right, Kraft warmth center-bottom).
     Plus a subtle horizontal wash along the bottom for "horizon"
     warmth without resorting to cartoon illustration. Scales fluidly
     at any viewport, no SVG needed. */
  .masthead-wash {
    background:
      radial-gradient(circle at 15% 25%, rgb(241 93 34 / 18%) 0%, transparent 45%),
      radial-gradient(circle at 82% 20%, rgb(174 214 241 / 22%) 0%, transparent 50%),
      radial-gradient(circle at 78% 78%, rgb(230 126 34 / 16%) 0%, transparent 48%),
      radial-gradient(circle at 30% 95%, rgb(243 236 216 / 55%) 0%, transparent 55%),
      linear-gradient(180deg, rgb(248 249 250 / 0%) 0%, rgb(241 93 34 / 6%) 100%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  /* Subtle grain overlay — tiny orange + slate dots to add paper-ish
     texture that the gradient alone can't supply. Very low contrast. */
  .masthead-wash::after {
    background-image:
      radial-gradient(circle at 18% 42%, rgb(241 93 34 / 8%) 0.8px, transparent 1.1px),
      radial-gradient(circle at 62% 28%, rgb(44 62 80 / 5%) 0.8px, transparent 1.1px),
      radial-gradient(circle at 88% 66%, rgb(241 93 34 / 7%) 0.8px, transparent 1.1px);
    background-size: 120px 120px, 96px 96px, 156px 156px;
    content: '';
    inset: 0;
    mix-blend-mode: multiply;
    opacity: 0.55;
    pointer-events: none;
    position: absolute;
  }
  .masthead-rule-top {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    gap: 10px;
    justify-content: center;
    letter-spacing: 0.26em;
    margin-bottom: 28px;
    padding: 8px 18px;
    position: relative;
    text-transform: uppercase;
  }
  .masthead-rule-top::before,
  .masthead-rule-top::after {
    background: linear-gradient(to right, transparent, color-mix(in srgb, var(--heritage-orange) 35%, transparent), transparent);
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    margin: 0 10px;
    max-width: 80px;
  }
  .masthead-rule-divider { opacity: 0.55; }
  /* Playful, less literary title — Outfit-driven, with an italic
     Fraunces "the" sitting on top of the brand and title words.
     Sized modestly so it doesn't dominate the page like a broadsheet
     masthead; meant to read "happy little zine," not "The Paris
     Review." */
  .masthead-title {
    color: var(--deep-slate);
    font-family: var(--font-display);
    line-height: 1;
    margin: 0 0 18px;
    position: relative;
    z-index: 1;
  }
  .masthead-title-lede {
    color: rgb(44 62 80 / 55%);
    display: block;
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .masthead-title-brand {
    color: var(--heritage-orange);
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }
  .masthead-title-main {
    color: var(--deep-slate);
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 0.95;
    position: relative;
  }
  /* Hand-drawn squiggle underline, stroked in Heritage Orange. SVG
     uses currentColor so the stroke inherits the color rule below. */
  .masthead-title-squiggle {
    bottom: -0.2em;
    color: var(--heritage-orange);
    height: 0.28em;
    left: -2%;
    opacity: 0.9;
    position: absolute;
    width: 104%;
  }
  /* Pitch kept plain — single font, single weight, single color.
     Only the brand name pulls Heritage Orange as a small accent. */
  .masthead-pitch {
    color: rgb(44 62 80 / 78%);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.55vw, 1.15rem);
    font-weight: 400;
    line-height: 1.6;
    margin: 0 auto 26px;
    max-width: 580px;
    position: relative;
    z-index: 1;
  }
  .masthead-pitch-brand {
    color: var(--heritage-orange);
  }
  .masthead-issue {
    align-items: center;
    color: var(--muted);
    display: inline-flex;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    gap: 10px;
    justify-content: center;
    letter-spacing: 0.22em;
    margin: 0;
    position: relative;
    text-transform: uppercase;
    z-index: 1;
  }
  .masthead-issue-chip {
    background: rgb(44 62 80 / 4%);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--deep-slate);
    padding: 6px 12px;
  }
  .masthead-issue-stamp {
    color: var(--heritage-orange);
    font-weight: 700;
  }
  .masthead-issue-dot { opacity: 0.45; }

  /* ══════════════ HERO MASCOT ══════════════
     Beanie-character illustration as the masthead's left-column hero
     feature. Flex item (not absolute) so the text block flows
     naturally to its right. `align-items: flex-end` on the parent
     pins the mascot's soil mound to the masthead baseline. Static
     placement — no sway — so it sits flush against the gradient. */
  .masthead-mascot {
    filter: drop-shadow(0 12px 24px rgb(44 62 80 / 18%));
    flex-shrink: 0;
    height: auto;
    pointer-events: none;
    position: relative;
    width: 220px;
    z-index: 1;
  }

  /* ══════════════ FRESH-OFF-THE-PRESS DIVIDER ══════════════
     Ornamental break between the masthead and the featured issue.
     Thin tapered rules flank a Fraunces-italic label with a small
     heritage-orange dot on each side. Sized to match the featured
     card width (980px) and padded against the card top. */
  .fresh-divider {
    align-items: center;
    color: var(--heritage-orange);
    display: flex;
    gap: 20px;
    justify-content: center;
    /* Symmetric vertical rhythm — the masthead's 48px bottom padding
       sits INSIDE its gradient wash, so the wash's visible bottom edge
       butts against the masthead's bounding box. To center this divider
       optically between the masthead and the featured card, we need
       roughly equal whitespace above and below. 40px on each side
       balances the gap the eye reads. */
    margin: 40px auto 40px;
    max-width: 760px;
    padding: 0 32px;
  }
  .fresh-divider-rule {
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--heritage-orange) 32%, transparent),
      transparent
    );
    flex: 1;
    height: 1px;
    max-width: 160px;
  }
  .fresh-divider-ornament {
    align-items: center;
    display: inline-flex;
    gap: 14px;
  }
  .fresh-divider-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgb(241 93 34 / 14%);
    display: inline-block;
    flex-shrink: 0;
    height: 6px;
    width: 6px;
  }
  .fresh-divider-text {
    color: var(--heritage-orange);
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  /* ══════════════ ISSUE CARDS (featured + back issues) ══════════════ */
  .issue {
    background: var(--wash);
    border: 1px solid color-mix(in srgb, var(--tint) 14%, var(--hairline));
    border-radius: 24px;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    isolation: isolate;
    overflow: hidden;
    position: relative;
    text-decoration: none;
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms ease;
  }
  .issue::after {
    background: linear-gradient(160deg, transparent 30%, rgb(255 255 255 / 32%) 65%, transparent 100%);
    content: '';
    inset: 0;
    mix-blend-mode: overlay;
    opacity: 0.55;
    pointer-events: none;
    position: absolute;
    z-index: 0;
  }
  .issue:hover {
    border-color: color-mix(in srgb, var(--tint) 48%, transparent);
    box-shadow: 0 24px 48px -20px color-mix(in srgb, var(--tint) 40%, transparent);
    transform: translateY(-3px);
  }
  .issue > * { position: relative; z-index: 1; }

  /* ── Featured (hero) card: horizontal on wide, stacked on narrow ── */
  .issue-featured {
    display: grid;
    gap: 0;
    grid-template-columns: 1.05fr 1fr;
    margin: 0 auto 56px;
    max-width: 980px;
  }
  .issue-featured .issue-media { aspect-ratio: auto; height: 100%; min-height: 340px; }
  .issue-featured .issue-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: center;
    padding: 44px 40px;
  }

  /* ── Media frame (when coverImage present) ── */
  .issue-media {
    aspect-ratio: 16 / 10;
    background: color-mix(in srgb, var(--tint) 8%, white);
    border-right: 1px solid color-mix(in srgb, var(--tint) 12%, transparent);
    overflow: hidden;
    position: relative;
  }
  .issue-media-frame {
    background:
