---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featured = posts.find((p) => p.data.featured);
const rest = posts.filter((p) => p !== featured);
---

<BaseLayout
  title="the beanstalk — the beanies.family blog"
  description="stories, updates, and philosophy from the making of beanies.family. local-first, privacy-first, family-first."
  canonicalPath="/blog"
>
  <header class="mx-auto max-w-6xl px-6 py-16">
    <h1 class="font-outfit text-4xl font-bold text-secondary-500 sm:text-5xl">the beanstalk</h1>
    <p class="mt-3 max-w-xl text-lg text-secondary-400">
      stories, updates, and philosophy from the making of beanies.family.
    </p>
  </header>

  {
    featured && (
      <section class="mx-auto max-w-6xl px-6 pb-10">
        <a
          href={`/blog/${featured.data.slug}`}
          class="block rounded-3xl bg-white p-8 shadow-sm transition-shadow hover:shadow-md sm:p-10"
        >
          <div class="flex items-start gap-5">
            {featured.data.coverEmoji && (
              <span class="text-5xl" aria-hidden="true">
                {featured.data.coverEmoji}
              </span>
            )}
            <div class="flex-1">
              <p class="text-xs font-semibold uppercase tracking-wide text-primary-500">featured</p>
              <h2 class="mt-2 font-outfit text-2xl font-semibold text-secondary-500 sm:text-3xl">
                {featured.data.title}
              </h2>
              <p class="mt-3 text-secondary-400">{featured.data.excerpt}</p>
              <p class="mt-4 text-sm text-secondary-400">
                by {featured.data.author} ·{' '}
                <time datetime={featured.data.date.toISOString()}>
                  {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </p>
            </div>
          </div>
        </a>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-6 pb-20">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        rest.map((post) => (
          <li>
            <a
              href={`/blog/${post.data.slug}`}
              class="block h-full rounded-2xl bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
            >
              {post.data.coverEmoji && (
                <span class="text-3xl" aria-hidden="true">
                  {post.data.coverEmoji}
                </span>
              )}
              <h3 class="mt-3 font-outfit text-lg font-semibold text-secondary-500">{post.data.title}</h3>
              <p class="mt-2 line-clamp-3 text-sm text-secondary-400">{post.data.excerpt}</p>
              <p class="mt-4 text-xs text-secondary-400">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
