---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubstackSubscribe from '../../components/SubstackSubscribe.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '~/utils/content';
// Fraunces drives the beanstalk's broadsheet/zine aesthetic — oversized
// italic on the masthead + typographic-plate cards, italic on subtitles.
import '@fontsource-variable/fraunces';

/**
 * Per-issue tint treatment. Each post gets one of five brand-palette
 * washes so the /blog index reads as a series of distinct editions,
 * not a uniform card grid. Cycles by issue number so posts 6+ wrap
 * back to the first tint, preserving the visual rhythm indefinitely.
 *
 * Hex values chosen to match the guides' pillar tints — keeps the
 * site visually consistent family-wide.
 */
type IssueTint = {
  name: string;
  hex: string;
  wash: string;
  accentOn: string;
  ink: string;
};

const TINTS: IssueTint[] = [
  {
    name: 'orange',
    hex: '#f15d22',
    wash: 'linear-gradient(140deg, #fff6ef 0%, #ffe9d6 100%)',
    accentOn: 'rgb(241 93 34 / 18%)',
    ink: '#a83a11',
  },
  {
    name: 'terracotta',
    hex: '#c76a21',
    wash: 'linear-gradient(140deg, #fff5e8 0%, #f5e1c2 100%)',
    accentOn: 'rgb(199 106 33 / 22%)',
    ink: '#7d420f',
  },
  {
    name: 'sky',
    hex: '#3a82b3',
    wash: 'linear-gradient(140deg, #f1f8fd 0%, #dceaf6 100%)',
    accentOn: 'rgb(58 130 179 / 22%)',
    ink: '#1f4d6d',
  },
  {
    name: 'kraft',
    hex: '#b58a2a',
    wash: 'linear-gradient(140deg, #fbf6e8 0%, #f3e4bc 100%)',
    accentOn: 'rgb(181 138 42 / 22%)',
    ink: '#6c4f15',
  },
  {
    name: 'slate',
    hex: '#2c3e50',
    wash: 'linear-gradient(140deg, #f2f4f7 0%, #dde3ec 100%)',
    accentOn: 'rgb(44 62 80 / 20%)',
    ink: '#1a2533',
  },
];

const allPosts = await getCollection('blog', isPublished);

// Assign issue numbers by chronological order (oldest = Issue 01). Done
// ascending so issue numbers stay stable as new posts land at the top.
const byDateAsc = [...allPosts].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const issueMap = new Map<string, number>();
byDateAsc.forEach((p, i) => issueMap.set(p.data.slug, i + 1));

const byDateDesc = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// "This week's issue" is always the most recent post. `featured: true` in
// frontmatter can still pin a different post if editorial logic ever
// calls for it.
const explicitFeatured = allPosts.find((p) => p.data.featured);
const featuredPost = explicitFeatured ?? byDateDesc[0];
const backIssues = byDateDesc.filter((p) => p !== featuredPost);

function tintFor(issueNumber: number): IssueTint {
  return TINTS[(issueNumber - 1) % TINTS.length]!;
}

const fmtLong = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const fmtIssueStamp = (d: Date) =>
  d.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();

const totalIssues = allPosts.length;
const latestDate = byDateDesc[0]?.data.date;
---

<BaseLayout
  title="the beanstalk — the beanies.family blog"
  description="the latest beanie news and updates — posted every friday, or roughly whenever I feel like it."
  canonicalPath="/blog"
>
  <main class="beanstalk">
    <!-- ══════════════ MASTHEAD ══════════════ -->
    <header class="masthead">
      <div class="masthead-wash" aria-hidden="true"></div>
      {/* Inline SVG backdrop — cartoon beanstalk scene inspired by the
          original .webp banner. Three stylized bean-vines with twists
          + curls + leaves, rooted in little soil mounds, a smiling
          orange cloud top-right, plus a few flying leaves for
          ambiance. Gradient-baked opacity keeps it atmospheric so
          the title copy stays the focal point. viewBox 1200x340 +
          preserveAspectRatio="xMidYMax slice" pins the horizon to
          the bottom on any viewport — mobile responsiveness is free. */}
      <svg
        class="masthead-backdrop"
        viewBox="0 0 1200 340"
        preserveAspectRatio="xMidYMax slice"
        aria-hidden="true"
      >
        <defs>
          <radialGradient id="bsGlow" cx="50%" cy="95%" r="70%">
            <stop offset="0%" stop-color="#f15d22" stop-opacity="0.2" />
            <stop offset="45%" stop-color="#e67e22" stop-opacity="0.09" />
            <stop offset="100%" stop-color="#f15d22" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="bsVine" x1="0" y1="1" x2="0" y2="0">
            <stop offset="0%" stop-color="#8b4513" stop-opacity="0.42" />
            <stop offset="50%" stop-color="#c76a21" stop-opacity="0.48" />
            <stop offset="100%" stop-color="#e67e22" stop-opacity="0.3" />
          </linearGradient>
          <linearGradient id="bsLeaf" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#f15d22" stop-opacity="0.36" />
            <stop offset="100%" stop-color="#e67e22" stop-opacity="0.2" />
          </linearGradient>
          <linearGradient id="bsSoil" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#8b5a2b" stop-opacity="0.38" />
            <stop offset="100%" stop-color="#5d3a1a" stop-opacity="0.26" />
          </linearGradient>
        </defs>

        <rect width="1200" height="340" fill="url(#bsGlow)" />

        {/* ── BEANSTALK 1 (left) — S-curve with top curl ── */}
        <g>
          <ellipse cx="200" cy="332" rx="82" ry="14" fill="url(#bsSoil)" />
          <circle cx="170" cy="330" r="2" fill="#5d3a1a" fill-opacity="0.32" />
          <circle cx="215" cy="335" r="1.6" fill="#5d3a1a" fill-opacity="0.32" />
          <circle cx="245" cy="328" r="2" fill="#5d3a1a" fill-opacity="0.32" />
          <path
            d="M 200 320 C 170 282, 222 256, 198 222 C 176 190, 230 175, 206 142 C 184 108, 236 90, 214 58 C 204 38, 224 18, 204 6"
            stroke="url(#bsVine)"
            stroke-width="10"
            fill="none"
            stroke-linecap="round"
          />
          <path
            d="M 204 6 Q 236 4, 236 32 Q 222 44, 212 28"
            stroke="url(#bsVine)"
            stroke-width="7"
            fill="none"
            stroke-linecap="round"
          />
          <ellipse cx="185" cy="270" rx="25" ry="10" transform="rotate(-28 185 270)" fill="url(#bsLeaf)" />
          <ellipse cx="225" cy="205" rx="25" ry="10" transform="rotate(28 225 205)" fill="url(#bsLeaf)" />
          <ellipse cx="185" cy="135" rx="22" ry="9" transform="rotate(-22 185 135)" fill="url(#bsLeaf)" />
          <ellipse cx="225" cy="72" rx="20" ry="8" transform="rotate(30 225 72)" fill="url(#bsLeaf)" />
          <circle cx="175" cy="295" r="4" fill="#f15d22" fill-opacity="0.3" />
        </g>

        {/* ── BEANSTALK 2 (middle) — twisty with top spiral ── */}
        <g>
          <ellipse cx="600" cy="332" rx="90" ry="15" fill="url(#bsSoil)" />
          <circle cx="570" cy="330" r="2" fill="#5d3a1a" fill-opacity="0.32" />
          <circle cx="618" cy="336" r="1.6" fill="#5d3a1a" fill-opacity="0.32" />
          <circle cx="648" cy="328" r="2" fill="#5d3a1a" fill-opacity="0.32" />
          <path
            d="M 600 320 C 578 284, 642 264, 610 228 C 578 192, 642 172, 600 132 C 564 92, 642 72, 616 42 C 606 24, 642 4, 626 30"
            stroke="url(#bsVine)"
            stroke-width="11"
            fill="none"
            stroke-linecap="round"
          />
          <path
            d="M 626 30 Q 642 18, 648 34 Q 640 46, 628 40"
            stroke="url(#bsVine)"
            stroke-width="8"
            fill="none"
            stroke-linecap="round"
          />
          <ellipse cx="620" cy="270" rx="26" ry="11" transform="rotate(22 620 270)" fill="url(#bsLeaf)" />
          <ellipse cx="585" cy="215" rx="26" ry="11" transform="rotate(-30 585 215)" fill="url(#bsLeaf)" />
          <ellipse cx="625" cy="155" rx="25" ry="10" transform="rotate(25 625 155)" fill="url(#bsLeaf)" />
          <ellipse cx="580" cy="95" rx="22" ry="9" transform="rotate(-25 580 95)" fill="url(#bsLeaf)" />
          <ellipse cx="625" cy="55" rx="18" ry="7" transform="rotate(30 625 55)" fill="url(#bsLeaf)" />
          <circle cx="572" cy="248" r="4" fill="#f15d22" fill-opacity="0.3" />
        </g>

        {/* ── BEANSTALK 3 (right) — upward twist with double curl ── */}
        <g>
          <ellipse cx="1000" cy="332" rx="82" ry="14" fill="url(#bsSoil)" />
          <circle cx="970" cy="330" r="2" fill="#5d3a1a" fill-opacity="0.32" />
          <circle cx="1018" cy="335" r="1.6" fill="#5d3a1a" fill-opacity="0.32" />
          <circle cx="1044" cy="328" r="2" fill="#5d3a1a" fill-opacity="0.32" />
          <path
            d="M 1000 320 C 1030 284, 975 258, 1020 224 C 1062 192, 984 170, 1036 132 C 1076 100, 1000 72, 1050 42"
            stroke="url(#bsVine)"
            stroke-width="10"
            fill="none"
            stroke-linecap="round"
          />
          <path
            d="M 1050 42 Q 1076 28, 1086 54 Q 1076 70, 1060 60"
            stroke="url(#bsVine)"
            stroke-width="8"
            fill="none"
            stroke-linecap="round"
          />
          <path
            d="M 1060 60 Q 1068 70, 1054 74"
            stroke="url(#bsVine)"
            stroke-width="6"
            fill="none"
            stroke-linecap="round"
          />
          <ellipse cx="1002" cy="275" rx="24" ry="10" transform="rotate(28 1002 275)" fill="url(#bsLeaf)" />
          <ellipse cx="1040" cy="210" rx="24" ry="10" transform="rotate(-30 1040 210)" fill="url(#bsLeaf)" />
          <ellipse cx="1004" cy="150" rx="22" ry="9" transform="rotate(22 1004 150)" fill="url(#bsLeaf)" />
          <ellipse cx="1046" cy="92" rx="20" ry="8" transform="rotate(-28 1046 92)" fill="url(#bsLeaf)" />
        </g>

        {/* ── Smiling cloud top-right ── */}
        <g transform="translate(1108, 60)">
          <g fill="#f15d22" fill-opacity="0.15">
            <ellipse cx="0" cy="0" rx="56" ry="20" />
            <ellipse cx="-28" cy="-10" rx="22" ry="15" />
            <ellipse cx="22" cy="-13" rx="20" ry="14" />
            <ellipse cx="0" cy="-18" rx="17" ry="10" />
          </g>
          <circle cx="-13" cy="-3" r="2.2" fill="#f15d22" fill-opacity="0.55" />
          <circle cx="13" cy="-3" r="2.2" fill="#f15d22" fill-opacity="0.55" />
          <path
            d="M -11 5 Q 0 14 11 5"
            stroke="#f15d22"
            stroke-opacity="0.55"
            stroke-width="2"
            fill="none"
            stroke-linecap="round"
          />
        </g>

        {/* ── Flying leaves for ambiance ── */}
        <ellipse cx="380" cy="102" rx="10" ry="4" transform="rotate(40 380 102)" fill="url(#bsLeaf)" />
        <ellipse cx="820" cy="74" rx="10" ry="4" transform="rotate(-30 820 74)" fill="url(#bsLeaf)" />
        <ellipse cx="460" cy="62" rx="8" ry="3" transform="rotate(20 460 62)" fill="url(#bsLeaf)" />
      </svg>

      {/* Mascot as a left-side hero illustration — full opacity,
          anchored bottom of the masthead so it reads as "standing
          next to the title." Absolutely positioned so the text block
          stays naturally centered in the max-width container. */}
      <img
        src="/brand/beanies-beanstalk-mascot.webp"
        alt=""
        class="masthead-mascot"
        aria-hidden="true"
      />
      <div class="masthead-text">
        <div class="masthead-rule-top" aria-hidden="true">
          <span>THE BEANSTALK</span>
          <span class="masthead-rule-divider">·</span>
          <span>EST. 2026</span>
          <span class="masthead-rule-divider">·</span>
          <span>A BEANIES.FAMILY PUBLICATION</span>
        </div>
        <h1 class="masthead-title">
          <span class="masthead-title-lede">the</span>
          <span class="masthead-title-brand">beanies.family</span>
          <span class="masthead-title-main">
            beanstalk
            <svg
              class="masthead-title-squiggle"
              viewBox="0 0 300 20"
              aria-hidden="true"
              preserveAspectRatio="none"
            >
              <path
                d="M 4 14 Q 30 2, 60 11 T 120 10 T 180 11 T 240 10 T 296 11"
                fill="none"
                stroke="currentColor"
                stroke-width="4"
                stroke-linecap="round"
              />
            </svg>
          </span>
        </h1>
        <p class="masthead-pitch">
          a newsletter about <span class="masthead-pitch-brand">beanies.family</span>,
          vibe coding, or just life in general. published every friday, or roughly whenever
          I feel like it. not written by AI. usually.
        </p>
        <p class="masthead-issue">
          <span class="masthead-issue-chip">VOL. 01</span>
          <span class="masthead-issue-dot">·</span>
          <span class="masthead-issue-chip">{totalIssues} ISSUES</span>
          {latestDate && (
            <>
              <span class="masthead-issue-dot">·</span>
              <span class="masthead-issue-stamp">LATEST {fmtIssueStamp(latestDate)}</span>
            </>
          )}
        </p>
      </div>
    </header>

    <!-- ══════════════ FEATURED: THIS WEEK'S ISSUE ══════════════ -->
    {featuredPost && (() => {
      const issueNo = issueMap.get(featuredPost.data.slug) ?? 1;
      const tint = tintFor(issueNo);
      const hasImage = !!featuredPost.data.coverImage;
      return (
        <a
          class={`issue issue-featured ${hasImage ? 'issue-has-image' : 'issue-plate-variant'}`}
          href={`/blog/${featuredPost.data.slug}`}
          style={`--tint: ${tint.hex}; --tint-ink: ${tint.ink}; --wash: ${tint.wash}; --accent-on: ${tint.accentOn};`}
          aria-label={`Read: ${featuredPost.data.title}`}
        >
          <div class="issue-media" aria-hidden="true">
            {hasImage ? (
              <div class="issue-media-frame">
                <img src={featuredPost.data.coverImage} alt="" loading="eager" />
                <span class="issue-media-tape issue-media-tape-tl"></span>
                <span class="issue-media-tape issue-media-tape-br"></span>
              </div>
            ) : (
              <div class="issue-plate">
                <span class="issue-plate-grid" aria-hidden="true"></span>
                {featuredPost.data.coverEmoji && (
                  <span class="issue-plate-emoji">{featuredPost.data.coverEmoji}</span>
                )}
                <span class="issue-plate-stamp">ISSUE {String(issueNo).padStart(2, '0')}</span>
                <img
                  class="issue-plate-sprout"
                  src="/brand/beanies-beanstalk-mascot.webp"
                  alt=""
                  aria-hidden="true"
                  width="96"
                  height="166"
                />
              </div>
            )}
          </div>
          <div class="issue-body">
            <p class="issue-kicker">
              <span class="issue-kicker-dot" aria-hidden="true"></span>
              <span class="issue-kicker-label">LATEST ISSUE</span>
              <span class="issue-kicker-divider">·</span>
              <span class="issue-kicker-issue">ISSUE {String(issueNo).padStart(2, '0')}</span>
            </p>
            <h2 class="issue-title issue-title-featured">{featuredPost.data.title}</h2>
            {featuredPost.data.subtitle && (
              <p class="issue-sub">{featuredPost.data.subtitle}</p>
            )}
            <p class="issue-byline">
              <span class="issue-byline-author">{featuredPost.data.author}</span>
              <span class="issue-byline-dot">·</span>
              <span class="issue-byline-date">{fmtLong(featuredPost.data.date)}</span>
              {featuredPost.data.category && (
                <>
                  <span class="issue-byline-dot">·</span>
                  <span class="issue-byline-cat">{featuredPost.data.category}</span>
                </>
              )}
            </p>
            <span class="issue-cta">
              read the issue
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </span>
          </div>
        </a>
      );
    })()}

    <!-- ══════════════ BACK ISSUES ══════════════ -->
    {backIssues.length > 0 && (
      <>
        <div class="section-rule" aria-hidden="true">
          <span>BACK ISSUES</span>
        </div>
        <section class="issues-grid" aria-label="Back issues">
          {backIssues.map((post) => {
            const issueNo = issueMap.get(post.data.slug) ?? 1;
            const tint = tintFor(issueNo);
            const hasImage = !!post.data.coverImage;
            return (
              <a
                class={`issue ${hasImage ? 'issue-has-image' : 'issue-plate-variant'}`}
                href={`/blog/${post.data.slug}`}
                style={`--tint: ${tint.hex}; --tint-ink: ${tint.ink}; --wash: ${tint.wash}; --accent-on: ${tint.accentOn};`}
                aria-label={`Read: ${post.data.title}`}
              >
                <div class="issue-media" aria-hidden="true">
                  {hasImage ? (
                    <div class="issue-media-frame">
                      <img src={post.data.coverImage} alt="" loading="lazy" />
                      <span class="issue-media-tape issue-media-tape-tl"></span>
                    </div>
                  ) : (
                    <div class="issue-plate">
                      <span class="issue-plate-grid" aria-hidden="true"></span>
                      {post.data.coverEmoji && (
                        <span class="issue-plate-emoji">{post.data.coverEmoji}</span>
                      )}
                      <span class="issue-plate-stamp">ISSUE {String(issueNo).padStart(2, '0')}</span>
                      <img
                        class="issue-plate-sprout"
                        src="/brand/beanies-beanstalk-mascot.webp"
                        alt=""
                        aria-hidden="true"
                        width="80"
                        height="138"
                      />
                    </div>
                  )}
                </div>
                <div class="issue-body">
                  <p class="issue-kicker">
                    <span class="issue-kicker-dot" aria-hidden="true"></span>
                    <span class="issue-kicker-issue">ISSUE {String(issueNo).padStart(2, '0')}</span>
                    {post.data.category && (
                      <>
                        <span class="issue-kicker-divider">·</span>
                        <span class="issue-kicker-cat">{post.data.category}</span>
                      </>
                    )}
                  </p>
                  <h3 class="issue-title">{post.data.title}</h3>
                  {post.data.subtitle && (
                    <p class="issue-sub">{post.data.subtitle}</p>
                  )}
                  <p class="issue-byline">
                    <span class="issue-byline-author">{post.data.author}</span>
                    <span class="issue-byline-dot">·</span>
                    <span class="issue-byline-date">{fmtLong(post.data.date)}</span>
                  </p>
                </div>
              </a>
            );
          })}
        </section>
      </>
    )}

    <div class="subscribe-section">
      <SubstackSubscribe />
    </div>
  </main>
</BaseLayout>

<style>
  .beanstalk {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --kraft: #f3ecd8;
    --cloud-white: #f8f9fa;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', Fraunces, 'Source Serif 4', Georgia, serif;

    background: var(--cloud-white);
    background-image:
      radial-gradient(circle at 8% 12%, rgb(241 93 34 / 4%) 0%, transparent 40%),
      radial-gradient(circle at 92% 88%, rgb(174 214 241 / 6%) 0%, transparent 45%);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* ══════════════ MASTHEAD ══════════════
     Flex layout: mascot on the left, text block on the right. Mascot
     is bottom-aligned so the soil mound in the drawing sits on the
     masthead's baseline. On narrow viewports the flex direction flips
     to column + mascot scales down (see responsive block). */
  .masthead {
    align-items: flex-end;
    box-sizing: border-box;
    display: flex;
    gap: 32px;
    margin: 0 auto;
    max-width: 980px;
    padding: 120px 32px 48px;
    position: relative;
    text-align: center;
  }
  .masthead-text {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }
  .masthead-wash {
    background:
      radial-gradient(circle at 22% 35%, rgb(241 93 34 / 10%) 0%, transparent 42%),
      radial-gradient(circle at 78% 70%, rgb(230 126 34 / 7%) 0%, transparent 45%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  .masthead-rule-top {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    gap: 10px;
    justify-content: center;
    letter-spacing: 0.26em;
    margin-bottom: 28px;
    padding: 8px 18px;
    position: relative;
    text-transform: uppercase;
  }
  .masthead-rule-top::before,
  .masthead-rule-top::after {
    background: linear-gradient(to right, transparent, color-mix(in srgb, var(--heritage-orange) 35%, transparent), transparent);
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    margin: 0 10px;
    max-width: 80px;
  }
  .masthead-rule-divider { opacity: 0.55; }
  /* Playful, less literary title — Outfit-driven, with an italic
     Fraunces "the" sitting on top of the brand and title words.
     Sized modestly so it doesn't dominate the page like a broadsheet
     masthead; meant to read "happy little zine," not "The Paris
     Review." */
  .masthead-title {
    color: var(--deep-slate);
    font-family: var(--font-display);
    line-height: 1;
    margin: 0 0 18px;
    position: relative;
    z-index: 1;
  }
  .masthead-title-lede {
    color: rgb(44 62 80 / 55%);
    display: block;
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .masthead-title-brand {
    color: var(--heritage-orange);
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }
  .masthead-title-main {
    color: var(--deep-slate);
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 0.95;
    position: relative;
  }
