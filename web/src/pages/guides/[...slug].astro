---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AUTHOR } from '@beanies/brand/schema';
import { SITE_URL } from '@beanies/brand/nav';
import { isPublished } from '~/utils/content';
// Fraunces: humanist serif used for guide body prose only. Scoped here so
// it doesn't ship on every marketing page. Variable font = single file.
import '@fontsource-variable/fraunces';

export async function getStaticPaths() {
  const guides = await getCollection('guides', isPublished);
  return guides.map((guide) => ({
    params: { slug: guide.data.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

const canonicalPath = `/guides/${guide.data.slug}`;

// Build ToC from H2 headings. H3s skipped — too granular for a pillar ToC
// and clutters the rail. Astro's default slugger gives each an id.
const toc = headings.filter((h) => h.depth === 2);

// Rough reading time: 220 wpm against the rendered-content body. Pulled
// from the raw markdown body (Astro doesn't expose word count directly).
const wordCount = guide.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 220));

// Resolve related blog posts from frontmatter slugs (drafts stay excluded).
const allPosts = await getCollection('blog', isPublished);
const related = guide.data.relatedPosts
  .map((slug) => allPosts.find((p) => p.data.slug === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined)
  .map((p) => ({
    title: p.data.title,
    href: `/blog/${p.data.slug}`,
    excerpt: p.data.excerpt,
  }));

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Article JSON-LD — TechArticle subtype since guides are informational reference.
const articleSchema = {
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.excerpt,
  datePublished: guide.data.publishedDate.toISOString(),
  dateModified: guide.data.lastUpdated.toISOString(),
  author: { '@id': `${SITE_URL}/about/greg#greg` },
  publisher: { '@id': `${SITE_URL}#org` },
  mainEntityOfPage: `${SITE_URL}${canonicalPath}`,
  url: `${SITE_URL}${canonicalPath}`,
  inLanguage: 'en',
  keywords: guide.data.tags.join(', '),
};
---

<BaseLayout
  title={`${guide.data.title} — beanies.family`}
  description={guide.data.excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  publishedTime={guide.data.publishedDate.toISOString()}
  modifiedTime={guide.data.lastUpdated.toISOString()}
  jsonLd={[articleSchema, AUTHOR]}
>
  <!-- Reading progress bar: pure CSS via scroll-timeline where supported,
       no-op elsewhere. Thin Heritage Orange strip across the top of the page. -->
  <div class="guide-progress" aria-hidden="true"><span></span></div>

  <article class="guide-page">
    <div class="guide-shell">
      <!-- Left column: article body. Right column on wide screens: sticky
           section rail. Everything else collapses gracefully on narrow. -->
      <div class="guide-main">
        <a href="/guides" class="guide-back">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          all guides
        </a>

        <header class="guide-header">
          <p class="guide-kicker">
            <span class="guide-kicker-dot" aria-hidden="true"></span>
            the beanies guides · pillar
          </p>
          {guide.data.heroEmoji && <div class="guide-hero-emoji">{guide.data.heroEmoji}</div>}
          <h1 class="guide-title">{guide.data.title}</h1>
          <p class="guide-excerpt">{guide.data.excerpt}</p>
          <p class="guide-meta">
            <span class="guide-meta-dot">·</span>
            <time datetime={guide.data.lastUpdated.toISOString()}>
              updated {fmt(guide.data.lastUpdated)}
            </time>
            <span class="guide-meta-dot">·</span>
            <span>{readingMinutes} min read</span>
            {
              guide.data.lastUpdated.getTime() !== guide.data.publishedDate.getTime() && (
                <>
                  <span class="guide-meta-dot">·</span>
                  <span>first published <time datetime={guide.data.publishedDate.toISOString()}>{fmt(guide.data.publishedDate)}</time></span>
                </>
              )
            }
          </p>
        </header>

        {
          toc.length > 2 && (
            <nav class="guide-toc" aria-label="what's in this guide">
              <p class="guide-toc-label">what's in this guide</p>
              <ol class="guide-toc-list">
                {toc.map((h, i) => (
                  <li>
                    <a href={`#${h.slug}`}>
                      <span class="guide-toc-num">{String(i + 1).padStart(2, '0')}</span>
                      <span class="guide-toc-text">{h.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )
        }

        <div class="guide-divider guide-divider-top" aria-hidden="true">
          <span class="guide-divider-glyph">🫘</span>
        </div>

        <div class="guide-prose" id="guide-content">
          <Content />
        </div>

        {
          guide.data.keyTakeaways.length > 0 && (
            <section class="guide-recap" aria-labelledby="guide-recap-title">
              <div class="guide-recap-eyebrow">recap</div>
              <h2 id="guide-recap-title" class="guide-recap-title">what to take away</h2>
              <ol class="guide-recap-list">
                {guide.data.keyTakeaways.map((point, i) => (
                  <li>
                    <span class="guide-recap-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    <span class="guide-recap-text">{point}</span>
                  </li>
                ))}
              </ol>
            </section>
          )
        }

        {
          related.length > 0 && (
            <aside class="guide-related">
              <p class="guide-related-eyebrow">further reading</p>
              <h2 class="guide-related-title">from the beanstalk</h2>
              <p class="guide-related-sub">personal stories + product updates that expand on ideas in this guide.</p>
              <ul class="guide-related-list">
                {related.map((post) => (
                  <li>
                    <a href={post.href}>
                      <span class="guide-related-arrow" aria-hidden="true">→</span>
                      <span>
                        <span class="guide-related-post-title">{post.title}</span>
                        <span class="guide-related-post-excerpt">{post.excerpt}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </aside>
          )
        }
      </div>

      {
        toc.length > 2 && (
          <aside class="guide-rail" aria-hidden="true">
            <div class="guide-rail-inner">
              <p class="guide-rail-label">sections</p>
              <ol class="guide-rail-list">
                {toc.map((h, i) => (
                  <li>
                    <a href={`#${h.slug}`} data-rail-target={h.slug}>
                      <span class="guide-rail-num">{String(i + 1).padStart(2, '0')}</span>
                      <span class="guide-rail-text">{h.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          </aside>
        )
      }
    </div>
  </article>

  <!-- Back-to-top: matches the homepage control. Shown after 400px of scroll. -->
  <button id="back-to-top" class="back-to-top" aria-label="back to top" hidden>↑</button>
</BaseLayout>

<script>
  // Rail-section sync: highlight the current H2 in the sticky rail as the
  // reader scrolls. Works with IntersectionObserver. Falls back to no-op if
  // the rail isn't rendered (short guides) or the API is unavailable.
  const railLinks = document.querySelectorAll<HTMLAnchorElement>('[data-rail-target]');
  if (railLinks.length > 0 && 'IntersectionObserver' in window) {
    const headings = Array.from(
      document.querySelectorAll<HTMLHeadingElement>('.guide-prose h2[id]')
    );
    const byId = new Map<string, HTMLAnchorElement>();
    railLinks.forEach((a) => {
      const slug = a.dataset.railTarget;
      if (slug) byId.set(slug, a);
    });

    let currentActive: HTMLAnchorElement | null = null;
    const activate = (slug: string | undefined) => {
      if (!slug) return;
      const next = byId.get(slug);
      if (!next || next === currentActive) return;
      currentActive?.classList.remove('is-active');
      next.classList.add('is-active');
      currentActive = next;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) activate(visible[0].target.id);
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
    if (headings[0]) activate(headings[0].id);
  }

  // Copy-link on H2 hover — lightweight zero-deps version.
  for (const h of document.querySelectorAll<HTMLHeadingElement>('.guide-prose h2[id]')) {
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.className = 'guide-h2-anchor';
    a.setAttribute('aria-label', 'copy link to this section');
    a.textContent = '#';
    h.appendChild(a);
  }

  // Back-to-top: show after a screen's worth of scroll, smooth-scroll on click.
  const backToTop = document.getElementById('back-to-top');
  if (backToTop) {
    const toggleBackToTop = () => {
      if (window.scrollY > 400) backToTop.removeAttribute('hidden');
      else backToTop.setAttribute('hidden', '');
    };
    window.addEventListener('scroll', toggleBackToTop, { passive: true });
    toggleBackToTop();
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style is:global>
  .guide-page {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --sky-silk: #aed6f1;
    --cloud-white: #f8f9fa;
    --kraft: #f3ecd8;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', 'Fraunces', 'Source Serif 4', Georgia, serif;
    --font-hand: 'Caveat', 'Caveat Variable', cursive;
    background: var(--cloud-white);
    background-image:
      radial-gradient(circle at 8% 12%, rgb(241 93 34 / 3%) 0%, transparent 40%),
      radial-gradient(circle at 92% 88%, rgb(174 214 241 / 6%) 0%, transparent 45%);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Reading progress bar — uses scroll-timeline where supported (modern
     Chromium + Firefox Nightly). No JS needed. Other browsers: the bar
     stays at 0% width, which is fine — it's decorative, not load-bearing. */
  .guide-progress {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    z-index: 50;
    pointer-events: none;
    background: transparent;
  }
  .guide-progress span {
    display: block;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--heritage-orange), var(--terracotta));
    box-shadow: 0 0 8px rgb(241 93 34 / 40%);
  }
  @supports (animation-timeline: scroll()) {
    .guide-progress span {
      width: 100%;
      transform-origin: 0 50%;
      animation: guide-progress-grow linear both;
      animation-timeline: scroll(root block);
    }
    @keyframes guide-progress-grow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
  }

  .guide-shell {
    box-sizing: border-box;
    display: grid;
    gap: 48px;
    grid-template-columns: minmax(0, 1fr);
    margin: 0 auto;
    max-width: 780px;
    padding: 88px 24px 64px;
  }
  @media (min-width: 1200px) {
    .guide-shell {
      grid-template-columns: minmax(0, 720px) 200px;
      max-width: 1000px;
    }
  }
  @media (min-width: 1440px) {
    .guide-shell {
      grid-template-columns: minmax(0, 760px) 220px;
      max-width: 1080px;
    }
  }

  .guide-main { min-width: 0; }

  .guide-back {
    align-items: center;
    color: rgb(44 62 80 / 45%);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    gap: 6px;
    letter-spacing: 0.02em;
    margin-bottom: 32px;
    text-decoration: none;
    text-transform: lowercase;
    transition: color 200ms, gap 200ms;
  }
  .guide-back:hover {
    color: var(--heritage-orange);
    gap: 10px;
  }

  /* Hero — magazine-cover treatment. Kicker + oversized title + subtitle. */
  .guide-header {
    position: relative;
    margin-bottom: 40px;
    padding-bottom: 32px;
  }
  .guide-kicker {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    gap: 8px;
    letter-spacing: 0.16em;
    margin: 0 0 20px;
    text-transform: uppercase;
  }
  .guide-kicker-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgb(241 93 34 / 18%);
    display: inline-block;
    height: 6px;
    width: 6px;
  }
  .guide-hero-emoji {
    font-size: 3.5rem;
    line-height: 1;
    margin-bottom: 20px;
    filter: drop-shadow(0 8px 24px rgb(241 93 34 / 18%));
    transform-origin: center;
    animation: guide-emoji-breathe 6s ease-in-out infinite;
  }
  @keyframes guide-emoji-breathe {
    0%, 100% { transform: scale(1) rotate(-2deg); }
    50% { transform: scale(1.04) rotate(2deg); }
  }
  .guide-title {
    color: var(--deep-slate);
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
    max-width: 28ch;
    text-wrap: balance;
  }
  .guide-excerpt {
    color: rgb(44 62 80 / 72%);
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.55;
    margin: 20px 0 0;
    max-width: 52ch;
    text-wrap: pretty;
  }
  .guide-meta {
    color: rgb(44 62 80 / 48%);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 500;
    gap: 8px;
    letter-spacing: 0.02em;
    margin: 28px 0 0;
  }
  .guide-meta-dot { color: var(--heritage-orange); font-weight: 700; opacity: 0.55; }

  /* Top ToC — kept for pillar-level overview + AIO crawlers. Redesigned
     with numbered chapter list and hairline rule. Still semantic <ol>. */
  .guide-toc {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(243, 236, 216, 0.55));
    border: 1px solid var(--hairline);
    border-radius: 24px;
    box-shadow: 0 1px 0 rgb(44 62 80 / 3%), 0 12px 28px rgb(44 62 80 / 4%);
    margin: 36px 0 40px;
    padding: 28px 32px;
    position: relative;
  }
  .guide-toc::before {
    content: '🫘';
    font-size: 1.25rem;
    left: 24px;
    opacity: 0.45;
    position: absolute;
    top: -14px;
    background: var(--cloud-white);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .guide-toc-label {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    margin: 0 0 16px;
    text-transform: uppercase;
  }
  .guide-toc-list { counter-reset: chapter; list-style: none; margin: 0; padding: 0; }
  .guide-toc-list li {
    border-top: 1px solid var(--hairline);
    padding: 0;
  }
  .guide-toc-list li:first-child { border-top: none; }
  .guide-toc-list li a {
    align-items: baseline;
    color: var(--deep-slate);
    display: grid;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    gap: 16px;
    grid-template-columns: 28px 1fr;
    padding: 12px 0;
    text-decoration: none;
    transition: color 180ms, padding 180ms;
  }
  .guide-toc-list li a:hover {
    color: var(--heritage-orange);
    padding-left: 4px;
  }
  .guide-toc-num {
    color: var(--heritage-orange);
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-style: italic;
    font-weight: 600;
    opacity: 0.7;
  }

  /* Decorative divider — bean glyph centered between sections. */
  .guide-divider {
    align-items: center;
    display: flex;
    justify-content: center;
    margin: 32px 0 40px;
    position: relative;
  }
  .guide-divider::before,
  .guide-divider::after {
    background: linear-gradient(90deg, transparent, var(--hairline), var(--hairline), transparent);
    content: '';
    flex: 1;
    height: 1px;
    max-width: 140px;
  }
  .guide-divider-glyph {
    color: var(--heritage-orange);
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    margin: 0 16px;
    opacity: 0.55;
  }

  /* Prose body — Fraunces serif, relaxed rhythm, generous spacing. */
  .guide-prose {
    counter-reset: chapter;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.75;
    overflow-wrap: break-word;
  }
  /* Headings break on word boundaries only — aggressive wrapping is
     confined to paragraphs below, where long URLs may otherwise overflow. */
  .guide-prose h2,
  .guide-prose h3,
  .guide-prose h4 {
    overflow-wrap: normal;
    word-break: normal;
  }

  /* H2 — chapter opener with eyebrow + ornamental glyph. */
  .guide-prose h2 {
    color: var(--deep-slate);
    counter-increment: chapter;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 800;
    letter-spacing: -0.018em;
    line-height: 1.18;
    margin: 4.5rem 0 1.25rem;
    padding-top: 2.5rem;
    position: relative;
    scroll-margin-top: 90px;
    text-wrap: balance;
  }
  .guide-prose h2::before {
    color: var(--heritage-orange);
    content: 'chapter ' counter(chapter, decimal-leading-zero);
    display: block;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    margin-bottom: 10px;
    opacity: 0.85;
    text-transform: uppercase;
  }
  .guide-prose h2::after {
    background: var(--heritage-orange);
    border-radius: 999px;
    content: '';
    display: block;
    height: 3px;
    margin-top: 18px;
    width: 48px;
  }
  /* Copy-link glyph appended by the script above. */
  .guide-prose .guide-h2-anchor {
    color: rgb(44 62 80 / 15%);
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
    font-weight: 600;
    margin-left: 12px;
    opacity: 0;
    text-decoration: none;
    transition: opacity 160ms, color 160ms;
    vertical-align: middle;
  }
  .guide-prose h2:hover .guide-h2-anchor {
    color: var(--heritage-orange);
    opacity: 1;
  }

  .guide-prose h3 {
    color: var(--deep-slate);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 2.25rem 0 0.75rem;
    scroll-margin-top: 90px;
  }
  .guide-prose h3::before {
    color: var(--heritage-orange);
    content: '§';
    font-family: var(--font-serif);
    font-weight: 600;
    margin-right: 10px;
    opacity: 0.7;
  }

  /* Paragraphs — relaxed serif body. Allow aggressive breaking so the
     occasional pasted URL doesn't escape the column. */
  .guide-prose p {
    color: var(--ink);
    margin-bottom: 1.25rem;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .guide-prose p:last-child { margin-bottom: 0; }
  .guide-prose strong { color: var(--deep-slate); font-weight: 600; }
  .guide-prose em { color: var(--deep-slate); font-style: italic; }
  .guide-prose a {
    color: var(--heritage-orange);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: rgb(241 93 34 / 35%);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: text-decoration-color 180ms, color 180ms;
  }
  .guide-prose a:hover {
    color: var(--terracotta);
    text-decoration-color: currentColor;
    text-decoration-thickness: 2px;
  }

  /* Lead paragraph — first <p> after each H2 gets a drop-cap. Class is
     added by rehype-guide-annotations.mjs. Never matches the short-answer
     paragraph. */
  .guide-prose .guide-lead {
    font-size: 1.125rem;
    font-weight: 400;
  }
  .guide-prose .guide-lead::first-letter {
    background: linear-gradient(135deg, var(--heritage-orange), var(--terracotta));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    float: left;
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: 4.25rem;
    font-weight: 700;
    line-height: 0.88;
    margin: 0.24rem 0.5rem -0.1rem -0.15rem;
    padding-right: 4px;
  }

  /* Short-answer block — the AIO citation chunk. Kraft-paper card with
     Heritage Orange accent, "TL;DR" eyebrow (via CSS), quote-mark glyph.
     Semantically still a <p> with <strong> inside. */
  .guide-prose .guide-short-answer {
    background: linear-gradient(135deg, rgba(243, 236, 216, 0.7), rgba(255, 255, 255, 0.85));
    border: 1px solid rgb(241 93 34 / 12%);
    border-left: 4px solid var(--heritage-orange);
    border-radius: 18px;
    box-shadow: 0 1px 0 rgb(44 62 80 / 2%), 0 10px 24px rgb(44 62 80 / 4%);
    color: var(--deep-slate);
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.6;
    margin: 1.5rem 0 2rem;
    padding: 22px 28px 22px 60px;
    position: relative;
  }
  .guide-prose .guide-short-answer::before {
    color: rgb(241 93 34 / 30%);
    content: '“';
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 700;
    left: 18px;
    line-height: 1;
    position: absolute;
    top: 12px;
  }
  .guide-prose .guide-short-answer::after {
    background: var(--heritage-orange);
    border-radius: 999px;
    color: white;
    content: 'TL;DR';
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 4px 10px;
    position: absolute;
