---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AUTHOR } from '@beanies/brand/schema';
import { SITE_URL } from '@beanies/brand/nav';
import { isPublished } from '~/utils/content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', isPublished);
  return guides.map((guide) => ({
    params: { slug: guide.data.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

const canonicalPath = `/guides/${guide.data.slug}`;

// Build ToC from H2 headings. H3s are skipped — too granular for a pillar ToC
// and clutters the sidebar. Each heading already gets an id from Astro's
// default slugger (rehype-slug-style).
const toc = headings.filter((h) => h.depth === 2);

// Resolve related blog posts from frontmatter slugs (drafts stay excluded)
const allPosts = await getCollection('blog', isPublished);
const related = guide.data.relatedPosts
  .map((slug) => allPosts.find((p) => p.data.slug === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined)
  .map((p) => ({
    title: p.data.title,
    href: `/blog/${p.data.slug}`,
    excerpt: p.data.excerpt,
  }));

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Article JSON-LD — TechArticle subtype since guides are informational references
const articleSchema = {
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.excerpt,
  datePublished: guide.data.publishedDate.toISOString(),
  dateModified: guide.data.lastUpdated.toISOString(),
  author: { '@id': `${SITE_URL}/about/greg#greg` },
  publisher: { '@id': `${SITE_URL}#org` },
  mainEntityOfPage: `${SITE_URL}${canonicalPath}`,
  url: `${SITE_URL}${canonicalPath}`,
  inLanguage: 'en',
  keywords: guide.data.tags.join(', '),
};
---

<BaseLayout
  title={`${guide.data.title} — beanies.family`}
  description={guide.data.excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  publishedTime={guide.data.publishedDate.toISOString()}
  modifiedTime={guide.data.lastUpdated.toISOString()}
  jsonLd={[articleSchema, AUTHOR]}
>
  <article class="guide-page">
    <div class="guide-container">
      <a href="/guides" class="guide-back">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        all guides
      </a>

      <header class="guide-header">
        {guide.data.heroEmoji && <div class="guide-hero-emoji">{guide.data.heroEmoji}</div>}
        <h1 class="guide-title">{guide.data.title}</h1>
        <p class="guide-excerpt">{guide.data.excerpt}</p>
        <p class="guide-updated">
          <time datetime={guide.data.lastUpdated.toISOString()}>
            updated {fmt(guide.data.lastUpdated)}
          </time>
          {
            guide.data.lastUpdated.getTime() !== guide.data.publishedDate.getTime() && (
              <span class="guide-published">
                · first published <time datetime={guide.data.publishedDate.toISOString()}>{fmt(guide.data.publishedDate)}</time>
              </span>
            )
          }
        </p>
      </header>

      {
        toc.length > 2 && (
          <nav class="guide-toc" aria-label="Table of contents">
            <p class="guide-toc-label">what's in this guide</p>
            <ol class="guide-toc-list">
              {toc.map((h) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ol>
          </nav>
        )
      }

      <div class="guide-divider"></div>

      <div class="guide-prose" id="guide-content">
        <Content />
      </div>

      {
        related.length > 0 && (
          <aside class="guide-related">
            <h2 class="guide-related-title">further reading</h2>
            <p class="guide-related-sub">personal stories + product updates from the beanstalk blog:</p>
            <ul class="guide-related-list">
              {related.map((post) => (
                <li>
                  <a href={post.href}>
                    <span class="guide-related-post-title">{post.title}</span>
                    <span class="guide-related-post-excerpt">{post.excerpt}</span>
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
  </article>
</BaseLayout>

<style is:global>
  .guide-page {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --cloud-white: #f8f9fa;
    background: var(--cloud-white);
    min-height: 100vh;
    overflow-x: hidden;
  }
  .guide-container {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 720px;
    padding: 88px 24px 64px;
  }
  .guide-back {
    align-items: center;
    color: rgb(44 62 80 / 35%);
    display: inline-flex;
    font-family: Outfit, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    gap: 4px;
    margin-bottom: 24px;
    text-decoration: none;
    transition: color 200ms;
  }
  .guide-back:hover { color: var(--heritage-orange); }

  .guide-header { margin-bottom: 32px; }
  .guide-hero-emoji { font-size: 3rem; line-height: 1; margin-bottom: 16px; }
  .guide-title {
    color: var(--deep-slate);
    font-family: Outfit, sans-serif;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }
  .guide-excerpt {
    color: rgb(44 62 80 / 70%);
    font-family: Outfit, sans-serif;
    font-size: 1.0625rem;
    line-height: 1.55;
    margin: 12px 0 0;
  }
  .guide-updated {
    color: rgb(44 62 80 / 40%);
    font-family: Outfit, sans-serif;
    font-size: 0.75rem;
    margin: 16px 0 0;
  }
  .guide-published { margin-left: 4px; }

  .guide-toc {
    background: white;
    border: 1px solid rgb(44 62 80 / 8%);
    border-radius: 20px;
    margin: 32px 0;
    padding: 24px;
  }
  .guide-toc-label {
    color: rgb(44 62 80 / 50%);
    font-family: Outfit, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0 0 12px;
    text-transform: uppercase;
  }
  .guide-toc-list { list-style: decimal inside; margin: 0; padding: 0; }
  .guide-toc-list li { color: rgb(44 62 80 / 40%); font-size: 0.875rem; padding: 4px 0; }
  .guide-toc-list li a {
    color: var(--deep-slate);
    font-family: Outfit, sans-serif;
    font-weight: 600;
    text-decoration: none;
  }
  .guide-toc-list li a:hover { color: var(--heritage-orange); }

  .guide-divider {
    background: rgb(44 62 80 / 8%);
    height: 1px;
    margin: 24px 0;
  }

  .guide-prose { overflow-wrap: anywhere; word-break: break-word; }
  .guide-prose h2 {
    color: var(--deep-slate);
    font-family: Outfit, sans-serif;
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    scroll-margin-top: 90px;
  }
  .guide-prose h3 {
    color: var(--deep-slate);
    font-family: Outfit, sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    scroll-margin-top: 90px;
  }
  .guide-prose p {
    color: rgb(44 62 80 / 75%);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .guide-prose strong { color: var(--deep-slate); font-weight: 600; }
  .guide-prose em { font-style: italic; }
  .guide-prose a {
    color: var(--heritage-orange);
    font-weight: 600;
    text-decoration: none;
  }
  .guide-prose a:hover { color: var(--terracotta); text-decoration: underline; }
  .guide-prose ul, .guide-prose ol { margin-bottom: 1rem; padding-left: 1.5rem; }
  .guide-prose li {
    color: rgb(44 62 80 / 75%);
    line-height: 1.7;
    margin-bottom: 0.375rem;
  }
  .guide-prose ul li { list-style-type: disc; }
  .guide-prose ol li { list-style-type: decimal; }
  .guide-prose blockquote {
    border-left: 3px solid var(--heritage-orange);
    color: rgb(44 62 80 / 70%);
    font-style: italic;
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
  }
  .guide-prose code {
    background: rgb(44 62 80 / 5%);
    border-radius: 4px;
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
    padding: 0.15em 0.4em;
  }
  .guide-prose hr {
    background: rgb(44 62 80 / 8%);
    border: none;
    height: 1px;
    margin: 2rem 0;
  }
  .guide-prose img {
    border: 1px solid rgb(44 62 80 / 8%);
    border-radius: 16px;
    display: block;
    margin: 1.5rem auto;
    max-width: 100%;
    width: 100%;
  }

  .guide-related {
    background: white;
    border: 1px solid rgb(44 62 80 / 8%);
    border-radius: 24px;
    margin-top: 48px;
    padding: 28px;
  }
  .guide-related-title {
    color: var(--deep-slate);
    font-family: Outfit, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
  }
  .guide-related-sub {
    color: rgb(44 62 80 / 55%);
    font-size: 0.875rem;
    margin: 6px 0 16px;
  }
  .guide-related-list { list-style: none; margin: 0; padding: 0; }
  .guide-related-list li { border-top: 1px solid rgb(44 62 80 / 6%); }
  .guide-related-list li:first-child { border-top: none; }
  .guide-related-list a {
    color: var(--deep-slate);
    display: block;
    padding: 14px 0;
    text-decoration: none;
  }
  .guide-related-list a:hover { color: var(--heritage-orange); }
  .guide-related-post-title {
    display: block;
    font-family: Outfit, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
  }
  .guide-related-post-excerpt {
    color: rgb(44 62 80 / 55%);
    display: block;
    font-size: 0.8125rem;
    margin-top: 4px;
  }

  @media (max-width: 520px) {
    .guide-container { padding-top: 76px; }
    .guide-title { font-size: 1.5rem; }
    .guide-excerpt { font-size: 0.9375rem; }
  }
</style>
