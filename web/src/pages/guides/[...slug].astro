---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AUTHOR } from '@beanies/brand/schema';
import { SITE_URL } from '@beanies/brand/nav';
import { isPublished, comparePillarOrder } from '~/utils/content';
// Fraunces: humanist serif used for guide body prose only. Scoped here so
// it doesn't ship on every marketing page. Variable font = single file.
import '@fontsource-variable/fraunces';

export async function getStaticPaths() {
  const guides = await getCollection('guides', isPublished);
  // Walk the pillar set in the canonical Notion order (see `comparePillarOrder`
  // in utils/content.ts) so prev/next mirrors the library index. Not
  // chronological — the guides are intentionally read as a curriculum.
  const sorted = [...guides].sort(comparePillarOrder);
  return guides.map((guide) => {
    const i = sorted.findIndex((g) => g.data.slug === guide.data.slug);
    const prevGuide = i > 0 ? sorted[i - 1] : undefined;
    const nextGuide = i < sorted.length - 1 ? sorted[i + 1] : undefined;
    // `firstGuide` powers the loopback CTA on the final pillar's payoff
    // card ("re-read chapter 1 with the system in mind"). Also supplies
    // chapter-1 title/slug so the card doesn't have to hard-code either.
    const firstGuide = sorted[0];
    return {
      params: { slug: guide.data.slug },
      props: {
        guide,
        prevGuide,
        nextGuide,
        firstGuide,
        chapterNumber: i + 1,
        prevChapterNumber: i > 0 ? i : undefined,
        nextChapterNumber: i < sorted.length - 1 ? i + 2 : undefined,
      },
    };
  });
}

const { guide, prevGuide, nextGuide, firstGuide, chapterNumber, prevChapterNumber, nextChapterNumber } = Astro.props;
const { Content, headings } = await render(guide);

const canonicalPath = `/guides/${guide.data.slug}`;

// Build ToC from H2 headings. H3s skipped — too granular for a pillar ToC
// and clutters the rail. Astro's default slugger gives each an id.
const toc = headings.filter((h) => h.depth === 2);

// Rough reading time: 220 wpm against the rendered-content body. Pulled
// from the raw markdown body (Astro doesn't expose word count directly).
const wordCount = guide.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 220));

// Resolve related blog posts from frontmatter slugs (drafts stay excluded).
const allPosts = await getCollection('blog', isPublished);
const related = guide.data.relatedPosts
  .map((slug) => allPosts.find((p) => p.data.slug === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined)
  .map((p) => ({
    title: p.data.title,
    href: `/blog/${p.data.slug}`,
    excerpt: p.data.excerpt,
  }));

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Article JSON-LD — TechArticle subtype since guides are informational reference.
const articleSchema = {
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.excerpt,
  datePublished: guide.data.publishedDate.toISOString(),
  dateModified: guide.data.lastUpdated.toISOString(),
  author: { '@id': `${SITE_URL}/about/greg#greg` },
  publisher: { '@id': `${SITE_URL}#org` },
  mainEntityOfPage: `${SITE_URL}${canonicalPath}`,
  url: `${SITE_URL}${canonicalPath}`,
  inLanguage: 'en',
  keywords: guide.data.tags.join(', '),
};
---

<BaseLayout
  title={`${guide.data.title} — beanies.family`}
  description={guide.data.excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  publishedTime={guide.data.publishedDate.toISOString()}
  modifiedTime={guide.data.lastUpdated.toISOString()}
  jsonLd={[articleSchema, AUTHOR]}
>
  <!-- Reading progress bar: pure CSS via scroll-timeline where supported,
       no-op elsewhere. Thin Heritage Orange strip across the top of the page. -->
  <div class="guide-progress" aria-hidden="true"><span></span></div>

  <article class="guide-page">
    <div class="guide-shell">
      <!-- Left column: article body. Right column on wide screens: sticky
           section rail. Everything else collapses gracefully on narrow. -->
      <div class="guide-main">
        <a href="/guides" class="guide-back">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          all guides
        </a>

        <header class="guide-header">
          <p class="guide-kicker">
            <span class="guide-kicker-dot" aria-hidden="true"></span>
            the beanies guides · pillar
          </p>
          {guide.data.heroEmoji && <div class="guide-hero-emoji">{guide.data.heroEmoji}</div>}
          <h1 class="guide-title">{guide.data.title}</h1>
          <p class="guide-excerpt">{guide.data.excerpt}</p>
          <p class="guide-meta">
            <span class="guide-meta-dot">·</span>
            <time datetime={guide.data.lastUpdated.toISOString()}>
              updated {fmt(guide.data.lastUpdated)}
            </time>
            <span class="guide-meta-dot">·</span>
            <span>{readingMinutes} min read</span>
            {
              guide.data.lastUpdated.getTime() !== guide.data.publishedDate.getTime() && (
                <>
                  <span class="guide-meta-dot">·</span>
                  <span>first published <time datetime={guide.data.publishedDate.toISOString()}>{fmt(guide.data.publishedDate)}</time></span>
                </>
              )
            }
          </p>
        </header>

        {
          toc.length > 2 && (
            <nav class="guide-toc" aria-label="what's in this guide">
              <p class="guide-toc-label">what's in this guide</p>
              <ol class="guide-toc-list">
                {toc.map((h, i) => (
                  <li>
                    <a href={`#${h.slug}`}>
                      <span class="guide-toc-num">{String(i + 1).padStart(2, '0')}</span>
                      <span class="guide-toc-text">{h.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )
        }

        <div class="guide-divider guide-divider-top" aria-hidden="true">
          <span class="guide-divider-glyph">🫘</span>
        </div>

        <div class="guide-prose" id="guide-content">
          <Content />
        </div>

        {
          guide.data.keyTakeaways.length > 0 && (
            <section class="guide-recap" aria-labelledby="guide-recap-title">
              <div class="guide-recap-eyebrow">recap</div>
              <h2 id="guide-recap-title" class="guide-recap-title">what to take away</h2>
              <ol class="guide-recap-list">
                {guide.data.keyTakeaways.map((point, i) => (
                  <li>
                    <span class="guide-recap-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    <span class="guide-recap-text">{point}</span>
                  </li>
                ))}
              </ol>
            </section>
          )
        }

        {/* Final-pillar payoff card — renders BEFORE "further reading"
            so the primary end-of-curriculum CTAs land before we offer
            off-ramp links to the blog. The payoff is the closing beat
            we want the reader to arrive at. Only renders on the guide
            flagged `isFinalPillar` in frontmatter. */}
        {guide.data.isFinalPillar && firstGuide && (
          <section class="guide-payoff" aria-labelledby="guide-payoff-title">
            <div class="guide-payoff-eyebrow">
              <span class="guide-payoff-eyebrow-dot" aria-hidden="true"></span>
              you made it!
            </div>
            <h2 id="guide-payoff-title" class="guide-payoff-title">what should i do now?</h2>
            <p class="guide-payoff-body">
              well, we did it. we've talked about the feeling of being overwhelmed,
              how we can feel more organized and in control, understanding our family
              finances, and why the systems and tools we use are critically important
              in accomplishing our goal of regaining control, while at the same time
              preserving our privacy (and sanity).
            </p>
            <p class="guide-payoff-body">
              what comes next is practice - put these ideas to work in the world, in
              your real life, using whatever systems work best for you.
            </p>
            <p class="guide-payoff-body">
              <strong>beanies.family</strong> is the tool I built based on the
              lessons I've described in the four chapters above. It's local-first,
              family-friendly, and designed for exactly this.
            </p>
            <div class="guide-payoff-actions">
              <a class="guide-payoff-cta guide-payoff-cta-primary" href="https://app.beanies.family/welcome">
                <span class="guide-payoff-cta-label">try beanies.family</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
              <a class="guide-payoff-cta guide-payoff-cta-secondary" href={`/guides/${firstGuide.data.slug}`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                  <polyline points="12 19 5 12 12 5" />
                  <line x1="19" y1="12" x2="5" y2="12" />
                </svg>
                <span class="guide-payoff-cta-label">re-read chapter 1</span>
              </a>
            </div>
            {guide.data.loopbackTeaser && (
              <p class="guide-payoff-loopback">
                {guide.data.loopbackTeaser} <a class="guide-payoff-loopback-link" href="/#contact">let me know</a>.
              </p>
            )}
          </section>
        )}

        {
          related.length > 0 && (
            <aside class="guide-related">
              <p class="guide-related-eyebrow">further reading</p>
              <h2 class="guide-related-title">from the beanstalk</h2>
              <p class="guide-related-sub">personal stories + product updates that expand on ideas in this guide.</p>
              <ul class="guide-related-list">
                {related.map((post) => (
                  <li>
                    <a href={post.href}>
                      <span class="guide-related-arrow" aria-hidden="true">→</span>
                      <span>
                        <span class="guide-related-post-title">{post.title}</span>
                        <span class="guide-related-post-excerpt">{post.excerpt}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </aside>
          )
        }

        {/* Prev/next chapter nav — a two-card walk-through rhythm. Each
            card shows the chapter label + title as the header and the
            forward/backward teaser (pulled from adjacent pillar's
            frontmatter via `nextGuide.data.nextTeaser` for forward and
            `guide.data.prevTeaser` for backward) as the earn-the-click
            body copy. On the final pillar, the "next" slot drops since
            the payoff card above already replaces it. */}
        <nav class="guide-nav" aria-label="guide navigation" data-final={guide.data.isFinalPillar ? 'true' : undefined}>
          <a class="guide-nav-btn" href={prevGuide ? `/guides/${prevGuide.data.slug}` : '/guides'}>
            <svg class="guide-nav-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24" aria-hidden="true">
              <polyline points="15 18 9 12 15 6" />
            </svg>
            <span class="guide-nav-text">
              <span class="guide-nav-label">
                {prevGuide ? `chapter ${prevChapterNumber} ·  previous` : 'back to'}
              </span>
              <span class="guide-nav-title">
                {prevGuide ? prevGuide.data.title : 'the curriculum'}
              </span>
              {prevGuide && guide.data.prevTeaser && (
                <span class="guide-nav-teaser">{guide.data.prevTeaser}</span>
              )}
            </span>
          </a>

          {!guide.data.isFinalPillar && (
            <a
              class="guide-nav-btn guide-nav-btn-right"
              href={nextGuide ? `/guides/${nextGuide.data.slug}` : '/guides'}
            >
              <span class="guide-nav-text">
                <span class="guide-nav-label">
                  {nextGuide ? `chapter ${nextChapterNumber} ·  next` : 'back to'}
                </span>
                <span class="guide-nav-title">
                  {nextGuide ? nextGuide.data.title : 'the curriculum'}
                </span>
                {nextGuide && guide.data.nextTeaser && (
                  <span class="guide-nav-teaser">{guide.data.nextTeaser}</span>
                )}
              </span>
              <svg class="guide-nav-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24" aria-hidden="true">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </a>
          )}
        </nav>
      </div>

      {
        toc.length > 2 && (
          <aside class="guide-rail" aria-hidden="true">
            <div class="guide-rail-inner">
              <p class="guide-rail-label">sections</p>
              <ol class="guide-rail-list">
                {toc.map((h, i) => (
                  <li>
                    <a href={`#${h.slug}`} data-rail-target={h.slug}>
                      <span class="guide-rail-num">{String(i + 1).padStart(2, '0')}</span>
                      <span class="guide-rail-text">{h.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          </aside>
        )
      }
    </div>
  </article>

  <!-- Back-to-top: matches the homepage control. Shown after 400px of scroll. -->
  <button id="back-to-top" class="back-to-top" aria-label="back to top" hidden>↑</button>
</BaseLayout>

<script>
  // Rail-section sync: highlight the current H2 in the sticky rail as the
  // reader scrolls. Works with IntersectionObserver. Falls back to no-op if
  // the rail isn't rendered (short guides) or the API is unavailable.
  const railLinks = document.querySelectorAll<HTMLAnchorElement>('[data-rail-target]');
  if (railLinks.length > 0 && 'IntersectionObserver' in window) {
    const headings = Array.from(
      document.querySelectorAll<HTMLHeadingElement>('.guide-prose h2[id]')
    );
    const byId = new Map<string, HTMLAnchorElement>();
    railLinks.forEach((a) => {
      const slug = a.dataset.railTarget;
      if (slug) byId.set(slug, a);
    });

    let currentActive: HTMLAnchorElement | null = null;
    const activate = (slug: string | undefined) => {
      if (!slug) return;
      const next = byId.get(slug);
      if (!next || next === currentActive) return;
      currentActive?.classList.remove('is-active');
      next.classList.add('is-active');
      currentActive = next;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) activate(visible[0].target.id);
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
    if (headings[0]) activate(headings[0].id);
  }

  // Copy-link on H2 hover — lightweight zero-deps version.
  for (const h of document.querySelectorAll<HTMLHeadingElement>('.guide-prose h2[id]')) {
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.className = 'guide-h2-anchor';
    a.setAttribute('aria-label', 'copy link to this section');
    a.textContent = '#';
    h.appendChild(a);
  }

  // Back-to-top: show after a screen's worth of scroll, smooth-scroll on click.
  const backToTop = document.getElementById('back-to-top');
  if (backToTop) {
    const toggleBackToTop = () => {
      if (window.scrollY > 400) backToTop.removeAttribute('hidden');
      else backToTop.setAttribute('hidden', '');
    };
    window.addEventListener('scroll', toggleBackToTop, { passive: true });
    toggleBackToTop();
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style is:global>
  .guide-page {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --sky-silk: #aed6f1;
    --cloud-white: #f8f9fa;
    --kraft: #f3ecd8;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', 'Fraunces', 'Source Serif 4', Georgia, serif;
    --font-hand: 'Caveat', 'Caveat Variable', cursive;
    background: var(--cloud-white);
    background-image:
      radial-gradient(circle at 8% 12%, rgb(241 93 34 / 3%) 0%, transparent 40%),
      radial-gradient(circle at 92% 88%, rgb(174 214 241 / 6%) 0%, transparent 45%);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Reading progress bar — uses scroll-timeline where supported (modern
     Chromium + Firefox Nightly). No JS needed. Other browsers: the bar
     stays at 0% width, which is fine — it's decorative, not load-bearing. */
  .guide-progress {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    z-index: 50;
    pointer-events: none;
    background: transparent;
  }
  .guide-progress span {
    display: block;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--heritage-orange), var(--terracotta));
    box-shadow: 0 0 8px rgb(241 93 34 / 40%);
  }
  @supports (animation-timeline: scroll()) {
    .guide-progress span {
      width: 100%;
      transform-origin: 0 50%;
      animation: guide-progress-grow linear both;
      animation-timeline: scroll(root block);
    }
    @keyframes guide-progress-grow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
  }

  .guide-shell {
    box-sizing: border-box;
    display: grid;
    gap: 48px;
    grid-template-columns: minmax(0, 1fr);
    margin: 0 auto;
    max-width: 780px;
    padding: 88px 24px 64px;
  }
  @media (min-width: 1200px) {
    .guide-shell {
      grid-template-columns: minmax(0, 720px) 200px;
      max-width: 1000px;
    }
  }
  @media (min-width: 1440px) {
    .guide-shell {
      grid-template-columns: minmax(0, 760px) 220px;
      max-width: 1080px;
    }
  }

  .guide-main { min-width: 0; }

  .guide-back {
    align-items: center;
    color: rgb(44 62 80 / 45%);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    gap: 6px;
    letter-spacing: 0.02em;
    margin-bottom: 32px;
    text-decoration: none;
    text-transform: lowercase;
    transition: color 200ms, gap 200ms;
  }
  .guide-back:hover {
    color: var(--heritage-orange);
    gap: 10px;
  }

  /* Hero — magazine-cover treatment. Kicker + oversized title + subtitle. */
  .guide-header {
    position: relative;
    margin-bottom: 40px;
    padding-bottom: 32px;
  }
  .guide-kicker {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    gap: 8px;
    letter-spacing: 0.16em;
    margin: 0 0 20px;
    text-transform: uppercase;
  }
  .guide-kicker-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgb(241 93 34 / 18%);
    display: inline-block;
    height: 6px;
    width: 6px;
  }
  .guide-hero-emoji {
    font-size: 3.5rem;
    line-height: 1;
    margin-bottom: 20px;
    filter: drop-shadow(0 8px 24px rgb(241 93 34 / 18%));
    transform-origin: center;
    animation: guide-emoji-breathe 6s ease-in-out infinite;
  }
  @keyframes guide-emoji-breathe {
    0%, 100% { transform: scale(1) rotate(-2deg); }
    50% { transform: scale(1.04) rotate(2deg); }
  }
  .guide-title {
    color: var(--deep-slate);
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
    max-width: 28ch;
    text-wrap: balance;
  }
  .guide-excerpt {
    color: rgb(44 62 80 / 72%);
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.55;
    margin: 20px 0 0;
    max-width: 52ch;
    text-wrap: pretty;
  }
  .guide-meta {
    color: rgb(44 62 80 / 48%);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 500;
    gap: 8px;
    letter-spacing: 0.02em;
    margin: 28px 0 0;
  }
  .guide-meta-dot { color: var(--heritage-orange); font-weight: 700; opacity: 0.55; }

  /* Top ToC — kept for pillar-level overview + AIO crawlers. Redesigned
     with numbered chapter list and hairline rule. Still semantic <ol>. */
  .guide-toc {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(243, 236, 216, 0.55));
    border: 1px solid var(--hairline);
    border-radius: 24px;
    box-shadow: 0 1px 0 rgb(44 62 80 / 3%), 0 12px 28px rgb(44 62 80 / 4%);
    margin: 36px 0 40px;
    padding: 28px 32px;
    position: relative;
  }
  .guide-toc::before {
    content: '🫘';
    font-size: 1.25rem;
    left: 24px;
    opacity: 0.45;
    position: absolute;
    top: -14px;
    background: var(--cloud-white);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .guide-toc-label {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    margin: 0 0 16px;
    text-transform: uppercase;
  }
  .guide-toc-list { counter-reset: chapter; list-style: none; margin: 0; padding: 0; }
  .guide-toc-list li {
    border-top: 1px solid var(--hairline);
    padding: 0;
  }
  .guide-toc-list li:first-child { border-top: none; }
  .guide-toc-list li a {
    align-items: baseline;
    color: var(--deep-slate);
    display: grid;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    gap: 16px;
    grid-template-columns: 28px 1fr;
    padding: 12px 0;
    text-decoration: none;
    transition: color 180ms, padding 180ms;
  }
  .guide-toc-list li a:hover {
    color: var(--heritage-orange);
    padding-left: 4px;
  }
  .guide-toc-num {
    color: var(--heritage-orange);
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-style: italic;
    font-weight: 600;
    opacity: 0.7;
  }

  /* Decorative divider — bean glyph centered between sections. */
  .guide-divider {
    align-items: center;
    display: flex;
    justify-content: center;
    margin: 32px 0 40px;
    position: relative;
  }
  .guide-divider::before,
  .guide-divider::after {
    background: linear-gradient(90deg, transparent, var(--hairline), var(--hairline), transparent);
    content: '';
    flex: 1;
    height: 1px;
    max-width: 140px;
  }
  .guide-divider-glyph {
    color: var(--heritage-orange);
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    margin: 0 16px;
    opacity: 0.55;
  }

  /* Hugging-beanies mascot at the warm ending of a guide. Centres the
     PNG, applies a soft idle breath so it feels alive, lifts it with a
     subtle drop-shadow in Heritage Orange so it reads as a happy-end
     punctuation mark rather than a random image drop. `prefers-reduced-
     motion` drops the animation. */
  .guide-prose .guide-beanies-hug {
    animation: beanies-hug-breath 5.2s ease-in-out infinite;
    filter: drop-shadow(0 18px 32px rgb(241 93 34 / 20%));
    margin: 32px auto 40px;
    max-width: 220px;
    text-align: center;
  }
  .guide-prose .guide-beanies-hug img {
    display: block;
    height: auto;
    margin: 0 auto;
    max-width: 200px;
    width: 100%;
  }
  @keyframes beanies-hug-breath {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-3px) scale(1.015); }
  }
  @media (prefers-reduced-motion: reduce) {
    .guide-prose .guide-beanies-hug { animation: none; }
  }
  @media (max-width: 520px) {
    .guide-prose .guide-beanies-hug { margin: 24px auto 32px; max-width: 160px; }
    .guide-prose .guide-beanies-hug img { max-width: 160px; }
  }

  /* Prose body — Fraunces serif, relaxed rhythm, generous spacing. */
  .guide-prose {
    counter-reset: chapter;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.75;
    overflow-wrap: break-word;
  }
  /* Headings break on word boundaries only — aggressive wrapping is
     confined to paragraphs below, where long URLs may otherwise overflow. */
  .guide-prose h2,
  .guide-prose h3,
  .guide-prose h4 {
    overflow-wrap: normal;
    word-break: normal;
  }

  /* H2 — chapter opener with eyebrow + ornamental glyph. */
  .guide-prose h2 {
    color: var(--deep-slate);
    counter-increment: chapter;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 800;
    letter-spacing: -0.018em;
    line-height: 1.18;
    margin: 4.5rem 0 1.25rem;
    padding-top: 2.5rem;
    position: relative;
    scroll-margin-top: 90px;
    text-wrap: balance;
  }
  .guide-prose h2::before {
    color: var(--heritage-orange);
    content: 'chapter ' counter(chapter);
    display: block;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    margin-bottom: 10px;
    opacity: 0.85;
    text-transform: uppercase;
  }
  .guide-prose h2::after {
    background: var(--heritage-orange);
    border-radius: 999px;
    content: '';
    display: block;
    height: 3px;
    margin-top: 18px;
    width: 48px;
  }
  /* Copy-link glyph appended by the script above. */
  .guide-prose .guide-h2-anchor {
    color: rgb(44 62 80 / 15%);
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
    font-weight: 600;
    margin-left: 12px;
    opacity: 0;
    text-decoration: none;
    transition: opacity 160ms, color 160ms;
    vertical-align: middle;
  }
  .guide-prose h2:hover .guide-h2-anchor {
    color: var(--heritage-orange);
    opacity: 1;
  }

  .guide-prose h3 {
    color: var(--deep-slate);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 2.25rem 0 0.75rem;
    scroll-margin-top: 90px;
  }
  .guide-prose h3::before {
    color: var(--heritage-orange);
    content: '§';
    font-family: var(--font-serif);
    font-weight: 600;
    margin-right: 10px;
    opacity: 0.7;
  }

  /* Paragraphs — relaxed serif body. Allow aggressive breaking so the
     occasional pasted URL doesn't escape the column. */
  .guide-prose p {
    color: var(--ink);
    margin-bottom: 1.25rem;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .guide-prose p:last-child { margin-bottom: 0; }
  .guide-prose strong { color: var(--deep-slate); font-weight: 600; }
  .guide-prose em { color: var(--deep-slate); font-style: italic; }
  .guide-prose a {
    color: var(--heritage-orange);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: rgb(241 93 34 / 35%);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: text-decoration-color 180ms, color 180ms;
  }
  .guide-prose a:hover {
    color: var(--terracotta);
    text-decoration-color: currentColor;
    text-decoration-thickness: 2px;
  }

  /* Lead paragraph — first <p> after each H2 gets a drop-cap. Class is
     added by rehype-guide-annotations.mjs. Never matches the short-answer
     paragraph. `display: flow-root` establishes a block-formatting context
     so the floated ::first-letter stays contained to this paragraph —
     otherwise a short lead + a following list lets the float extend below
     and pushes the first bullet (and only the first bullet) to the right. */
  .guide-prose .guide-lead {
    display: flow-root;
    font-size: 1.125rem;
    font-weight: 400;
  }
  .guide-prose .guide-lead::first-letter {
    background: linear-gradient(135deg, var(--heritage-orange), var(--terracotta));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    float: left;
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: 4.25rem;
    font-weight: 700;
    line-height: 0.88;
    margin: 0.24rem 0.5rem -0.1rem -0.15rem;
    padding-right: 4px;
  }

  /* Short-answer block — the AIO citation chunk. Kraft-paper card with
     Heritage Orange accent, "TL;DR" eyebrow (via CSS), quote-mark glyph.
     Semantically still a <p> with <strong> inside. */
  .guide-prose .guide-short-answer {
    background: linear-gradient(135deg, rgba(243, 236, 216, 0.7), rgba(255, 255, 255, 0.85));
    border: 1px solid rgb(241 93 34 / 12%);
    border-left: 4px solid var(--heritage-orange);
    border-radius: 18px;
    box-shadow: 0 1px 0 rgb(44 62 80 / 2%), 0 10px 24px rgb(44 62 80 / 4%);
    color: var(--deep-slate);
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.6;
    margin: 1.5rem 0 2rem;
    padding: 22px 28px 22px 60px;
    position: relative;
  }
  .guide-prose .guide-short-answer::before {
    color: rgb(241 93 34 / 30%);
    content: '“';
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 700;
    left: 18px;
    line-height: 1;
    position: absolute;
    top: 12px;
  }
  .guide-prose .guide-short-answer::after {
    background: var(--heritage-orange);
    border-radius: 999px;
    color: white;
    content: 'TL;DR';
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 4px 10px;
    position: absolute;
    right: 16px;
    text-transform: uppercase;
    top: -10px;
  }
  .guide-prose .guide-short-answer-label {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    margin-right: 6px;
    text-transform: uppercase;
    vertical-align: 0.1em;
  }

  /* Lists — break up dense paragraphs. Explicit list-style is needed
     because a global reset (Tailwind preflight / Astro BaseLayout) strips
     markers across the site. */
  .guide-prose ul, .guide-prose ol {
    margin: 0 0 1.5rem;
    padding-left: 1.75rem;
  }
  .guide-prose ul { list-style: disc; }
  .guide-prose ol { list-style: decimal; }
  .guide-prose li {
    color: var(--ink);
    margin-bottom: 0.5rem;
    padding-left: 6px;
  }
  .guide-prose ul li::marker { color: var(--heritage-orange); }
  .guide-prose ol li::marker { color: var(--heritage-orange); font-weight: 600; }

  /* Blockquote — pull-quote-style treatment. Hand-font accent mark. */
  .guide-prose blockquote {
    border: none;
    color: var(--deep-slate);
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.005em;
    line-height: 1.45;
    margin: 2rem 0;
    padding: 0 0 0 2.5rem;
    position: relative;
  }
  .guide-prose blockquote::before {
    color: var(--heritage-orange);
    content: '—';
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    left: 0;
    line-height: 1;
    opacity: 0.7;
    position: absolute;
    top: 0.1em;
  }
  .guide-prose blockquote p { color: inherit; font-size: inherit; margin-bottom: 0.75rem; }
  .guide-prose blockquote p:last-child { margin-bottom: 0; }

  .guide-prose code {
    background: rgb(44 62 80 / 6%);
    border-radius: 4px;
    color: var(--deep-slate);
    font-family: ui-monospace, monospace;
    font-size: 0.88em;
    font-weight: 500;
    padding: 0.15em 0.42em;
  }
  .guide-prose hr {
    background: var(--hairline);
    border: none;
    height: 1px;
    margin: 2.5rem auto;
    width: 60%;
  }
  .guide-prose img {
    border: 1px solid var(--hairline);
    border-radius: 20px;
    box-shadow: 0 12px 36px rgb(44 62 80 / 6%);
    display: block;
    margin: 2rem auto;
    max-width: 100%;
    width: 100%;
  }

  /* Recap card — structured takeaways at the article's close.
     Kraft-paper treatment, numbered list, acts as a visual "landing pad". */
  .guide-recap {
    background: linear-gradient(135deg, var(--deep-slate), #34495e 70%, #2c3e50);
    background-image:
      linear-gradient(135deg, rgba(241, 93, 34, 0.12), transparent 60%),
      linear-gradient(135deg, var(--deep-slate), #34495e);
    border-radius: 28px;
    box-shadow: 0 1px 0 rgb(44 62 80 / 4%), 0 24px 60px rgb(44 62 80 / 14%);
    color: white;
    margin: 64px 0 48px;
    overflow: hidden;
    padding: 36px 36px 40px;
    position: relative;
  }
  .guide-recap::before {
    background: radial-gradient(circle, rgba(241, 93, 34, 0.25) 0%, transparent 70%);
    border-radius: 50%;
    content: '';
    height: 260px;
    position: absolute;
    right: -80px;
    top: -80px;
    width: 260px;
  }
  .guide-recap-eyebrow {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    margin-bottom: 8px;
    position: relative;
    text-transform: uppercase;
  }
  .guide-recap-title {
    color: white;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
    position: relative;
  }
  .guide-recap-list {
    counter-reset: recap;
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .guide-recap-list li {
    align-items: baseline;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: grid;
    gap: 18px;
    grid-template-columns: 40px 1fr;
    padding: 16px 0;
  }
  .guide-recap-list li:first-child { border-top: none; padding-top: 4px; }
  .guide-recap-num {
    color: var(--heritage-orange);
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 600;
    line-height: 1;
  }
  .guide-recap-text {
    color: rgba(255, 255, 255, 0.88);
    font-family: var(--font-serif);
    font-size: 1.025rem;
    line-height: 1.55;
  }

  /* Related ("from the beanstalk") — paper-card, hand-font accent. */
  .guide-related {
    background: white;
    border: 1px solid var(--hairline);
    border-radius: 24px;
    box-shadow: 0 1px 0 rgb(44 62 80 / 2%), 0 8px 24px rgb(44 62 80 / 3%);
    margin-top: 32px;
    padding: 32px;
  }
  .guide-related-eyebrow {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    margin: 0 0 6px;
    text-transform: uppercase;
  }
  .guide-related-title {
    color: var(--deep-slate);
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .guide-related-sub {
    color: var(--muted);
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    margin: 6px 0 18px;
  }
  .guide-related-list { list-style: none; margin: 0; padding: 0; }
  .guide-related-list li { border-top: 1px solid var(--hairline); }
  .guide-related-list li:first-child { border-top: none; }
  .guide-related-list a {
    align-items: start;
    color: var(--deep-slate);
    display: grid;
    gap: 16px;
    grid-template-columns: 24px 1fr;
    padding: 16px 0;
    text-decoration: none;
    transition: color 180ms, gap 180ms;
  }
  .guide-related-list a:hover {
    color: var(--heritage-orange);
    gap: 20px;
  }
  .guide-related-arrow {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    opacity: 0.5;
    transition: opacity 180ms;
  }
  .guide-related-list a:hover .guide-related-arrow { opacity: 1; }
  .guide-related-post-title {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
  }
  .guide-related-post-excerpt {
    color: var(--muted);
    display: block;
    font-family: var(--font-serif);
    font-size: 0.92rem;
    font-style: italic;
    line-height: 1.5;
    margin-top: 4px;
  }

  /* Prev/next guide navigation — two flex cards that walk the pillar
     set in chronological order. Uses min-width: 0 on both the button
     and its inner text container so long titles collapse to ellipsis
     on mobile instead of blowing the flex row past the viewport
     (same trick the blog's post-nav uses). Styling leans e-zine:
     cream cards, hairline rule on top, serif italic labels. */
  /* ==========================================================
     Final-pillar payoff card — the closing moment of the curriculum.

     Visually distinct from every other block on the page: filled
     slate-to-orange wash, kraft-paper grain, enough negative space
     that the two CTAs are the centre of attention. This is the reader's
     arrival, not a nav row. Only renders when `isFinalPillar: true`
     in the guide frontmatter.
  ========================================================== */
  .guide-payoff {
    background:
      radial-gradient(circle at 18% 20%, rgb(241 93 34 / 12%) 0%, transparent 50%),
      radial-gradient(circle at 82% 80%, rgb(230 126 34 / 10%) 0%, transparent 55%),
      linear-gradient(145deg, #1d2a3a 0%, #2c3e50 60%, #35516c 100%);
    border: 1px solid rgb(255 255 255 / 8%);
    border-radius: 28px;
    box-shadow:
      0 1px 0 rgb(255 255 255 / 10%) inset,
      0 28px 60px -28px rgb(44 62 80 / 40%);
    color: white;
    margin-top: 56px;
    overflow: hidden;
    padding: 44px 40px 40px;
    position: relative;
  }
  /* Subtle grain so the filled slate doesn't read as flat digital fill. */
  .guide-payoff::before {
    background-image:
      radial-gradient(circle at 10% 10%, rgb(255 255 255 / 4%) 0%, transparent 20%),
      radial-gradient(circle at 90% 90%, rgb(255 255 255 / 3%) 0%, transparent 22%);
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  .guide-payoff > * { position: relative; z-index: 1; }
  .guide-payoff-eyebrow {
    align-items: center;
    color: rgb(255 255 255 / 75%);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: 0.22em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }
  .guide-payoff-eyebrow-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgb(241 93 34 / 24%);
    display: inline-block;
    height: 8px;
    width: 8px;
  }
  .guide-payoff-title {
    color: white;
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 3.5vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.022em;
    line-height: 1.1;
    margin: 0 0 20px;
    max-width: 640px;
  }
  .guide-payoff-body {
    color: rgb(255 255 255 / 88%);
    font-family: var(--font-serif);
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 18px;
    max-width: 640px;
  }
  /* Last body paragraph pushes a bit more against the actions block
     so the CTAs have room to breathe; intra-paragraph rhythm stays
     tight. */
  .guide-payoff-body:last-of-type {
    margin-bottom: 30px;
  }
  .guide-payoff-body strong {
    color: var(--heritage-orange);
    font-weight: 600;
  }
  .guide-payoff-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 22px;
  }
  .guide-payoff-cta {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: -0.006em;
    padding: 14px 24px;
    text-decoration: none;
    transition: transform 200ms, box-shadow 200ms, background-color 200ms;
  }
  .guide-payoff-cta-primary {
    background: var(--heritage-orange);
    box-shadow: 0 12px 28px -14px rgb(241 93 34 / 80%);
    color: white;
  }
  .guide-payoff-cta-primary:hover {
    background: #e05517;
    box-shadow: 0 16px 32px -12px rgb(241 93 34 / 90%);
    transform: translateY(-2px);
  }
  .guide-payoff-cta-primary svg {
    transition: transform 200ms;
  }
  .guide-payoff-cta-primary:hover svg { transform: translateX(3px); }
  .guide-payoff-cta-secondary {
    background: rgb(255 255 255 / 10%);
    border: 1px solid rgb(255 255 255 / 18%);
    color: white;
  }
  .guide-payoff-cta-secondary:hover {
    background: rgb(255 255 255 / 16%);
    border-color: rgb(255 255 255 / 30%);
    transform: translateY(-2px);
  }
  .guide-payoff-cta-secondary svg {
    transition: transform 200ms;
  }
  .guide-payoff-cta-secondary:hover svg { transform: translateX(-3px); }
  .guide-payoff-loopback {
    border-top: 1px solid rgb(255 255 255 / 14%);
    color: rgb(255 255 255 / 70%);
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.55;
    margin: 22px 0 0;
    max-width: 620px;
    padding-top: 18px;
  }
  /* "let me know" link inside the loopback — kept subtle (underline,
     same italic serif) so it reads as a sentence continuation, not a
     second CTA competing with the two buttons above. Hover lights it
     to Heritage Orange. */
  .guide-payoff-loopback-link {
    color: white;
    font-style: italic;
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: rgb(255 255 255 / 40%);
    text-underline-offset: 3px;
    transition: color 180ms, text-decoration-color 180ms;
  }
  .guide-payoff-loopback-link:hover {
    color: var(--heritage-orange);
    text-decoration-color: var(--heritage-orange);
  }

  /* ==========================================================
     Prev/next chapter nav (enhanced from the label-only variant).

     Each card now earns the click by previewing the adjacent chapter:
       - eyebrow = "chapter N · previous/next"
       - title = chapter title
       - teaser = one-sentence pull from adjacent pillar's frontmatter
     Teaser sentence is the difference between "there's a next chapter"
     and "here's why you want it." On the final pillar the right card
     is suppressed since the payoff card above replaces it and the prev
     card becomes full-width.
  ========================================================== */
  .guide-nav {
    border-top: 1px solid var(--hairline);
    display: flex;
    gap: 14px;
    margin-top: 48px;
    padding-top: 32px;
  }
  .guide-nav[data-final='true'] { border-top: none; padding-top: 24px; }
  .guide-nav[data-final='true'] .guide-nav-btn { flex: 1; }
  .guide-nav-btn {
    align-items: flex-start;
    background: white;
    border: 1px solid rgb(44 62 80 / 8%);
    border-radius: 20px;
    display: flex;
    flex: 1;
    gap: 14px;
    min-width: 0;
    padding: 20px 22px;
    text-decoration: none;
    transition:
      border-color 220ms,
      box-shadow 220ms,
      transform 220ms;
  }
  .guide-nav-btn > .guide-nav-text {
    flex: 1;
    min-width: 0;
  }
  .guide-nav-btn:hover {
    border-color: rgb(241 93 34 / 28%);
    box-shadow: 0 12px 28px -16px rgb(241 93 34 / 20%);
    transform: translateY(-2px);
  }
  .guide-nav-btn-right {
    justify-content: flex-end;
    text-align: right;
  }
  .guide-nav-icon {
    color: rgb(44 62 80 / 30%);
    flex-shrink: 0;
    margin-top: 4px;
    transition: color 220ms, transform 220ms;
  }
  .guide-nav-btn:hover .guide-nav-icon {
    color: var(--heritage-orange);
    transform: translateX(-3px);
  }
  .guide-nav-btn-right:hover .guide-nav-icon {
    transform: translateX(3px);
  }
  .guide-nav-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .guide-nav-label {
    color: var(--heritage-orange);
    font-family: var(--font-display);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    opacity: 0.9;
    text-transform: uppercase;
  }
  .guide-nav-title {
    -webkit-box-orient: vertical;
    color: var(--deep-slate);
    display: -webkit-box;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.012em;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    line-height: 1.25;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 200ms;
  }
  .guide-nav-btn:hover .guide-nav-title {
    color: var(--heritage-orange);
  }
  /* Teaser: the one-sentence reason to click, pulled from the adjacent
     pillar's frontmatter. Intentionally italic + serif so it reads like
     a book-margin annotation, not a nav label. */
  .guide-nav-teaser {
    color: rgb(44 62 80 / 65%);
    display: block;
