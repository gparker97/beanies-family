---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { isPublished, comparePillarOrder } from '~/utils/content';
import { SITE_URL } from '@beanies/brand/nav';
// Fraunces serif is used in the page title + pitch lines to carry the
// e-zine / library aesthetic into the landing page. Scoped import so
// the font only ships on this route.
import '@fontsource-variable/fraunces';

/**
 * Per-pillar visual treatment. The grid is four chapter-covers, each
 * with its own palette + background texture. The `slug` key matches
 * the guide frontmatter slug — adding a new pillar guide requires an
 * entry here OR it falls back to the neutral 'default' theme.
 *
 * `tint` maps to the heavy accent (chapter number, hover, title
 * gradient anchor). `wash` is the card's base fill. `accentOn` drives
 * the texture colour against that wash.
 */
type PillarTheme = {
  tint: string;
  wash: string;
  accentOn: string;
  glyph: string;
  texture: 'swirl' | 'grid' | 'ledger' | 'circuit';
};

const PILLAR_THEMES: Record<string, PillarTheme> = {
  'overwhelmed-family-planning': {
    tint: '#f15d22',
    wash: 'linear-gradient(140deg, #fff6ef 0%, #ffe9d6 100%)',
    accentOn: 'rgb(241 93 34 / 22%)',
    glyph: '🌀',
    texture: 'swirl',
  },
  'family-organization': {
    tint: '#3a82b3',
    wash: 'linear-gradient(140deg, #f1f8fd 0%, #dceaf6 100%)',
    accentOn: 'rgb(58 130 179 / 28%)',
    glyph: '🏠',
    texture: 'grid',
  },
  'family-finance-basics': {
    tint: '#c76a21',
    wash: 'linear-gradient(140deg, #fff5e8 0%, #f5e1c2 100%)',
    accentOn: 'rgb(199 106 33 / 32%)',
    glyph: '💰',
    texture: 'ledger',
  },
  'local-first-family-finance-planning-tools': {
    tint: '#2c3e50',
    wash: 'linear-gradient(140deg, #f2f4f7 0%, #dde3ec 100%)',
    accentOn: 'rgb(44 62 80 / 30%)',
    glyph: '🔒',
    texture: 'circuit',
  },
};

const DEFAULT_THEME: PillarTheme = {
  tint: '#2c3e50',
  wash: 'linear-gradient(140deg, #ffffff 0%, #eef1f5 100%)',
  accentOn: 'rgb(44 62 80 / 20%)',
  glyph: '📖',
  texture: 'grid',
};

const guides = [...(await getCollection('guides', isPublished))].sort(comparePillarOrder);

// Call render() per guide so we can surface each pillar's H2s as a
// "what's inside" bullet list on the card. Build-time only; no runtime
// cost. Word count comes from the raw markdown body — Astro doesn't
// expose that directly on the rendered Content.
const pillars = await Promise.all(
  guides.map(async (guide, i) => {
    const { headings } = await render(guide);
    const h2s = headings.filter((h) => h.depth === 2).map((h) => h.text);
    const wordCount = guide.body?.split(/\s+/).filter(Boolean).length ?? 0;
    const readingMinutes = Math.max(1, Math.round(wordCount / 220));
    const theme = PILLAR_THEMES[guide.data.slug] ?? DEFAULT_THEME;
    return {
      number: String(i + 1),
      slug: guide.data.slug,
      title: guide.data.title,
      excerpt: guide.data.excerpt,
      heroEmoji: guide.data.heroEmoji,
      tags: guide.data.tags,
      lastUpdated: guide.data.lastUpdated,
      publishedDate: guide.data.publishedDate,
      stationSubtitle: guide.data.stationSubtitle,
      h2s,
      readingMinutes,
      theme,
      href: `/guides/${guide.data.slug}`,
    };
  })
);

const totalReadingMinutes = pillars.reduce((sum, p) => sum + p.readingMinutes, 0);

const canonicalPath = '/guides';

/**
 * Library-level structured data. CollectionPage tells crawlers this is a
 * curated index; ItemList enumerates the pillars in reading order with
 * an explicit `position` (1..N) so AI retrieval can reconstruct the
 * intended sequence. Each entry is a LearningResource pointing at the
 * guide's canonical URL — the guide's own Article JSON-LD on the
 * detail page then fills in authorship, dates, keywords.
 */
const collectionSchema = {
  '@type': 'CollectionPage',
  '@id': `${SITE_URL}${canonicalPath}#library`,
  name: 'the family library',
  description:
    'four pillar guides on the building blocks of a calmer family life: overwhelm, organization, finance, and privacy-first tooling.',
  url: `${SITE_URL}${canonicalPath}`,
  inLanguage: 'en',
  isPartOf: { '@id': `${SITE_URL}#site` },
  hasPart: pillars.map((p) => ({
    '@type': 'LearningResource',
    '@id': `${SITE_URL}${p.href}#guide`,
    name: p.title,
    description: p.excerpt,
    url: `${SITE_URL}${p.href}`,
    learningResourceType: 'Guide',
    timeRequired: `PT${p.readingMinutes}M`,
    keywords: p.tags.join(', '),
    inLanguage: 'en',
  })),
};

const itemListSchema = {
  '@type': 'ItemList',
  '@id': `${SITE_URL}${canonicalPath}#itemlist`,
  name: 'the family library — reading order',
  numberOfItems: pillars.length,
  itemListOrder: 'ItemListOrderAscending',
  itemListElement: pillars.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}${p.href}`,
    name: p.title,
  })),
};
---

<BaseLayout
  title="the family library — beanies.family"
  description="four evergreen pillar guides on family life, in a deliberate reading order: overwhelm, organization, finance basics, and local-first tooling. honest, lived experience — not listicles."
  canonicalPath={canonicalPath}
  jsonLd={[collectionSchema, itemListSchema]}
>
  <main class="library">
    <!-- ============== HERO ============== -->
    <header class="library-hero">
      <div class="library-hero-wash" aria-hidden="true"></div>
      <img
        src="/brand/beanies_family_hugging_transparent_512x512.png"
        alt=""
        class="library-hero-mascot"
        width="220"
        height="220"
        aria-hidden="true"
      />
      <div class="library-hero-content">
        <p class="library-kicker">
          <span class="library-kicker-dot" aria-hidden="true"></span>
          a reading curriculum · in order
        </p>
        <h1 class="library-title">
          <span class="library-title-over">the family</span>
          <span class="library-title-under">library</span>
        </h1>
        <p class="library-pitch">
          how to go from feeling overwhelmed to feeling in control. four chapters
          to help you take control of your family and financial life.
          <em>designed to be read in order.</em>
        </p>
        <div class="library-stats">
          <span class="library-stat">
            <strong>{pillars.length}</strong> chapters
          </span>
          <span class="library-stat-dot" aria-hidden="true">·</span>
          <span class="library-stat">
            <strong>~{totalReadingMinutes}</strong> min total
          </span>
          <span class="library-stat-dot" aria-hidden="true">·</span>
          <span class="library-stat library-stat-italic">a lifetime to practice</span>
        </div>
      </div>
    </header>

    {/* ============== CURRICULUM ARC ==============
        Promoted from a secondary nav strip to the primary hero element.
        Each station shows number + title + station subtitle (the "what
        this chapter does for you" hook). Connector gradients flow from
        one pillar's tint to the next so the arc literally walks the
        reader through the palette. Previously this was a squished
        1-line-title strip; now it's a proper curriculum map. */}
    <nav class="library-arc" aria-label="the curriculum path" id="the-path">
      <div class="library-arc-frame">
        <p class="library-arc-label">
          <span class="library-arc-label-rule" aria-hidden="true"></span>
          <span>the path, chapter by chapter</span>
          <span class="library-arc-label-rule" aria-hidden="true"></span>
        </p>
        <ol class="library-arc-list">
          {pillars.map((p, i) => {
            const next = pillars[i + 1];
            const connectorStyle = next
              ? `background: linear-gradient(to right, ${p.theme.tint}, ${next.theme.tint});`
              : '';
            return (
              <li class="library-arc-item" style={`--tint: ${p.theme.tint}`}>
                <a href={`#pillar-${p.slug}`} class="library-arc-link">
                  <span class="library-arc-num" aria-hidden="true">{p.number}</span>
                  <span class="library-arc-body">
                    <span class="library-arc-text">{p.title}</span>
                    {p.stationSubtitle && (
                      <span class="library-arc-sub">{p.stationSubtitle}</span>
                    )}
                  </span>
                </a>
                {next && (
                  <span
                    class="library-arc-connector"
                    style={connectorStyle}
                    aria-hidden="true"
                  ></span>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    </nav>

    <!-- ============== PILLAR COVERS ============== -->
    <section class="library-pillars" aria-label="the pillar guides">
      {pillars.map((p, i) => (
        <article
          class={`pillar pillar--${p.theme.texture}`}
          id={`pillar-${p.slug}`}
          style={`--tint: ${p.theme.tint}; --wash: ${p.theme.wash}; --accent-on: ${p.theme.accentOn};`}
        >
          <div class="pillar-texture" aria-hidden="true">
            {p.theme.texture === 'swirl' && (
              <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                <g fill="none" stroke="currentColor" stroke-width="1.2">
                  <circle cx="200" cy="200" r="40" />
                  <circle cx="200" cy="200" r="80" />
                  <circle cx="200" cy="200" r="125" />
                  <circle cx="200" cy="200" r="175" />
                  <circle cx="200" cy="200" r="230" />
                  <path d="M 70 200 Q 140 90, 200 200 T 330 200" />
                  <path d="M 70 240 Q 140 130, 200 240 T 330 240" />
                </g>
              </svg>
            )}
            {p.theme.texture === 'grid' && (
              <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                <defs>
                  <pattern id={`grid-${p.slug}`} width="28" height="28" patternUnits="userSpaceOnUse">
                    <path d="M 28 0 L 0 0 0 28" fill="none" stroke="currentColor" stroke-width="1" />
                  </pattern>
                </defs>
                <rect width="100%" height="100%" fill={`url(#grid-${p.slug})`} />
                <rect x="60" y="60" width="120" height="90" fill="none" stroke="currentColor" stroke-width="1.5" />
                <rect x="200" y="160" width="140" height="110" fill="none" stroke="currentColor" stroke-width="1.5" />
              </svg>
            )}
            {p.theme.texture === 'ledger' && (
              <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                <g stroke="currentColor" stroke-width="0.9" fill="none">
                  {Array.from({ length: 22 }).map((_, j) => (
                    <line x1="0" y1={18 + j * 18} x2="400" y2={18 + j * 18} />
                  ))}
                  <line x1="70" y1="0" x2="70" y2="400" stroke-width="1.4" />
                  <line x1="330" y1="0" x2="330" y2="400" stroke-width="1.4" />
                </g>
              </svg>
            )}
            {p.theme.texture === 'circuit' && (
              <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                <g fill="none" stroke="currentColor" stroke-width="1.3">
                  <path d="M 40 80 H 160 V 160 H 280 V 60 H 360" />
                  <path d="M 20 220 H 120 V 320 H 260 V 260 H 380" />
                  <path d="M 80 360 V 260 H 200" />
                  <circle cx="160" cy="80" r="4" fill="currentColor" />
                  <circle cx="280" cy="160" r="4" fill="currentColor" />
                  <circle cx="120" cy="220" r="4" fill="currentColor" />
                  <circle cx="260" cy="320" r="4" fill="currentColor" />
                  <circle cx="200" cy="260" r="4" fill="currentColor" />
                </g>
              </svg>
            )}
          </div>

          <header class="pillar-head">
            <span class="pillar-chapter">chapter {p.number}</span>
            <span class="pillar-time">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              {p.readingMinutes} min
            </span>
            {i === 0 && <span class="pillar-badge">start here</span>}
          </header>

          <div class="pillar-glyph" aria-hidden="true">{p.heroEmoji ?? p.theme.glyph}</div>

          <h2 class="pillar-title">
            <a href={p.href}>{p.title}</a>
          </h2>

          <p class="pillar-pitch">{p.excerpt}</p>

          {p.h2s.length > 0 && (
            <div class="pillar-inside">
              <p class="pillar-inside-label">what's inside</p>
              <ul class="pillar-inside-list">
                {p.h2s.slice(0, 4).map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
              {p.h2s.length > 4 && (
                <p class="pillar-inside-more">+ {p.h2s.length - 4} more chapters</p>
              )}
            </div>
          )}

          {p.tags.length > 0 && (
            <ul class="pillar-tags" aria-label="tags">
              {p.tags.slice(0, 3).map((t) => (
                <li class="pillar-tag">{t}</li>
              ))}
            </ul>
          )}

          <a href={p.href} class="pillar-read">
            read chapter {p.number}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </a>
        </article>
      ))}
    </section>

    <!-- ============== FOOTER STRIP ============== -->
    <footer class="library-foot">
      <p class="library-foot-copy">
        the guides are written by <a href="/about/greg">greg</a> - a dad of three beanies, in the
        trenches of family logistics. for weekly notes on the beans and product,
        subscribe to <a href="/blog">the beanstalk</a>.
      </p>
    </footer>
  </main>
</BaseLayout>

<style>
  .library {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --sky-silk: #aed6f1;
    --cloud-white: #f8f9fa;
    --kraft: #f3ecd8;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', 'Fraunces', 'Source Serif 4', Georgia, serif;
    background: var(--cloud-white);
    background-image:
      radial-gradient(circle at 6% 14%, rgb(241 93 34 / 4%) 0%, transparent 42%),
      radial-gradient(circle at 94% 86%, rgb(174 214 241 / 7%) 0%, transparent 48%);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* ===== HERO ===== */
  .library-hero {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 1120px;
    padding: 120px 32px 60px;
    position: relative;
  }
  .library-hero-wash {
    background:
      radial-gradient(circle at 15% 20%, rgb(241 93 34 / 10%) 0%, transparent 40%),
      radial-gradient(circle at 85% 70%, rgb(230 126 34 / 8%) 0%, transparent 42%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  .library-hero-mascot {
    bottom: -20px;
    filter: drop-shadow(0 18px 36px rgb(44 62 80 / 14%));
    pointer-events: none;
    position: absolute;
    right: -30px;
    transform: rotate(7deg);
    width: 220px;
    z-index: 0;
  }
  .library-hero-content {
    max-width: 640px;
    position: relative;
    z-index: 1;
  }
  .library-kicker {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: 0.22em;
    margin: 0 0 24px;
    text-transform: uppercase;
  }
  .library-kicker-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgb(241 93 34 / 15%);
    display: inline-block;
    height: 8px;
    width: 8px;
  }
  .library-title {
    color: var(--deep-slate);
    display: block;
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    line-height: 0.92;
    margin: 0 0 24px;
  }
  .library-title-over {
    display: block;
    font-size: clamp(2rem, 4.2vw, 3rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    opacity: 0.78;
  }
  .library-title-under {
    color: var(--deep-slate);
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 7.5rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    margin-top: 2px;
    text-transform: lowercase;
  }
  .library-pitch {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    font-weight: 400;
    line-height: 1.55;
    margin: 0 0 28px;
    max-width: 560px;
  }
  .library-pitch em {
    color: var(--heritage-orange);
    font-style: italic;
    font-weight: 500;
  }
  .library-stats {
    align-items: center;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-display);
    font-size: 0.88rem;
    gap: 10px;
  }
  .library-stat strong {
    color: var(--deep-slate);
    font-weight: 700;
  }
  .library-stat-italic {
    font-family: var(--font-serif);
    font-style: italic;
  }
  .library-stat-dot {
    color: var(--heritage-orange);
    font-weight: 700;
    opacity: 0.55;
  }

  /* ===== CURRICULUM ARC =====
     Lifted from a thin secondary-nav strip into the primary "this is a
     journey" element. The arc now lives inside a framed container with
     a gently-warmed kraft wash so it reads as a front-of-book table of
     contents instead of a nav bar. Each station:
       - filled tint-colored number bubble (not just outlined)
       - chapter title in Outfit
       - Fraunces-italic subtitle that names the station's payoff
       - tint-to-tint gradient connector walking between pillars
     On mobile the row flips to a vertical timeline with the connector
     becoming a short vertical rule. */
  .library-arc {
    box-sizing: border-box;
    margin: 8px auto 0;
    max-width: 1120px;
    padding: 0 32px;
    position: relative;
  }
  .library-arc-frame {
    background:
      linear-gradient(180deg, rgb(248 249 250 / 0%) 0%, rgb(243 236 216 / 45%) 40%, rgb(243 236 216 / 60%) 100%),
      white;
    border: 1px solid var(--hairline);
    border-radius: 28px;
    box-shadow:
      0 1px 0 rgb(255 255 255 / 80%) inset,
      0 24px 48px -28px rgb(44 62 80 / 18%);
    box-sizing: border-box;
    padding: 40px 40px 44px;
    position: relative;
  }
  /* Tiny kraft-paper grain behind the frame contents, subtle enough to
     not compete with the station elements. */
  .library-arc-frame::before {
    background-image:
      radial-gradient(circle at 18% 22%, rgb(44 62 80 / 3%) 0%, transparent 28%),
      radial-gradient(circle at 82% 78%, rgb(241 93 34 / 3%) 0%, transparent 32%);
    border-radius: inherit;
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  .library-arc-label {
    align-items: center;
    color: var(--heritage-orange);
    display: flex;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    gap: 14px;
    justify-content: center;
    letter-spacing: 0.22em;
    margin: 0 0 32px;
    position: relative;
    text-transform: uppercase;
    z-index: 1;
  }
  .library-arc-label-rule {
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--heritage-orange) 35%, transparent),
      transparent
    );
    flex: 1;
    height: 1px;
    max-width: 120px;
  }
  .library-arc-list {
    align-items: flex-start;
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
  }
  /* Each item: the station link block on the left (number over body),
     then a gradient connector that fills the remaining space of the
     item's flex allotment and reaches toward the next item's bubble. */
  .library-arc-item {
    align-items: flex-start;
    display: flex;
    flex: 1 1 0;
    gap: 16px;
    min-width: 0;
  }
  .library-arc-item:last-child {
    flex: 0 0 auto;
  }
  .library-arc-link {
    align-items: center;
    color: var(--deep-slate);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    gap: 14px;
    min-width: 0;
    text-align: center;
    text-decoration: none;
    transition: transform 200ms ease;
    width: 180px;
  }
  .library-arc-link:hover { transform: translateY(-3px); }
  .library-arc-num {
    align-items: center;
    background: var(--tint, var(--heritage-orange));
    border-radius: 50%;
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--tint, var(--heritage-orange)) 14%, transparent),
      0 8px 18px -8px color-mix(in srgb, var(--tint, var(--heritage-orange)) 55%, transparent);
    color: white;
    display: inline-flex;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 800;
    height: 48px;
    justify-content: center;
    letter-spacing: -0.01em;
    position: relative;
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 220ms;
    width: 48px;
  }
  /* Subtle inner highlight so the number bubble reads as a button,
     not a flat disc. Kept inside the padding so it doesn't bleed. */
  .library-arc-num::after {
    background: linear-gradient(
      160deg,
      rgb(255 255 255 / 28%) 0%,
      transparent 50%
    );
    border-radius: inherit;
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  .library-arc-link:hover .library-arc-num {
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--tint, var(--heritage-orange)) 22%, transparent),
      0 12px 24px -8px color-mix(in srgb, var(--tint, var(--heritage-orange)) 65%, transparent);
    transform: scale(1.05);
  }
  .library-arc-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
    padding: 0 4px;
  }
  .library-arc-text {
    -webkit-box-orient: vertical;
    color: var(--deep-slate);
    display: -webkit-box;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.012em;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    line-height: 1.25;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 180ms;
    word-break: break-word;
  }
  .library-arc-link:hover .library-arc-text { color: var(--tint, var(--heritage-orange)); }
  .library-arc-sub {
    color: rgb(44 62 80 / 70%);
    display: block;
    font-family: var(--font-serif);
    font-feature-settings: 'ss01';
    font-size: 0.85rem;
