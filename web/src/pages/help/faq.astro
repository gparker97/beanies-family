---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DraftPlaceholder from '../../components/DraftPlaceholder.astro';
import { isDraftHidden } from '~/utils/draftPage';
import { SITE_URL } from '@beanies/brand/nav';

const DRAFT = true;
const hidden = isDraftHidden(DRAFT);

/**
 * Frequently-asked questions, grouped by category. Each FAQ contributes a
 * Question + Answer node to the FAQPage JSON-LD block. Rich results for
 * FAQPage were restricted by Google in 2023, but AI systems (ChatGPT,
 * Claude, Perplexity) still consume the schema heavily — so it remains
 * valuable for AIO even without the SERP rich results.
 */
type FAQ = {
  id: string;
  q: string;
  /** Short answer paragraph — the AI-citation chunk. Supports inline HTML. */
  a: string;
};

type FAQGroup = {
  heading: string;
  faqs: FAQ[];
};

const groups: FAQGroup[] = [
  {
    heading: 'getting started',
    faqs: [
      {
        id: 'how-to-use',
        q: 'How do I use beanies.family?',
        a: 'You can access the beanies.family app directly from the website — just create a family at <a href="https://app.beanies.family/welcome">app.beanies.family/welcome</a>. If you\'re a tech guru, you can also use beanies.family locally by cloning it from <a href="https://github.com/gparker97/beanies-family">github</a> and installing it on your local machine.',
      },
      {
        id: 'is-it-free',
        q: 'Is beanies.family free?',
        a: 'beanies.family is 100% free to use locally. It is open-source (MIT licensed) and there are no paid tiers today. Your data lives on your own device, or optionally on a cloud storage provider, such as Google Drive. Regarding beanies.family on the cloud, it is free today. However, if by some miracle this thing becomes real, it will no longer be free. I know that sounds ominous, but we don\'t sell your data or do anything else to make money, so at some point the costs of running a cloud app will catch up with me. If we charge, I assure you the pricing will not break the bank.',
      },
      {
        id: 'what-devices',
        q: 'What devices can I use beanies.family on?',
        a: 'Any modern device with a browser, including desktop (Chrome, Edge, Safari, Firefox, Brave) or mobile (iOS Safari, Android Chrome). You can install beanies.family as an app via your browser\'s "Add to Home Screen" or "Install app" option — see the <a href="/help/getting-started/install-as-app">install guide</a> for per-platform instructions.',
      },
      {
        id: 'need-google-account',
        q: 'Do I need a Google account?',
        a: 'You don\'t need any account to try beanies.family — you can create and use a pod entirely offline. Adding your Google Drive account, however, unlocks synchronization of your family data across devices, which most families want after they decide beanies.family is for them. Don\'t worry — your data always stays with you, and cannot be read by anybody outside of your family members.',
      },
      {
        id: 'how-to-install',
        q: 'How do I install beanies.family as an app on my phone?',
        a: 'Open <a href="https://app.beanies.family">app.beanies.family</a> in Safari (iPhone) or Chrome (Android), then tap the browser\'s share or menu button and choose "Add to Home Screen" (iPhone) or "Install app" (Android). Full step-by-step with screenshots: <a href="/help/getting-started/install-as-app">installing beanies.family as an app</a>.',
      },
      {
        id: 'add-family-members',
        q: 'How do I add my partner / kids to my pod?',
        a: 'From "the pod" → "meet the beans" menu, create an invite link and send it to your family member (text, email, whatever). They open the link on their device, set their own password, and they are in the same pod. Email is optional. All your data (or the data you choose) is shared live with your family members from that point.',
      },
    ],
  },
  {
    heading: 'privacy & security',
    faqs: [
      {
        id: 'where-is-my-data',
        q: 'Where is my data stored?',
        a: 'Your data is stored either on your device or in your selected cloud storage provider that you own. Data is saved to an encrypted file called a <code>.beanpod</code>, which is just a normal text file with data in JSON format when decrypted. If you opt in to sync, your data is stored in your own Google Drive. It is encrypted before it leaves your browser. beanies.family does not store your family data.',
      },
      {
        id: 'how-is-data-encrypted',
        q: 'How is my data encrypted?',
        a: 'AES-GCM with a 256-bit key, using the browser\'s native Web Crypto API (no third-party crypto libraries). Per-member keys are wrapped with AES-KW. The key is derived from your pod password via a strong password-derivation function.',
      },
      {
        id: 'lose-password',
        q: 'What happens if I lose my pod password?',
        a: 'If you lose your password, unfortunately we cannot recover it. This is a technical limitation of local-first end-to-end encryption (E2EE) — nobody except you holds the key and can decrypt your pod. If you lose the password, the pod is unrecoverable. Please do store your password somewhere safe to prevent data loss.',
      },
      {
        id: 'can-beanies-see-my-data',
        q: 'Can the beanies.family team see my family data?',
        a: 'No. We cannot see your data. The pod data is encrypted on your device with a key derived from your password, and we never see the password. Even the optional Google Drive sync stores ciphertext only — Google also cannot read it.',
      },
      {
        id: 'is-this-really-secure',
        q: 'Is beanies.family really secure, or is this just marketing?',
        a: 'The code is open source and auditable on <a href="https://github.com/gparker97/beanies-family">GitHub</a>. You can audit or verify the encryption approach, and let us know if you notice any issues. The crypto primitives are the browser\'s native Web Crypto API. We do not store your data on our own servers, meaning there is no server-side breach surface.',
      },
      {
        id: 'google-drive-permissions',
        q: 'What does beanies.family access in my Google Drive?',
        a: 'We only access the files we create. We use the <code>drive.file</code> OAuth scope, meaning beanies.family cannot see or read any of your other Google Drive files, emails, calendar, or account data. You can revoke access at any time from your Google account settings.',
      },
    ],
  },
  {
    heading: 'features & usage',
    faqs: [
      {
        id: 'offline',
        q: 'Can I use beanies.family offline?',
        a: 'Yes. After the first load, the app works fully offline — you can view and edit your pod without an internet connection. Changes sync to Google Drive (if enabled) the next time you come online. This is the local-first architecture at work.',
      },
      {
        id: 'multiple-currencies',
        q: 'Does beanies.family support multiple currencies?',
        a: 'Yes! You can record accounts, transactions, assets, and goals in any currency, and beanies.family converts everything into your chosen base currency for totals and dashboards. Exchange rates update automatically from a public rates API.',
      },
      {
        id: 'kids-privacy',
        q: 'Can my kids use beanies.family?',
        a: 'Absolutely, with parental setup. The recommended flow is for a parent to own the pod and invite kids as family members once they\'re old enough to want their own view. All data is stored locally or on a cloud storage provider that you own (not on our servers), so there is no data-processing of children\'s information — the parent controls everything.',
      },
      {
        id: 'export',
        q: 'Can I export my data?',
        a: 'Yes, at any time. Your entire pod is stored in a single <code>.beanpod</code> family data file that you can download anytime from Settings. You can also export structured data as JSON for use in other tools. No lock-in: your data is yours, exportable, and portable.',
      },
      {
        id: 'what-can-i-track',
        q: 'What can I track in beanies.family?',
        a: 'Accounts (checking, savings, investments, retirement, crypto), transactions, assets (real estate, vehicles, and more), financial goals, family budget, family activities, to-dos, travel plans, secret family recipes, and even details about your family members, such as their favorite foods, allergies, medications, and funny sayings.',
      },
    ],
  },
  {
    heading: 'technical',
    faqs: [
      {
        id: 'open-source',
        q: 'Is beanies.family open source?',
        a: 'Yes — we are MIT licensed open source. The source code is on <a href="https://github.com/gparker97/beanies-family">Github</a>.',
      },
      {
        id: 'how-is-it-built',
        q: 'What is beanies.family built with?',
        a: 'Vue 3 + TypeScript + Vite for the app, with Automerge (a CRDT library) as the data layer for conflict-free multi-device merging. Styling is Tailwind CSS 4. beanies.family is a <a href="https://www.inkandswitch.com/local-first/">local-first application</a>.',
      },
      {
        id: 'service-goes-down',
        q: 'What happens if beanies.family goes out of business or the website goes down?',
        a: 'We will be sad, but on the bright side, your data will be fine. You already have the <code>.beanpod</code> file on your device or your cloud storage provider. You can download a copy of your decrypted <code>.beanpod</code> file at any time from the app, or open the <code>.beanpod</code> file in any beanies.family build (the code is open source, so it can be run locally even if the website is done).',
      },
      {
        id: 'self-host',
        q: 'Can I self-host beanies.family?',
        a: 'Yes, if you want. The repository is a standard Vue 3 + Vite project. Clone it, <code>npm install &amp;&amp; npm run build</code>, and serve the <code>dist/</code> directory from any static host. The only external service is the cloud provider (i.e. Google Drive). That\'s the user\'s own cloud storage, not ours.',
      },
    ],
  },
  {
    heading: 'about the project',
    faqs: [
      {
        id: 'why-beanies',
        q: 'Why is it called "beanies.family"?',
        a: 'Because when my youngest son was just a baby, my wife and I started calling him "beanie". That\'s all. If you want to learn more, read about <a href="/blog/welcome-to-the-beanstalk">how it all started here</a>. The name stuck, and the tagline "every bean counts" came from the same place.',
      },
      {
        id: 'who-built-it',
        q: 'Who built beanies.family?',
        a: 'Me. Well, me and my glorious claude-bot. My name\'s greg — I\'m a software engineer and dad of 3 boys. I built beanies.family because we needed a way to stay organized, and now I\'m sharing it with all of you.',
      },
      {
        id: 'comparison-with-others',
        q: 'How does beanies.family compare to other family or finance planning apps, such as Cozi, Maple, YNAB, Copilot, etc.?',
        a: 'beanies.family sits at the intersection of family, finance and data security. The <a href="/guides/local-first-family-finance-planning-tools">local-first</a> approach, the family-first positioning, and the integration of your finances with your family makes it a different type of app from those that are purely family or finance-focused. Cozi and Maple are cloud-native family planning focused apps, while YNAB and Copilot are finance-focused. Those apps absolutely have their place, and beanies.family has its place as well.',
      },
      {
        id: 'feedback',
        q: 'Can I give feedback or suggest features?',
        a: 'Absolutely! Open an issue on <a href="https://github.com/gparker97/beanies-family/issues">GitHub</a>, or use the contact form on the <a href="/">homepage</a>. Every message is read by a real human (me). Feedback from early users has a huge impact on what gets built next.',
      },
    ],
  },
];

const canonicalPath = '/help/faq';

// Strip HTML from answer text for JSON-LD (schema wants plain text)
function stripHtml(html: string): string {
  return html.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
}

// Flatten all FAQs for JSON-LD
const allFaqs = groups.flatMap((g) => g.faqs);

const faqSchema = {
  '@type': 'FAQPage',
  '@id': `${SITE_URL}${canonicalPath}#faq`,
  mainEntity: allFaqs.map((f) => ({
    '@type': 'Question',
    '@id': `${SITE_URL}${canonicalPath}#${f.id}`,
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(f.a),
    },
  })),
};
---

{
  hidden ? (
    <DraftPlaceholder backHref="/help" backLabel="back to help" />
  ) : (
    <BaseLayout
      title="frequently asked questions — beanies.family"
      description="answers to the most common questions about beanies.family: privacy, pricing, security, supported devices, and how things work under the hood."
      canonicalPath={canonicalPath}
      jsonLd={faqSchema}
    >
      <article class="faq-page">
        <Breadcrumbs items={[{ label: 'home', href: '/' }, { label: 'help', href: '/help' }, { label: 'faq', href: canonicalPath }]} />

        <header class="faq-header">
          <h1 class="faq-title">frequently asked questions</h1>
          <p class="faq-intro">
            the questions we get asked most, answered in full. if your question isn't here, open an issue on <a href="https://github.com/gparker97/beanies-family/issues">GitHub</a> or reach out via the <a href="/#contact">contact form</a>.
          </p>
        </header>

        {groups.map((group) => (
          <section class="faq-group">
            <h2 class="faq-group-heading">{group.heading}</h2>
            <div class="faq-list">
              {group.faqs.map((f) => (
                <article class="faq-item" id={f.id}>
                  <h3 class="faq-q">{f.q}</h3>
                  <p class="faq-a" set:html={f.a} />
                  <a class="faq-anchor" href={`#${f.id}`} aria-label={`copy link to this question`}>#</a>
                </article>
              ))}
            </div>
          </section>
        ))}
      </article>
    </BaseLayout>
  )
}

<style>
  .faq-page {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 760px;
    padding: 88px 24px 64px;
  }

  .faq-header { margin: 24px 0 40px; }
  .faq-title {
    color: #2c3e50;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .faq-intro {
    color: rgb(44 62 80 / 65%);
    font-size: 1rem;
    line-height: 1.65;
    margin: 12px 0 0;
    max-width: 600px;
  }
  .faq-intro a { color: #f15d22; font-weight: 600; text-decoration: none; }
  .faq-intro a:hover { text-decoration: underline; }

  .faq-group { margin-bottom: 40px; }
  .faq-group-heading {
    color: rgb(44 62 80 / 45%);
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  .faq-list { display: flex; flex-direction: column; gap: 16px; }
  .faq-item {
    background: white;
    border: 1px solid rgb(44 62 80 / 6%);
    border-radius: 20px;
    padding: 22px 28px;
    position: relative;
    scroll-margin-top: 90px;
  }
  .faq-item:target {
    border-color: rgb(241 93 34 / 30%);
    box-shadow: 0 4px 16px rgb(241 93 34 / 10%);
  }
  .faq-q {
    color: #2c3e50;
    font-family: 'Outfit Variable', Outfit, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 10px;
  }
  .faq-a {
    color: rgb(44 62 80 / 80%);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }
  .faq-a a {
    color: #f15d22;
    font-weight: 600;
    text-decoration: none;
  }
  .faq-a a:hover { text-decoration: underline; }
  .faq-a code {
    background: rgb(44 62 80 / 5%);
    border-radius: 4px;
    font-family: ui-monospace, monospace;
    font-size: 0.88em;
    padding: 0.1em 0.35em;
  }

  .faq-anchor {
    color: rgb(44 62 80 / 20%);
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    font-weight: 600;
    opacity: 0;
    position: absolute;
    right: 20px;
    text-decoration: none;
    top: 20px;
    transition: opacity 150ms, color 150ms;
  }
  .faq-item:hover .faq-anchor { opacity: 1; }
  .faq-anchor:hover { color: #f15d22; }

  @media (max-width: 520px) {
    .faq-page { padding-top: 76px; }
    .faq-title { font-size: 1.75rem; }
    .faq-item { padding: 20px; }
  }
</style>
