---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DraftPlaceholder from '../../components/DraftPlaceholder.astro';
import { isDraftHidden } from '~/utils/draftPage';
import { SITE_URL } from '@beanies/brand/nav';
// Fraunces carries the italic display flourish in the title + kicker. Scoped
// import so the font only ships on this route.
import '@fontsource-variable/fraunces';

const DRAFT = true;
const hidden = isDraftHidden(DRAFT);

/**
 * Frequently-asked questions, grouped by category. Each FAQ contributes a
 * Question + Answer node to the FAQPage JSON-LD block. Rich results for
 * FAQPage were restricted by Google in 2023, but AI systems (ChatGPT,
 * Claude, Perplexity) still consume the schema heavily — so it remains
 * valuable for AIO even without the SERP rich results.
 */
type FAQ = {
  id: string;
  q: string;
  /** Answer — the AI-citation chunk. Supports inline HTML and multi-paragraph (<p>...</p><p>...</p>). */
  a: string;
};

type FAQGroup = {
  heading: string;
  faqs: FAQ[];
};

const groups: FAQGroup[] = [
  {
    heading: 'getting started',
    faqs: [
      {
        id: 'how-to-use',
        q: 'How do I use beanies.family?',
        a: '<p>You can access the beanies.family app directly from the website — just create a family at <a href="https://app.beanies.family/welcome">app.beanies.family/welcome</a>.</p><p>If you\'re a tech guru, you can also use beanies.family locally by cloning it from <a href="https://github.com/gparker97/beanies-family">github</a> and installing it on your local machine.</p>',
      },
      {
        id: 'is-it-free',
        q: 'Is beanies.family free?',
        a: '<p>beanies.family is 100% free to use locally. It is open-source (MIT licensed) and there are no paid tiers today. Your data lives on your own device, or optionally on a cloud storage provider, such as Google Drive.</p><p>Regarding beanies.family on the cloud, it is free today. However, if by some miracle this thing becomes real, it will no longer be free. I know that sounds ominous, but we don\'t sell your data or do anything else to make money, so at some point the costs of running a cloud app will catch up with me. If we charge, I assure you the pricing will not break the bank.</p>',
      },
      {
        id: 'what-devices',
        q: 'What devices can I use beanies.family on?',
        a: 'Any modern device with a browser, including desktop (Chrome, Edge, Safari, Firefox, Brave) or mobile (iOS Safari, Android Chrome). You can install beanies.family as an app via your browser\'s "Add to Home Screen" or "Install app" option — see the <a href="/help/getting-started/install-as-app">install guide</a> for per-platform instructions.',
      },
      {
        id: 'need-google-account',
        q: 'Do I need a Google account?',
        a: 'You don\'t need any account to try beanies.family — you can create and use a pod entirely offline. Adding your Google Drive account, however, unlocks synchronization of your family data across devices, which most families want after they decide beanies.family is for them. Don\'t worry — your data always stays with you, and cannot be read by anybody outside of your family members.',
      },
      {
        id: 'how-to-install',
        q: 'How do I install beanies.family as an app on my phone?',
        a: 'Open <a href="https://app.beanies.family">app.beanies.family</a> in Safari (iPhone) or Chrome (Android), then tap the browser\'s share or menu button and choose "Add to Home Screen" (iPhone) or "Install app" (Android). Full step-by-step with screenshots: <a href="/help/getting-started/install-as-app">installing beanies.family as an app</a>.',
      },
      {
        id: 'add-family-members',
        q: 'How do I add my partner / kids to my pod?',
        a: 'From "the pod" → "meet the beans" menu, create an invite link and send it to your family member (text, email, whatever). They open the link on their device, set their own password, and they are in the same pod. Email is optional. All your data (or the data you choose) is shared live with your family members from that point.',
      },
    ],
  },
  {
    heading: 'privacy & security',
    faqs: [
      {
        id: 'where-is-my-data',
        q: 'Where is my data stored?',
        a: '<p>Your data is stored either on your device or in your selected cloud storage provider that you own. Data is saved to an encrypted file called a <code>.beanpod</code>, which is just a normal text file with data in JSON format when decrypted.</p><p>If you opt in to sync, your data is stored in your own Google Drive. It is encrypted before it leaves your browser. beanies.family does not store your family data.</p>',
      },
      {
        id: 'how-is-data-encrypted',
        q: 'How is my data encrypted?',
        a: 'AES-GCM with a 256-bit key, using the browser\'s native Web Crypto API (no third-party crypto libraries). Per-member keys are wrapped with AES-KW. The key is derived from your pod password via a strong password-derivation function.',
      },
      {
        id: 'lose-password',
        q: 'What happens if I lose my pod password?',
        a: '<p>If you lose your password, unfortunately we cannot recover it. This is a technical limitation of local-first end-to-end encryption (E2EE) — nobody except you holds the key and can decrypt your pod.</p><p>If you lose the password, the pod is unrecoverable. Please do store your password somewhere safe to prevent data loss.</p>',
      },
      {
        id: 'can-beanies-see-my-data',
        q: 'Can the beanies.family team see my family data?',
        a: 'No. We cannot see your data. The pod data is encrypted on your device with a key derived from your password, and we never see the password. Even the optional Google Drive sync stores ciphertext only — Google also cannot read it.',
      },
      {
        id: 'is-this-really-secure',
        q: 'Is beanies.family really secure, or is this just marketing?',
        a: 'The code is open source and auditable on <a href="https://github.com/gparker97/beanies-family">GitHub</a>. You can audit or verify the encryption approach, and let us know if you notice any issues. The crypto primitives are the browser\'s native Web Crypto API. We do not store your data on our own servers, meaning there is no server-side breach surface.',
      },
      {
        id: 'google-drive-permissions',
        q: 'What does beanies.family access in my Google Drive?',
        a: 'We only access the files we create. We use the <code>drive.file</code> OAuth scope, meaning beanies.family cannot see or read any of your other Google Drive files, emails, calendar, or account data. You can revoke access at any time from your Google account settings.',
      },
    ],
  },
  {
    heading: 'features & usage',
    faqs: [
      {
        id: 'offline',
        q: 'Can I use beanies.family offline?',
        a: 'Yes. After the first load, the app works fully offline — you can view and edit your pod without an internet connection. Changes sync to Google Drive (if enabled) the next time you come online. This is the <strong>local-first</strong> architecture at work.',
      },
      {
        id: 'multiple-currencies',
        q: 'Does beanies.family support multiple currencies?',
        a: 'Yes! You can record accounts, transactions, assets, and goals in any currency, and beanies.family converts everything into your chosen base currency for totals and dashboards. Exchange rates update automatically from a public rates API.',
      },
      {
        id: 'kids-privacy',
        q: 'Can my kids use beanies.family?',
        a: 'Absolutely, with parental setup. The recommended flow is for a parent to own the pod and invite kids as family members once they\'re old enough to want their own view. All data is stored locally or on a cloud storage provider that you own (not on our servers), so there is no data-processing of children\'s information — the parent controls everything.',
      },
      {
        id: 'export',
        q: 'Can I export my data?',
        a: 'Yes, at any time. Your entire pod is stored in a single <code>.beanpod</code> family data file that you can download anytime from Settings. You can also export structured data as JSON for use in other tools. No lock-in: your data is yours, exportable, and portable.',
      },
      {
        id: 'what-can-i-track',
        q: 'What can I track in beanies.family?',
        a: 'Accounts (checking, savings, investments, retirement, crypto), transactions, assets (real estate, vehicles, and more), financial goals, family budget, family activities, to-dos, travel plans, secret family recipes, and even details about your family members, such as their favorite foods, allergies, medications, and funny sayings.',
      },
    ],
  },
  {
    heading: 'technical',
    faqs: [
      {
        id: 'open-source',
        q: 'Is beanies.family open source?',
        a: 'Yes — we are MIT licensed open source. The source code is on <a href="https://github.com/gparker97/beanies-family">Github</a>.',
      },
      {
        id: 'how-is-it-built',
        q: 'What is beanies.family built with?',
        a: 'Vue 3 + TypeScript + Vite for the app, with Automerge (a CRDT library) as the data layer for conflict-free multi-device merging. Styling is Tailwind CSS 4. beanies.family is a <a href="https://www.inkandswitch.com/local-first/">local-first application</a>.',
      },
      {
        id: 'service-goes-down',
        q: 'What happens if beanies.family goes out of business or the website goes down?',
        a: 'We will be sad, but on the bright side, your data will be fine. You already have the <code>.beanpod</code> file on your device or your cloud storage provider. You can download a copy of your decrypted <code>.beanpod</code> file at any time from the app, or open the <code>.beanpod</code> file in any beanies.family build (the code is open source, so it can be run locally even if the website is done).',
      },
      {
        id: 'self-host',
        q: 'Can I self-host beanies.family?',
        a: 'Yes, if you want. The repository is a standard Vue 3 + Vite project. Clone it, <code>npm install &amp;&amp; npm run build</code>, and serve the <code>dist/</code> directory from any static host. The only external service is the cloud provider (i.e. Google Drive). That\'s the user\'s own cloud storage, not ours.',
      },
    ],
  },
  {
    heading: 'about the project',
    faqs: [
      {
        id: 'why-beanies',
        q: 'Why is it called "beanies.family"?',
        a: '<p>Because when my youngest son was just a baby, my wife and I started calling him "beanie". That\'s all. If you want to learn more, read about <a href="/blog/welcome-to-the-beanstalk">how it all started here</a>.</p><p>The name stuck, and the tagline "every bean counts" came from the same place.</p>',
      },
      {
        id: 'who-built-it',
        q: 'Who built beanies.family?',
        a: '<p>Me. Well, me and my glorious <a href="https://claude.ai/">claude-bot</a>.</p><p>My name\'s greg — I\'m a software engineer and dad of 3 boys. I built beanies.family because we needed a way to stay organized, and now I\'m sharing it with all of you.</p>',
      },
      {
        id: 'comparison-with-others',
        q: 'How does beanies.family compare to other family or finance planning apps, such as Cozi, Maple, YNAB, Copilot, etc.?',
        a: '<p>beanies.family sits at the intersection of family, finance and data security. The <a href="/guides/local-first-family-finance-planning-tools"><strong>local-first</strong></a> approach, the family-first positioning, and the integration of your finances with your family makes it a different type of app from those that are purely family or finance-focused.</p><p>Cozi and Maple are cloud-native family planning focused apps, while YNAB and Copilot are finance-focused. Those apps absolutely have their place, and beanies.family has its place as well.</p>',
      },
      {
        id: 'feedback',
        q: 'Can I give feedback or suggest features?',
        a: 'Absolutely! Open an issue on <a href="https://github.com/gparker97/beanies-family/issues">GitHub</a>, or use the contact form on the <a href="/">homepage</a>. Every message is read by a real human (me). Feedback from early users has a huge impact on what gets built next.',
      },
    ],
  },
];

const canonicalPath = '/help/faq';

// Strip HTML from answer text for JSON-LD (schema wants plain text)
function stripHtml(html: string): string {
  return html.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
}

// Flatten all FAQs for JSON-LD
const allFaqs = groups.flatMap((g) => g.faqs);

/**
 * Per-group visual treatment. Each category gets its own tint for the
 * side-stripe + category header in the sidebar/section. Derived in
 * insertion order so new categories appear with a neutral tint until
 * added here.
 */
const GROUP_TINTS: Record<string, string> = {
  'getting started': '#f15d22',
  'privacy & security': '#2c3e50',
  'features & usage': '#3a82b3',
  'technical': '#c76a21',
  'about the project': '#8e6fb8',
};
const DEFAULT_TINT = '#2c3e50';

// Build the sidebar + section data. Each group gets a slug so the URL
// can deep-link to it (#getting-started), and we pre-compute the count
// so the sidebar chip can show "6 questions" without recomputing.
const sections = groups.map((g) => {
  const slug = g.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  return {
    slug,
    heading: g.heading,
    count: g.faqs.length,
    tint: GROUP_TINTS[g.heading] ?? DEFAULT_TINT,
    faqs: g.faqs,
  };
});

const totalCount = allFaqs.length;

const faqSchema = {
  '@type': 'FAQPage',
  '@id': `${SITE_URL}${canonicalPath}#faq`,
  mainEntity: allFaqs.map((f) => ({
    '@type': 'Question',
    '@id': `${SITE_URL}${canonicalPath}#${f.id}`,
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(f.a),
    },
  })),
};
---

{
  hidden ? (
    <DraftPlaceholder backHref="/help" backLabel="back to help" />
  ) : (
    <BaseLayout
      title="frequently asked questions — beanies.family"
      description="answers to the most common questions about beanies.family: privacy, pricing, security, supported devices, and how things work under the hood."
      canonicalPath={canonicalPath}
      jsonLd={faqSchema}
    >
      <article class="faq-page">
        <div class="faq-atmo" aria-hidden="true"></div>
        <img
          src="/brand/beanies_open_eyes_transparent_512x512.png"
          alt=""
          class="faq-mascot"
          width="200"
          height="200"
          aria-hidden="true"
        />

        <div class="faq-shell">
          <header class="faq-hero">
            <Breadcrumbs items={[{ label: 'home', href: '/' }, { label: 'help', href: '/help' }, { label: 'faq', href: canonicalPath }]} />

            <p class="faq-kicker">
              <span class="faq-kicker-dot" aria-hidden="true"></span>
              frequently asked · {totalCount} answers
            </p>
            <h1 class="faq-title">
              <span class="faq-title-over">questions,</span>
              <span class="faq-title-under">answered</span>
            </h1>
            <p class="faq-intro">
              the questions we get asked most, answered in full. filter, jump by
              category, or scroll it all. if your question isn&rsquo;t here, open an
              issue on <a href="https://github.com/gparker97/beanies-family/issues">GitHub</a>
              or reach out via the <a href="/#contact">contact form</a>.
            </p>
          </header>

          <div class="faq-layout">
            <!-- Sticky category sidebar on desktop; collapses to a horizontal
                 chip strip on mobile. Scroll-spy highlights the current
                 section as the reader passes through it. -->
            <aside class="faq-sidebar" aria-label="categories">
              <p class="faq-sidebar-label">categories</p>
              <ol class="faq-sidebar-list">
                {sections.map((s) => (
                  <li class="faq-sidebar-item" style={`--tint: ${s.tint}`}>
                    <a href={`#${s.slug}`} data-category-link={s.slug}>
                      <span class="faq-sidebar-name">{s.heading}</span>
                      <span class="faq-sidebar-count">{s.count}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </aside>

            <div class="faq-main">
              <!-- Client-side filter. DOM stays fully crawlable; the filter
                   just sets [hidden] on non-matching <article>s and category
                   sections that end up with zero matches. Empty-state panel
                   fills in if every question is filtered out. -->
              <div class="faq-filter">
                <svg
                  class="faq-filter-icon"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  aria-hidden="true"
                >
                  <circle cx="11" cy="11" r="7" />
                  <line x1="17" y1="17" x2="21" y2="21" />
                </svg>
                <input
                  type="search"
                  class="faq-filter-input"
                  id="faq-filter"
                  placeholder="filter questions…"
                  autocomplete="off"
                  aria-label="filter questions"
                />
                <button
                  type="button"
                  class="faq-filter-clear"
                  id="faq-filter-clear"
                  aria-label="clear filter"
                  hidden
                >×</button>
                <span class="faq-filter-count" id="faq-filter-count" aria-live="polite">
                  {totalCount} of {totalCount}
                </span>
              </div>

              {sections.map((s) => (
                <section
                  class="faq-group"
                  id={s.slug}
                  data-category-section={s.slug}
                  style={`--tint: ${s.tint}`}
                >
                  <header class="faq-group-head">
                    <span class="faq-group-stripe" aria-hidden="true"></span>
                    <h2 class="faq-group-heading">{s.heading}</h2>
                    <span class="faq-group-count">{s.count} {s.count === 1 ? 'question' : 'questions'}</span>
                  </header>
                  <div class="faq-list">
                    {s.faqs.map((f, i) => (
                      <article class="faq-item" id={f.id} data-faq-item>
                        <span class="faq-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                        <h3 class="faq-q">{f.q}</h3>
                        <div class="faq-a" set:html={f.a} />
                        <a class="faq-anchor" href={`#${f.id}`} aria-label={`copy link to this question`}>#</a>
                      </article>
                    ))}
                  </div>
                </section>
              ))}

              <div class="faq-empty" id="faq-empty" hidden>
                <p class="faq-empty-title">no questions match that filter.</p>
                <p class="faq-empty-hint">
                  try a shorter word, or clear the filter. if it&rsquo;s a real gap,
                  <a href="https://github.com/gparker97/beanies-family/issues">open an issue</a>
                  and we&rsquo;ll add it.
                </p>
              </div>

              <footer class="faq-foot">
                <p class="faq-foot-title">didn&rsquo;t find what you needed?</p>
                <div class="faq-foot-actions">
                  <a class="faq-foot-btn" href="https://github.com/gparker97/beanies-family/issues">
                    <span aria-hidden="true">🐙</span> open an issue
                  </a>
                  <a class="faq-foot-btn faq-foot-btn-alt" href="/#contact">
                    <span aria-hidden="true">✉</span> contact greg
                  </a>
                </div>
              </footer>
            </div>
          </div>
        </div>
      </article>

      <script is:inline>
        // Filter + scroll-spy, zero-deps. Runs once on initial load and on
        // input; the DOM is fully server-rendered and remains crawlable.
        (function () {
          var input = document.getElementById('faq-filter');
          var clear = document.getElementById('faq-filter-clear');
          var count = document.getElementById('faq-filter-count');
          var empty = document.getElementById('faq-empty');
          var items = Array.prototype.slice.call(document.querySelectorAll('[data-faq-item]'));
          var sections = Array.prototype.slice.call(document.querySelectorAll('[data-category-section]'));
          var links = Array.prototype.slice.call(document.querySelectorAll('[data-category-link]'));
          if (!input || !count || !empty) return;
          var total = items.length;

          // Pre-compute searchable text per item so we don't crawl the DOM on
          // every keystroke.
          var itemText = items.map(function (el) {
            return (el.textContent || '').toLowerCase();
          });

          function apply(q) {
            var needle = (q || '').trim().toLowerCase();
            var shown = 0;
            items.forEach(function (el, i) {
              var match = needle === '' || itemText[i].indexOf(needle) !== -1;
              el.hidden = !match;
              if (match) shown += 1;
            });
            // Hide a section whose items are all filtered out.
            sections.forEach(function (sec) {
              var any = sec.querySelectorAll('[data-faq-item]:not([hidden])').length > 0;
              sec.hidden = !any;
            });
            count.textContent = needle === ''
              ? total + ' of ' + total
              : shown + ' of ' + total + ' match';
            empty.hidden = shown !== 0;
            if (clear) clear.hidden = needle === '';
          }

          input.addEventListener('input', function () { apply(input.value); });
          if (clear) clear.addEventListener('click', function () {
            input.value = '';
            input.focus();
            apply('');
          });

          // Scroll-spy: highlight the sidebar link whose section is currently
          // at the top of the viewport. IntersectionObserver keeps this cheap.
          if ('IntersectionObserver' in window && links.length > 0) {
            var byId = {};
            links.forEach(function (a) {
              var k = a.getAttribute('data-category-link');
              if (k) byId[k] = a;
            });
            var active = null;
            var io = new IntersectionObserver(function (entries) {
              var visible = entries
                .filter(function (e) { return e.isIntersecting; })
                .sort(function (a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
              if (!visible[0]) return;
              var slug = visible[0].target.getAttribute('data-category-section');
              if (!slug) return;
              var next = byId[slug];
              if (!next || next === active) return;
              if (active) active.classList.remove('is-active');
              next.classList.add('is-active');
              active = next;
            }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });
            sections.forEach(function (s) { io.observe(s); });
          }
        })();
      </script>
    </BaseLayout>
  )
}

<style>
  .faq-page {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --cloud-white: #f8f9fa;
    --kraft: #f3ecd8;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', 'Fraunces', 'Source Serif 4', Georgia, serif;
    background: var(--cloud-white);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  .faq-atmo {
    background:
      radial-gradient(circle at 8% 18%, rgb(241 93 34 / 6%) 0%, transparent 42%),
      radial-gradient(circle at 92% 8%, rgb(174 214 241 / 9%) 0%, transparent 46%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .faq-mascot {
    filter: drop-shadow(0 14px 30px rgb(44 62 80 / 12%));
    pointer-events: none;
    position: absolute;
    right: -28px;
    top: 82px;
    transform: rotate(-8deg);
    width: 180px;
    z-index: 0;
  }

  .faq-shell {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 1180px;
    padding: 104px 32px 72px;
    position: relative;
    z-index: 1;
  }

  /* ===== HERO ===== */
  .faq-hero { margin-bottom: 44px; }
  .faq-kicker {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: 0.22em;
    margin: 20px 0 18px;
    text-transform: uppercase;
  }
  .faq-kicker-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgb(241 93 34 / 15%);
    display: inline-block;
    height: 8px;
    width: 8px;
  }
  .faq-title {
    color: var(--deep-slate);
    font-family: var(--font-serif);
    line-height: 0.92;
    margin: 0 0 20px;
  }
  .faq-title-over {
    display: block;
    font-size: clamp(1.75rem, 3.6vw, 2.6rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    opacity: 0.78;
  }
  .faq-title-under {
    color: var(--deep-slate);
    display: block;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-top: 2px;
    text-transform: lowercase;
  }
  .faq-intro {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
    max-width: 620px;
  }
  .faq-intro a {
    color: var(--heritage-orange);
    font-weight: 600;
