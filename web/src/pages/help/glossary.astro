---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DraftPlaceholder from '../../components/DraftPlaceholder.astro';
import { isDraftHidden } from '~/utils/draftPage';
import { SITE_URL } from '@beanies/brand/nav';
// Fraunces for the serif flourishes in the title + term names. Scoped
// to this route via the plain import.
import '@fontsource-variable/fraunces';

const DRAFT = true;
const hidden = isDraftHidden(DRAFT);

/**
 * Product + concept glossary. Each term renders as an <article> with an
 * anchor id (so URLs like /help/glossary#crdt jump there), and all terms
 * are aggregated into a single DefinedTermSet JSON-LD block so AI crawlers
 * can index individual terms for citation.
 */
type Term = {
  id: string;
  term: string;
  /** Short definition (1-2 sentences, quotable — the AI-citation chunk). */
  short: string;
  /** Optional longer elaboration rendered as HTML after the short definition. */
  long?: string;
};

const terms: Term[] = [
  {
    id: 'beanies-family',
    term: 'beanies.family',
    short:
      'A local-first, privacy-first web app for family planning — finances, activities, goals, and shared logistics, all in a single encrypted file that lives on your device.',
    long: 'Built as an alternative to cloud-native family apps that harvest data. Open source (MIT), works offline, optional Google Drive sync with client-side end-to-end encryption (E2EE).',
  },
  {
    id: 'pod',
    term: 'pod',
    short:
      "A family's private data unit in beanies.family. One pod holds everything one family tracks: members, finances, activities, goals, travel.",
    long: 'Each pod is backed by a single <code>.beanpod</code> file that the family controls. Inviting family members grants them access to the same pod. Each family gets their own, totally independent pod file.',
  },
  {
    id: 'beanpod-file',
    term: '.beanpod file',
    short:
      'The encrypted file format that holds an entire family pod. A single <code>.beanpod</code> is a portable, self-contained backup — you can email it, save it to a USB stick, or sync it to Google Drive.',
    long: 'Internally it is an Automerge CRDT document wrapped in an AES-GCM-encrypted envelope (V4 format). Without the pod password, the contents are unreadable — not even the beanies team can decrypt it. Unencrypted, a <code>.beanpod</code> file is just a simple text file containing data in JSON format (despite the extension).',
  },
  {
    id: 'bean-beanie',
    term: 'bean / beanie',
    short:
      'The affectionate term for a family member inside the beanies.family app. Each family member has a personalized bean avatar or a user uploaded photo avatar.',
    long: "Every beanie on screen is a real person (or pet) in your family. The brand philosophy is that every family member counts, including the smallest ones, and yes — even the pets. Hence the motto: 'every bean counts'.",
  },
  {
    id: 'family-nook',
    term: 'family nook',
    short:
      "The home screen of the app — a personalized, informative dashboard showing what's happening in your family today, this week, and in the near future.",
    long: 'Designed to be the single source of truth a family member checks first thing in the morning. Replaces the need for separate calendar, to-do, and finance apps open simultaneously.',
  },
  {
    id: 'local-first',
    term: 'local-first',
    short:
      'A software architecture where data lives on the user\'s device first and the cloud is optional. Local-first apps work offline, do not require an account on a remote server, and survive the company going out of business. See our <a href="/guides/local-first-family-finance-planning-tools">local-first guide</a> for more info.',
    long: 'The term local-first was popularized by the <a href="https://www.inkandswitch.com/local-first/">Ink &amp; Switch essay</a> of the same name. Local-first is a core positioning choice for beanies.family — your family data should belong to you, and does not require a server or database owned by someone else.',
  },
  {
    id: 'crdt',
    term: 'CRDT',
    short:
      'Conflict-free Replicated Data Type. A class of data structures that can be edited on multiple devices at once and reliably merged back together without conflicts — even if the edits happened offline.',
    long: 'CRDTs make it possible for two parents on two devices to both edit the family calendar at the same time, even when offline, and have the changes merge cleanly when they reconnect. beanies.family uses the Automerge CRDT library for its entire data layer.',
  },
  {
    id: 'automerge',
    term: 'Automerge',
    short:
      'The specific CRDT library beanies.family uses under the hood. An open-source project originally from the University of Cambridge and Ink & Switch that provides a JSON-like data structure with automatic conflict-free merging.',
    long: 'Automerge is loaded into the browser as a WebAssembly module (~2.6 MB). The family pod is stored as an Automerge document in memory, cached to IndexedDB, and persisted as the <code>.beanpod</code> file.',
  },
  {
    id: 'e2ee',
    term: 'end-to-end encryption (E2EE)',
    short:
      'Encryption where only the endpoints (you and your family) can read the data. Intermediate servers, including the service provider, see only ciphertext and cannot decrypt it. More info about E2EE is in the <a href="/guides/local-first-family-finance-planning-tools#end-to-end-encryption-explained-without-the-math">end-to-end encryption section</a> of the local-first guide.',
    long: "beanies.family's optional Google Drive sync is E2EE: the <code>.beanpod</code> file is encrypted with your pod password before it leaves your browser. Google stores the ciphertext, cannot read the file. No beanies server ever touches your data.",
  },
  {
    id: 'aes-gcm',
    term: 'AES-GCM',
    short:
      'The symmetric encryption algorithm used to encrypt the contents of the <code>.beanpod</code> file. Industry-standard authenticated encryption with a 256-bit key.',
    long: 'AES-GCM provides both confidentiality (nobody can read the file without the key) and integrity (any tampering is detected on decryption). Implemented directly via the browser\'s native Web Crypto API. No third-party crypto libraries are used.',
  },
  {
    id: 'aes-kw',
    term: 'AES-KW',
    short:
      "AES Key Wrap — a smaller companion algorithm used by beanies.family to encrypt per-member copies of the family's master encryption key. Each family member has their own key (passphrase), which both identifies the family member and unlocks your family's <code>.beanpod</code> file.",
    long: "When you invite a new family member, beanies.family wraps the family master key with a key derived from that family member's passphrase. They unwrap it on their device. The master key itself is never exposed in plaintext across the network.",
  },
  {
    id: 'web-crypto-api',
    term: 'Web Crypto API',
    short:
      "The browser's built-in cryptography toolkit. All encryption, decryption, key derivation, and key wrapping in beanies.family uses the native Web Crypto API rather than a third-party library.",
    long: 'Using the browser-native API means the cryptographic primitives are audited by browser vendors (Chromium, Firefox, Safari security teams). There is no beanies.family specific crypto code to review — the code just calls <code>crypto.subtle.encrypt()</code> and trusts the browser.',
  },
  {
    id: 'pwa',
    term: 'PWA (Progressive Web App)',
    short:
      'A web app that can be installed on a phone, tablet, or desktop, and behaves like a native app once installed. PWAs have a home-screen icon, full-screen launch, and offline support.',
    long: 'beanies.family is usable in your phone\'s browser or installable as a PWA. Both have the same functionality. You can install the PWA via your browser\'s "Install app" or "Add to Home Screen" option — see the <a href="/help/getting-started/install-as-app">install guide</a> for step-by-step instructions per platform.',
  },
  {
    id: 'google-drive-sync',
    term: 'Google Drive sync',
    short:
      'Optional cross-device backup for your pod. beanies.family can save the encrypted <code>.beanpod</code> file to your personal Google Drive so you can load it on another device and share data with your family members.',
    long: 'Sync is opt-in, and uses the <code>drive.file</code> OAuth scope. beanies.family can only see files it created in your Drive, and never any other files. The synced file is encrypted client-side before upload — Google sees ciphertext only. More detail in the <a href="/guides/local-first-family-finance-planning-tools#end-to-end-encryption-explained-without-the-math">encryption section</a> of the local-first guide.',
  },
  {
    id: 'mental-load',
    term: 'mental load',
    short:
      "The invisible cognitive labor of running a household. Includes things like remembering birthdays, tracking appointments, planning meals, knowing your kid's allergies, and more. Often concentrated in one parent, and rarely discussed explicitly. More in the <a href=\"/guides/overwhelmed-family-planning#family-overwhelm-is-a-compounding-problem\">overwhelmed guide</a>.",
    long: "The concept of \"mental load\" was popularised by <a href=\"https://www.fairplaylife.com/\">Eve Rodsky's \"Fair Play\"</a> and is a driver of family-planning overwhelm — see the <a href=\"/guides/overwhelmed-family-planning#share-the-mental-load-here-are-some-scripts-for-the-hard-conversations\">sharing-the-load scripts</a> in the overwhelmed guide. beanies.family's shared-pod model is designed so mental load can be externalised and redistributed. Once it's in the pod, anyone in the family can see and own it.",
  },
  {
    id: 'kin-keeping',
    term: 'kin-keeping',
    short:
      'The sociological term for the unpaid work of maintaining family relationships, including things like remembering to call grandma, organizing the birthday dinner, keeping track of extended-family events and milestones.',
    long: 'Closely related to mental load, but specifically the relational/ceremonial labor across extended family. Historically gendered work. A family-planning app that accounts for kin-keeping (not just task scheduling) meets the actual reality of raising a family more accurately than a generic calendar does.',
  },
  {
    id: 'indexeddb',
    term: 'IndexedDB',
    short:
      "The browser's built-in local database, used by beanies.family as a temporary cache for your family's decrypted pod data, and as PWA offline support.",
    long: 'The cache can be deleted on sign-out, so leaving a device clears all decrypted data from that device. The authoritative copy of your pod lives in the <code>.beanpod</code> file; IndexedDB is just a performance cache.',
  },
  {
    id: 'pod-password',
    term: 'pod password',
    short:
      "The password that encrypts your family's <code>.beanpod</code> file. Without it, the pod cannot be decrypted — not by you, not by beanies, not by anyone.",
    long: 'Given the <a href="/guides/local-first-family-finance-planning-tools">local-first</a> nature of the app, password recovery for a <code>.beanpod</code> file is not possible. If you lose the pod password and don\'t have the file cached on any device, the pod is unrecoverable. beanies.family strongly recommends writing it down somewhere safe.',
  },
  {
    id: 'the-beanstalk',
    term: 'the beanstalk',
    short:
      'The name for the beanies.family <a href="/blog">blog</a>, where greg talks about the latest news, features, and anything else he wants to talk about. You can also subscribe to receive updates in your inbox on <a href="https://gpbeanies.substack.com">Substack</a>.',
  },
];

const canonicalPath = '/help/glossary';

/**
 * "Core vocabulary" — the terms someone has to understand to read the
 * rest of the glossary + the product docs. Marked with a ribbon on the
 * card so a first-time reader can see where to start. Keep this list
 * small (4-6 entries); if everything is "core", nothing is.
 */
const CORE_TERMS = new Set<string>([
  'beanies-family',
  'pod',
  'beanpod-file',
  'local-first',
  'e2ee',
]);

/**
 * Normalize a term for sorting: strip a leading `.` or `the ` so
 * `.beanpod file` buckets under B and `the beanstalk` buckets under B.
 * Lowercased so case doesn't scramble the order.
 */
function sortKey(name: string): string {
  return name
    .toLowerCase()
    .replace(/^\./, '')
    .replace(/^the\s+/, '')
    .trim();
}

function firstLetter(name: string): string {
  const key = sortKey(name);
  const first = key[0]?.toUpperCase() ?? '#';
  return /[A-Z]/.test(first) ? first : '#';
}

/** Alphabet strip: 26 letters, each active if any term buckets under it. */
const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

// Sort + bucket.
const sortedTerms = [...terms].sort((a, b) => sortKey(a.term).localeCompare(sortKey(b.term)));
const bucketMap = new Map<string, Term[]>();
for (const t of sortedTerms) {
  const letter = firstLetter(t.term);
  if (!bucketMap.has(letter)) bucketMap.set(letter, []);
  bucketMap.get(letter)!.push(t);
}

const sections = ALPHABET
  .filter((letter) => bucketMap.has(letter))
  .map((letter) => ({
    letter,
    id: `letter-${letter.toLowerCase()}`,
    terms: bucketMap.get(letter) ?? [],
  }));

const activeLetters = new Set(sections.map((s) => s.letter));

/**
 * Compute cross-links ("see also") for each term. Heuristic: for term T,
 * find other terms whose name appears as a substring in T's short or
 * long text (case-insensitive, strip HTML tags + parentheticals from the
 * haystack). Skip self-matches and stop at three entries so the chip
 * row stays tidy.
 */
function stripHtml(s: string): string {
  return s.replace(/<[^>]+>/g, ' ').toLowerCase();
}
function normalizeTermName(name: string): string {
  return name
    .toLowerCase()
    .replace(/\s*\([^)]*\)\s*/g, ' ') // drop parentheticals like "(E2EE)"
    .replace(/\s*\/\s*/g, ' ') // "bean / beanie" -> "bean beanie"
    .replace(/\./g, '')
    .trim();
}
const relatedFor = new Map<string, Term[]>();
for (const t of terms) {
  const hay = stripHtml(`${t.short} ${t.long ?? ''}`);
  const hits: Term[] = [];
  for (const other of terms) {
    if (other.id === t.id) continue;
    const needle = normalizeTermName(other.term);
    if (needle.length < 3) continue;
    // Word-boundary check so "e2ee" doesn't match "tree" etc.
    const re = new RegExp(`(^|[^a-z0-9])${needle.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&')}([^a-z0-9]|$)`);
    if (re.test(hay)) hits.push(other);
    if (hits.length >= 3) break;
  }
  relatedFor.set(t.id, hits);
}

// DefinedTermSet JSON-LD — each term becomes a DefinedTerm the AI can cite.
const glossarySchema = {
  '@type': 'DefinedTermSet',
  '@id': `${SITE_URL}${canonicalPath}#glossary`,
  name: 'beanies.family glossary',
  description:
    'definitions of product terms, concepts, and technology used by beanies.family and in family planning generally.',
  hasDefinedTerm: terms.map((t) => ({
    '@type': 'DefinedTerm',
    '@id': `${SITE_URL}${canonicalPath}#${t.id}`,
    name: t.term,
    description: t.short,
    inDefinedTermSet: `${SITE_URL}${canonicalPath}#glossary`,
  })),
};
---

{
  hidden ? (
    <DraftPlaceholder backHref="/help" backLabel="back to help" />
  ) : (
    <BaseLayout
      title="glossary — beanies.family"
      description="definitions of the terms, concepts, and technology used throughout beanies.family. from CRDTs to kin-keeping."
      canonicalPath={canonicalPath}
      jsonLd={glossarySchema}
    >
      <article class="glossary-page">
        <div class="glossary-atmo" aria-hidden="true"></div>
        <img
          src="/brand/beanies_neutral_icon_transparent_350x350.png"
          alt=""
          class="glossary-mascot"
          width="180"
          height="180"
          aria-hidden="true"
        />

        <div class="glossary-shell">
          <header class="glossary-hero">
            <Breadcrumbs items={[{ label: 'home', href: '/' }, { label: 'help', href: '/help' }, { label: 'glossary', href: canonicalPath }]} />
            <p class="glossary-kicker">
              <span class="glossary-kicker-dot" aria-hidden="true"></span>
              the lexicon · {terms.length} defined
            </p>
            <h1 class="glossary-title">
              <span class="glossary-title-over">the</span>
              <span class="glossary-title-under">glossary</span>
            </h1>
            <p class="glossary-intro">
              definitions of the product terms, family-planning concepts, and technology
              you&rsquo;ll see across beanies.family. each entry is linkable &mdash; use
              the <code>#anchor</code> in the URL to share a specific definition.
            </p>
          </header>

          <!-- Alphabet strip. Letters without terms are rendered as spans
               (not links) and dimmed so the scanner sees the whole alphabet
               but can't click into empty sections. Sticky on desktop so
               it rides with the reader. -->
          <nav class="glossary-alphabet" aria-label="jump to letter">
            <ol class="glossary-alphabet-strip">
              {ALPHABET.map((letter) => (
                activeLetters.has(letter) ? (
                  <li class="glossary-alpha glossary-alpha-on">
                    <a href={`#letter-${letter.toLowerCase()}`}>{letter}</a>
                  </li>
                ) : (
                  <li class="glossary-alpha glossary-alpha-off">
                    <span>{letter}</span>
                  </li>
                )
              ))}
            </ol>
          </nav>

          <div class="glossary-sections">
            {sections.map((section) => (
              <section class="glossary-section" id={section.id}>
                <header class="glossary-section-head">
                  <span class="glossary-section-letter" aria-hidden="true">{section.letter}</span>
                  <span class="glossary-section-meta">
                    {`${section.terms.length} ${section.terms.length === 1 ? 'term' : 'terms'}`}
                  </span>
                  <span class="glossary-section-rule" aria-hidden="true"></span>
                </header>
                <div class="glossary-section-terms">
                  {section.terms.map((t) => {
                    const related = relatedFor.get(t.id) ?? [];
                    const isCore = CORE_TERMS.has(t.id);
                    return (
                      <article
                        class={`glossary-term${isCore ? ' is-core' : ''}`}
                        id={t.id}
                      >
                        {isCore && <span class="glossary-core-ribbon" aria-label="core vocabulary">core</span>}
                        <h2 class="glossary-term-name">{t.term}</h2>
                        <div class="glossary-term-short" set:html={t.short} />
                        {t.long && <div class="glossary-term-long" set:html={t.long} />}
                        {related.length > 0 && (
                          <div class="glossary-related">
                            <span class="glossary-related-label">see also</span>
                            <ul class="glossary-related-list">
                              {related.map((r) => (
                                <li><a href={`#${r.id}`}>{r.term}</a></li>
                              ))}
                            </ul>
                          </div>
                        )}
                        <a class="glossary-term-anchor" href={`#${t.id}`} aria-label={`copy link to ${t.term}`}>#</a>
                      </article>
                    );
                  })}
                </div>
              </section>
            ))}
          </div>

          <footer class="glossary-foot">
            <p class="glossary-foot-copy">
              spotted a missing term or a definition that could be clearer?
              <a href="/#contact">get in touch</a>
              and we&rsquo;ll add or refine it.
            </p>
          </footer>
        </div>
      </article>
    </BaseLayout>
  )
}

<style is:global>
  /* is:global is required here because several selectors (glossary-term
     -short a, glossary-term-long a, strong, code, etc.) target HTML
     injected via set:html from each term's definition. Astro's default
     scoping rewrites those descendant selectors to require the scope
     attribute on BOTH the parent AND the descendant, but set:html
     content never carries the scope attribute. Every selector below is
     namespaced under `.glossary-page` / glossary-* class prefixes so
     these rules don't leak to other pages. */
  .glossary-page {
    --deep-slate: #2c3e50;
    --heritage-orange: #f15d22;
    --terracotta: #e67e22;
    --cloud-white: #f8f9fa;
    --ink: #1f2d3d;
    --muted: rgb(44 62 80 / 60%);
    --hairline: rgb(44 62 80 / 8%);
    --font-display: 'Outfit Variable', Outfit, system-ui, sans-serif;
    --font-serif: 'Fraunces Variable', 'Fraunces', 'Source Serif 4', Georgia, serif;
    background: var(--cloud-white);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  .glossary-atmo {
    background:
      radial-gradient(circle at 88% 12%, rgb(241 93 34 / 6%) 0%, transparent 42%),
      radial-gradient(circle at 12% 82%, rgb(174 214 241 / 8%) 0%, transparent 46%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .glossary-mascot {
    filter: drop-shadow(0 14px 30px rgb(44 62 80 / 12%));
    pointer-events: none;
    position: absolute;
    right: -20px;
    top: 88px;
    transform: rotate(6deg);
    width: 160px;
    z-index: 0;
  }

  .glossary-shell {
    box-sizing: border-box;
    margin: 0 auto;
    max-width: 960px;
    padding: 104px 32px 72px;
    position: relative;
    z-index: 1;
  }

  /* ===== HERO ===== */
  .glossary-hero { margin-bottom: 36px; }
  .glossary-kicker {
    align-items: center;
    color: var(--heritage-orange);
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    gap: 10px;
    letter-spacing: 0.22em;
    margin: 20px 0 18px;
    text-transform: uppercase;
  }
  .glossary-kicker-dot {
    background: var(--heritage-orange);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgb(241 93 34 / 15%);
    display: inline-block;
    height: 8px;
    width: 8px;
  }
  .glossary-title {
    color: var(--deep-slate);
    font-family: var(--font-serif);
    line-height: 0.92;
    margin: 0 0 20px;
  }
  .glossary-title-over {
    display: block;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    opacity: 0.78;
  }
  .glossary-title-under {
    color: var(--deep-slate);
    display: block;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-top: 2px;
    text-transform: lowercase;
  }
  .glossary-intro {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
    max-width: 620px;
  }
  .glossary-intro code {
    background: rgb(44 62 80 / 5%);
    border-radius: 4px;
    font-family: ui-monospace, monospace;
    font-size: 0.85em;
    padding: 0.1em 0.35em;
  }

  /* ===== ALPHABET STRIP ===== */
  .glossary-alphabet {
    background: white;
    border: 1px solid var(--hairline);
    border-radius: 16px;
    box-shadow: 0 2px 12px rgb(44 62 80 / 4%);
    margin-bottom: 48px;
    padding: 10px 14px;
  }
  @media (min-width: 960px) {
    .glossary-alphabet {
      position: sticky;
      top: 84px;
      z-index: 5;
    }
  }
  .glossary-alphabet-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .glossary-alpha {
    line-height: 1;
  }
  .glossary-alpha a,
  .glossary-alpha span {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    height: 32px;
    justify-content: center;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background-color 150ms, color 150ms, transform 150ms;
    width: 30px;
  }
  .glossary-alpha-on a {
    color: var(--deep-slate);
  }
  .glossary-alpha-on a:hover {
    background: color-mix(in srgb, var(--heritage-orange) 14%, white);
    color: var(--heritage-orange);
    transform: translateY(-1px);
  }
  .glossary-alpha-off span {
    color: rgb(44 62 80 / 20%);
    cursor: default;
  }

  /* ===== SECTIONS ===== */
  .glossary-sections {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }
  .glossary-section { scroll-margin-top: 132px; }
  .glossary-section-head {
    align-items: flex-end;
    display: flex;
    gap: 18px;
    margin-bottom: 20px;
  }
  .glossary-section-letter {
    color: var(--heritage-orange);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 5rem);
    font-style: italic;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.85;
  }
  .glossary-section-meta {
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
