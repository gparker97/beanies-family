---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOFTWARE_APPLICATION } from '@beanies/brand/schema';
import { APP_URL } from '@beanies/brand/nav';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="beanies.family — every bean counts"
  description="beanies.family is the focal point of your family — local-first, privacy-first planning for finances, activities, goals, and more. Every bean counts."
  canonicalPath="/"
  jsonLd={SOFTWARE_APPLICATION}
>
  <section class="relative overflow-hidden">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-10 px-6 py-20 text-center sm:py-28">
      <img
        src="/brand/beanies_family_hugging_transparent_1024x1024.png"
        alt="the beanies family hugging"
        width="220"
        height="220"
        class="h-44 w-44"
        fetchpriority="high"
      />
      <div class="space-y-4">
        <h1 class="font-outfit text-4xl font-bold text-secondary-500 sm:text-5xl">
          every bean counts
        </h1>
        <p class="mx-auto max-w-xl text-lg text-secondary-400">
          beanies.family is the focal point of your family — plan finances, activities, and goals
          together. local-first, private, and yours.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href={`${APP_URL}/join`}
          class="rounded-xl bg-primary-500 px-6 py-3 font-outfit font-semibold text-white transition-colors hover:bg-primary-600"
        >
          start your family pod
        </a>
        <a
          href="/blog"
          class="rounded-xl border border-secondary-100 bg-white px-6 py-3 font-outfit font-semibold text-secondary-500 transition-colors hover:border-primary-400 hover:text-primary-500"
        >
          read the beanstalk
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-3">
      <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h2 class="font-outfit text-lg font-semibold text-secondary-500">local-first</h2>
        <p class="mt-2 text-sm text-secondary-400">
          your family's data lives on your device, not in our database. we don't have one.
        </p>
      </div>
      <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h2 class="font-outfit text-lg font-semibold text-secondary-500">end-to-end encrypted</h2>
        <p class="mt-2 text-sm text-secondary-400">
          optional Google Drive sync uses AES-GCM encryption. your key, your data.
        </p>
      </div>
      <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h2 class="font-outfit text-lg font-semibold text-secondary-500">built for families</h2>
        <p class="mt-2 text-sm text-secondary-400">
          accounts, activities, goals, to-dos, and travel — organized around the people you love.
        </p>
      </div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="mx-auto max-w-6xl px-6 py-16">
        <div class="mb-8 flex items-end justify-between">
          <h2 class="font-outfit text-2xl font-semibold text-secondary-500">from the beanstalk</h2>
          <a href="/blog" class="text-sm text-primary-500 hover:text-primary-600">see all posts →</a>
        </div>
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.data.slug}`}
                class="block rounded-2xl bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
              >
                {post.data.coverEmoji && (
                  <span class="text-3xl" aria-hidden="true">
                    {post.data.coverEmoji}
                  </span>
                )}
                <h3 class="mt-3 font-outfit text-lg font-semibold text-secondary-500">
                  {post.data.title}
                </h3>
                <p class="mt-2 line-clamp-3 text-sm text-secondary-400">{post.data.excerpt}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
